{
  "name": "shardtown-desktop",
  "version": "0.1.1",
  "private": true,
  "description": "Shardtown dashboard wrapper for macOS",
  "main": "main.js",
  "author": "Shardtown",
  "scripts": {
    "start": "electron .",
    "dist:mac": "electron-builder --mac dmg --x64 --arm64"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "fr.shardtwn.dashboard",
    "productName": "Shardtown",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "build/icon.png"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "icon": "build/icon.png",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "title": "Shardtown ${version}",
      "icon": "build/icon.png",
      "window": { "width": 540, "height": 380 },
      "contents": [
        { "x": 140, "y": 200, "type": "file" },
        { "x": 400, "y": 200, "type": "link", "path": "/Applications" }
      ]
    }
  }
}
