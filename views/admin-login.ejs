<!DOCTYPE html>
<html lang="fr" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <link rel="icon" type="image/png" href="/image/favicon.png">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ShardGuard | Administration</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #000000;
            --text: #ffffff;
            --accent: #ffffff;
            --muted: #888888;
            --border: #1a1a1a;
        }
        
        body { 
            font-family: 'Plus Jakarta Sans', sans-serif; 
            background: #000;
            background-image: 
                radial-gradient(at 50% 0%, rgba(37, 99, 235, 0.2) 0px, transparent 50%),
                radial-gradient(at 0% 100%, rgba(139, 92, 246, 0.1) 0px, transparent 50%),
                radial-gradient(at 100% 100%, rgba(236, 72, 153, 0.1) 0px, transparent 50%),
                radial-gradient(at 50% 50%, rgba(37, 99, 235, 0.05) 0px, transparent 50%);
            background-attachment: fixed;
            color: var(--text); 
            margin: 0;
            padding: 0;
        }

        .bg-glow {
            position: fixed;
            top: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 100%;
            height: 100vh;
            background: radial-gradient(circle at 50% -20%, rgba(37, 99, 235, 0.1) 0%, transparent 70%);
            pointer-events: none;
            z-index: -1;
        }

        .container-wide {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 24px;
        }

        .btn-white {
            background: #fff;
            color: #000;
            padding: 14px 32px;
            border-radius: 100px;
            font-weight: 700;
            font-size: 0.875rem;
            transition: opacity 0.2s;
            width: 100%;
            text-align: center;
            cursor: pointer;
            border: none;
        }

        .btn-white:hover {
            opacity: 0.9;
        }

        .login-card {
            background: #0a0a0a;
            border: 1px solid #1a1a1a;
            padding: 48px;
            border-radius: 24px;
        }

        .input-field {
            width: 100%;
            background: #0f0f0f;
            border: 1px solid #1a1a1a;
            border-radius: 12px;
            padding: 14px 18px;
            color: #fff;
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 0.9rem;
            font-weight: 500;
            outline: none;
            transition: border-color 0.2s;
            box-sizing: border-box;
        }

        .input-field:focus {
            border-color: #333;
        }

        .input-field::placeholder {
            color: #444;
        }

        .error-msg {
            background: rgba(239, 68, 68, 0.1);
            border: 1px solid rgba(239, 68, 68, 0.2);
            color: #f87171;
            padding: 12px 18px;
            border-radius: 12px;
            font-size: 0.875rem;
            font-weight: 600;
        }
    </style>
</head>
<body>
    <div class="bg-glow"></div>

    <div class="fixed top-6 left-0 right-0 z-50 px-6">
        <header id="main-header" class="container-wide flex justify-between items-center bg-transparent rounded-full transition-all duration-300 py-4 px-8 border border-white/10">
            <a href="/" class="flex items-center gap-2">
                <img src="/image/shardtown.jpeg" alt="Shardtown Logo" class="w-10 h-10 rounded-full object-cover">
                <span class="font-bold tracking-tight text-xl uppercase">Shardtown</span>
            </a>
        </header>
    </div>

    <script>
        window.addEventListener('scroll', () => {
            const header = document.getElementById('main-header');
            if (window.scrollY > 50) {
                header.classList.remove('bg-transparent', 'border-white/10');
                header.classList.add('bg-white/5', 'backdrop-blur-lg', 'border-white/5');
            } else {
                header.classList.add('bg-transparent', 'border-white/10');
                header.classList.remove('bg-white/5', 'backdrop-blur-lg', 'border-white/5');
            }
        });
    </script>

    <main class="min-h-screen flex items-center justify-center pt-32 pb-24 px-6">
        <div class="w-full max-w-md">
            <div class="text-center mb-10">
                <p class="text-sm font-bold tracking-widest text-white/40 uppercase mb-4">Accès Restreint</p>
                <h1 class="text-4xl font-bold uppercase tracking-tight">Administration</h1>
                <p class="text-white/40 text-sm mt-3">Espace réservé aux administrateurs Shardtown.</p>
            </div>

            <div class="login-card">
                <% if (typeof error !== 'undefined' && error) { %>
                    <div class="error-msg mb-6">Identifiants incorrects. Accès refusé.</div>
                <% } %>

                <form method="POST" action="/admin/login" class="flex flex-col gap-5">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <div>
                        <label class="text-xs font-bold text-white/40 uppercase tracking-widest block mb-2">Identifiant</label>
                        <input type="text" name="username" class="input-field" placeholder="Identifiant" required autocomplete="off">
                    </div>
                    <div>
                        <label class="text-xs font-bold text-white/40 uppercase tracking-widest block mb-2">Mot de Passe</label>
                        <input type="password" name="password" class="input-field" placeholder="••••••••••••" required>
                    </div>
                    <button type="submit" class="btn-white mt-2">Accéder</button>
                </form>
            </div>
        </div>
    </main>

    <footer class="py-10 border-t border-white/5">
        <div class="container-wide">
            <div class="flex flex-col md:flex-row justify-between items-center gap-4">
                <div class="flex items-center gap-2">
                    <img src="/image/shardtown.jpeg" alt="Shardtown Logo" class="w-6 h-6 rounded-full object-cover">
                    <span class="font-bold tracking-tight text-sm uppercase">Shardtown</span>
                </div>
                <div class="flex gap-8">
                    <a href="/terms" class="text-xs font-bold text-white/30 hover:text-white transition-colors">Conditions Générales</a>
                    <a href="/privacy" class="text-xs font-bold text-white/30 hover:text-white transition-colors">Politique de Confidentialité</a>
                    <a href="/admin" class="text-xs font-bold text-white hover:text-white transition-colors">Administrateur</a>
                </div>
                <p class="text-xs font-bold text-white/30">Copyright © 2026 Shardtown. Tous droits réservés.</p>
            </div>
        </div>
    </footer>
</body>
</html>
