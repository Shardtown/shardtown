<!DOCTYPE html>
<html lang="fr" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <link rel="icon" type="image/png" href="/image/favicon.png">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Premium — SHARDTOWN</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: #000;
            background-image:
                radial-gradient(at 50% 0%, rgba(251, 191, 36, 0.12) 0px, transparent 50%),
                radial-gradient(at 0% 100%, rgba(139, 92, 246, 0.08) 0px, transparent 50%),
                radial-gradient(at 100% 100%, rgba(251, 191, 36, 0.06) 0px, transparent 50%);
            background-attachment: fixed;
            color: #fff;
            margin: 0;
            padding: 0;
        }

        .bg-glow {
            position: fixed;
            top: 0; left: 50%;
            transform: translateX(-50%);
            width: 100%; height: 100vh;
            background: radial-gradient(circle at 50% -20%, rgba(251, 191, 36, 0.08) 0%, transparent 70%);
            pointer-events: none;
            z-index: -1;
        }

        .container-wide {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 24px;
        }

        .nav-link {
            color: #888;
            transition: color 0.2s;
            font-size: 0.875rem;
            font-weight: 500;
            text-decoration: none;
        }
        .nav-link:hover { color: #fff; }

        .feature-card {
            background: #0a0a0a;
            border: 1px solid #1a1a1a;
            border-radius: 20px;
            padding: 32px;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .feature-card:hover { border-color: rgba(251,191,36,0.2); }

        .feature-row {
            display: flex;
            align-items: flex-start;
            gap: 12px;
            padding: 10px 0;
            border-bottom: 1px solid rgba(255,255,255,0.04);
        }
        .feature-row:last-child { border-bottom: none; }

        .check-icon {
            width: 16px;
            height: 16px;
            border-radius: 50%;
            background: rgba(251,191,36,0.15);
            border: 1px solid rgba(251,191,36,0.3);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            margin-top: 2px;
        }

        .code-input {
            background: #0a0a0a;
            border: 1px solid #2a2a2a;
            border-radius: 12px;
            color: #fff;
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 1rem;
            font-weight: 700;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            outline: none;
            transition: border-color 0.2s, box-shadow 0.2s;
            padding: 16px 24px;
            width: 100%;
        }
        .code-input::placeholder { letter-spacing: 0.06em; text-transform: none; font-weight: 400; color: #444; }
        .code-input:focus { border-color: rgba(251,191,36,0.5); box-shadow: 0 0 0 3px rgba(251,191,36,0.08); }

        .guild-select {
            background: #0a0a0a;
            border: 1px solid #2a2a2a;
            border-radius: 12px;
            color: #fff;
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 0.9rem;
            outline: none;
            transition: border-color 0.2s;
            padding: 14px 20px;
            width: 100%;
            appearance: none;
            cursor: pointer;
        }
        .guild-select:focus { border-color: rgba(251,191,36,0.5); }
        .guild-select option { background: #111; }

        .btn-premium {
            background: linear-gradient(135deg, #fbbf24, #f59e0b);
            color: #000;
            border: none;
            border-radius: 12px;
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-weight: 800;
            font-size: 0.95rem;
            padding: 16px 32px;
            cursor: pointer;
            transition: opacity 0.2s, transform 0.15s;
            letter-spacing: 0.01em;
            width: 100%;
        }
        .btn-premium:hover { opacity: 0.9; transform: translateY(-1px); }
        .btn-premium:active { transform: translateY(0); }
        .btn-premium:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }

        .badge-free {
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 6px;
            padding: 2px 8px;
            font-size: 0.7rem;
            font-weight: 700;
            letter-spacing: 0.06em;
            text-transform: uppercase;
            color: rgba(255,255,255,0.4);
        }

        .badge-premium {
            background: rgba(251,191,36,0.15);
            border: 1px solid rgba(251,191,36,0.3);
            border-radius: 6px;
            padding: 2px 8px;
            font-size: 0.7rem;
            font-weight: 700;
            letter-spacing: 0.06em;
            text-transform: uppercase;
            color: #fbbf24;
        }

        .feat-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            padding: 13px 24px;
            border-bottom: 1px solid rgba(255,255,255,0.04);
        }
        .feat-row:last-child { border-bottom: none; }
        .feat-label { font-size: 0.875rem; color: rgba(255,255,255,0.65); flex: 1; min-width: 0; }
        .feat-pills { display: flex; align-items: center; gap: 8px; flex-shrink: 0; }
        .pill {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            font-size: 0.72rem;
            font-weight: 700;
            padding: 3px 10px;
            border-radius: 100px;
            white-space: nowrap;
        }
        .pill-free {
            background: rgba(255,255,255,0.05);
            color: rgba(255,255,255,0.35);
            border: 1px solid rgba(255,255,255,0.08);
        }
        .pill-premium {
            background: rgba(251,191,36,0.12);
            color: #fbbf24;
            border: 1px solid rgba(251,191,36,0.25);
        }
        .pill-none {
            background: transparent;
            color: rgba(255,255,255,0.15);
            border: 1px solid rgba(255,255,255,0.06);
        }
        .feat-table-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 10px 24px 10px;
            border-bottom: 1px solid #1a1a1a;
        }
        .feat-table-header-labels {
            display: flex;
            gap: 8px;
            flex-shrink: 0;
        }

        .alert-success {
            background: rgba(34,197,94,0.1);
            border: 1px solid rgba(34,197,94,0.25);
            border-radius: 12px;
            padding: 16px 20px;
            color: #86efac;
            font-size: 0.9rem;
            display: none;
        }
        .alert-error {
            background: rgba(239,68,68,0.1);
            border: 1px solid rgba(239,68,68,0.25);
            border-radius: 12px;
            padding: 16px 20px;
            color: #fca5a5;
            font-size: 0.9rem;
            display: none;
        }

        .price-card {
            background: #0a0a0a;
            border: 1px solid #1a1a1a;
            border-radius: 24px;
            padding: 36px 32px;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            display: flex;
            flex-direction: column;
            position: relative;
        }
        .price-card:hover { border-color: rgba(255,255,255,0.15); transform: translateY(-2px); }
        .price-card.featured {
            border-color: rgba(251,191,36,0.4);
            background: linear-gradient(180deg, rgba(251,191,36,0.04), #0a0a0a 60%);
        }
        .price-card.featured:hover { border-color: rgba(251,191,36,0.6); }
        .price-card .ribbon {
            position: absolute;
            top: -12px;
            left: 50%;
            transform: translateX(-50%);
            background: linear-gradient(135deg, #fbbf24, #f59e0b);
            color: #000;
            font-size: 0.68rem;
            font-weight: 800;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            padding: 5px 14px;
            border-radius: 100px;
            white-space: nowrap;
        }
        .price-amount {
            font-size: 3.25rem;
            font-weight: 800;
            letter-spacing: -0.03em;
            line-height: 1;
        }
        .price-period {
            color: rgba(255,255,255,0.4);
            font-size: 0.95rem;
            font-weight: 500;
        }
        .price-feat {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            font-size: 0.875rem;
            color: rgba(255,255,255,0.7);
            padding: 8px 0;
        }
        .price-feat svg { flex-shrink: 0; margin-top: 3px; }

        .btn-plan {
            display: block;
            width: 100%;
            padding: 14px 24px;
            border-radius: 12px;
            font-weight: 800;
            font-size: 0.9rem;
            text-align: center;
            cursor: pointer;
            transition: opacity 0.2s, transform 0.15s;
            border: none;
            font-family: 'Plus Jakarta Sans', sans-serif;
            text-decoration: none;
            letter-spacing: 0.01em;
        }
        .btn-plan-primary {
            background: linear-gradient(135deg, #fbbf24, #f59e0b);
            color: #000;
        }
        .btn-plan-secondary {
            background: rgba(255,255,255,0.06);
            color: #fff;
            border: 1px solid rgba(255,255,255,0.1);
        }
        .btn-plan:hover { opacity: 0.9; transform: translateY(-1px); }

        .plan-toggle {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 8px;
            background: #060606;
            border: 1px solid #1a1a1a;
            border-radius: 14px;
            padding: 6px;
        }
        .plan-toggle-option {
            display: flex;
            flex-direction: column;
            align-items: flex-start;
            gap: 2px;
            padding: 12px 16px;
            border-radius: 10px;
            cursor: pointer;
            transition: background 0.2s;
            border: 1px solid transparent;
        }
        .plan-toggle-option:hover { background: rgba(255,255,255,0.03); }
        .plan-toggle-option.active {
            background: rgba(251,191,36,0.08);
            border-color: rgba(251,191,36,0.3);
        }
        .plan-toggle-option input { display: none; }
        .plan-toggle-name {
            font-size: 0.78rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            color: rgba(255,255,255,0.5);
        }
        .plan-toggle-option.active .plan-toggle-name { color: #fbbf24; }
        .plan-toggle-price {
            font-size: 1rem;
            font-weight: 800;
            color: #fff;
        }
        .plan-toggle-sub {
            font-size: 0.7rem;
            color: rgba(255,255,255,0.35);
            font-weight: 500;
        }

        .feature-block { margin-bottom: 64px; }
        .feature-block:last-child { margin-bottom: 0; }

        .feature-block-header {
            display: flex;
            align-items: center;
            gap: 14px;
            margin-bottom: 28px;
            padding-bottom: 20px;
            border-bottom: 1px solid #181818;
        }
        .feature-block-header img {
            width: 44px; height: 44px;
            border-radius: 12px;
            object-fit: cover;
            border: 1px solid rgba(255,255,255,0.08);
        }
        .feature-block-header h3 {
            font-size: 1.25rem;
            font-weight: 800;
            letter-spacing: -0.01em;
        }
        .feature-block-header p {
            font-size: 0.825rem;
            color: rgba(255,255,255,0.4);
        }

        .limits-strip {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 10px;
            margin-bottom: 14px;
        }
        .limit-card {
            background: linear-gradient(180deg, rgba(251,191,36,0.04), #0a0a0a 70%);
            border: 1px solid #1a1a1a;
            border-radius: 14px;
            padding: 16px 18px;
        }
        .limit-label {
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: rgba(255,255,255,0.4);
            margin-bottom: 8px;
        }
        .limit-compare {
            display: flex;
            align-items: center;
            gap: 10px;
            font-weight: 800;
            font-size: 0.95rem;
        }
        .limit-from {
            color: rgba(255,255,255,0.3);
            text-decoration: line-through;
            text-decoration-color: rgba(255,255,255,0.15);
        }
        .limit-to { color: #fbbf24; }

        .premium-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 10px;
        }
        .premium-feat {
            position: relative;
            background: #0a0a0a;
            border: 1px solid #181818;
            border-radius: 16px;
            padding: 22px;
            transition: all 0.25s ease;
            overflow: hidden;
        }
        .premium-feat::before {
            content: "";
            position: absolute;
            inset: 0;
            background: radial-gradient(at 100% 0%, rgba(251,191,36,0.06), transparent 60%);
            opacity: 0;
            transition: opacity 0.3s;
            pointer-events: none;
        }
        .premium-feat:hover { border-color: rgba(251,191,36,0.25); transform: translateY(-2px); }
        .premium-feat:hover::before { opacity: 1; }

        .premium-feat-icon {
            width: 38px; height: 38px;
            border-radius: 10px;
            background: rgba(251,191,36,0.1);
            border: 1px solid rgba(251,191,36,0.2);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fbbf24;
            margin-bottom: 14px;
        }
        .premium-feat-title {
            font-size: 0.95rem;
            font-weight: 700;
            margin-bottom: 6px;
            letter-spacing: -0.005em;
        }
        .premium-feat-desc {
            font-size: 0.8rem;
            color: rgba(255,255,255,0.45);
            line-height: 1.5;
        }

        .subsection-label {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 14px;
        }
        .subsection-label-line {
            flex: 1;
            height: 1px;
            background: linear-gradient(90deg, rgba(255,255,255,0.08), transparent);
        }
        .subsection-label span {
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: rgba(255,255,255,0.35);
        }
    </style>
</head>
<body>
<div class="bg-glow"></div>

<!-- Header -->
<div class="fixed top-6 left-0 right-0 z-50 px-6">
    <header class="container-wide flex justify-between items-center bg-transparent rounded-full py-4 px-8 border border-white/10" style="background: rgba(0,0,0,0.6); backdrop-filter: blur(20px);">
        <a href="/" class="flex items-center gap-2">
            <img src="/image/shardtown.jpeg" alt="Shardtown Logo" class="w-10 h-10 rounded-full object-cover">
            <span class="font-bold tracking-tight text-xl uppercase">Shardtown</span>
        </a>
        <nav class="hidden md:flex items-center gap-8">
            <a href="/#products" class="nav-link">Produits</a>
            <a href="/#services" class="nav-link">Services</a>
            <a href="/wiki" class="nav-link">Wiki</a>
            <a href="/status" class="nav-link">Statut</a>
        </nav>
        <% if (user) { %>
            <div class="flex items-center gap-3 px-4 py-2 bg-white/5 rounded-full border border-white/5">
                <% if (user.avatar) { %>
                    <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" class="w-7 h-7 rounded-full" alt="">
                <% } else { %>
                    <div class="w-7 h-7 rounded-full bg-white/10 flex items-center justify-center text-xs font-bold"><%= user.username.charAt(0).toUpperCase() %></div>
                <% } %>
                <span class="text-sm font-semibold"><%= user.username %></span>
            </div>
        <% } else { %>
            <a href="/login?returnTo=/premium" class="px-5 py-2.5 rounded-full font-bold text-sm" style="background:#fff;color:#000;">Se connecter</a>
        <% } %>
    </header>
</div>

<main style="padding-top: 120px;">
    <!-- Hero -->
    <section class="py-20 text-center">
        <div class="container-wide">
            <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full mb-8" style="background:rgba(251,191,36,0.1);border:1px solid rgba(251,191,36,0.2);">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="#fbbf24" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                <span class="text-xs font-bold tracking-widest uppercase" style="color:#fbbf24;">Shardtown Premium</span>
            </div>
            <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight mb-6" style="line-height:0.92;">Tous les bots.<br><span style="color:#fbbf24;">Une seule offre.</span></h1>
            <p class="text-white/40 text-xl max-w-xl mx-auto mb-10">Débloquez l'ensemble des fonctionnalités avancées de ShardGuard et Shard sur votre serveur Discord.</p>
            <div class="flex justify-center gap-4 flex-wrap">
                <a href="#pricing" class="px-8 py-4 rounded-full font-bold text-sm" style="background:linear-gradient(135deg,#fbbf24,#f59e0b);color:#000;">Voir les tarifs</a>
                <a href="#features" class="px-8 py-4 rounded-full font-bold text-sm border border-white/10 text-white/70 hover:text-white hover:border-white/20 transition-colors">Voir les fonctionnalités</a>
            </div>
        </div>
    </section>

    <!-- Pricing -->
    <section id="pricing" class="py-16">
        <div class="container-wide">
            <div class="text-center mb-12">
                <p class="text-sm font-bold tracking-widest text-white/40 uppercase mb-3">Tarifs</p>
                <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight mb-3">Choisissez votre formule</h2>
                <p class="text-white/40">Une seule offre, deux façons de payer. Annulez à tout moment.</p>
            </div>

            <div class="grid md:grid-cols-2 gap-6 max-w-3xl mx-auto">

                <!-- Monthly plan -->
                <div class="price-card">
                    <div class="mb-2">
                        <span class="text-xs font-bold tracking-widest text-white/40 uppercase">Mensuel</span>
                    </div>
                    <div class="flex items-baseline gap-2 mb-1">
                        <span class="price-amount">4,97 €</span>
                        <span class="price-period">/ mois</span>
                    </div>
                    <p class="text-white/40 text-sm mb-6">Facturé chaque mois. Sans engagement.</p>

                    <div class="flex-1 mb-8">
                        <div class="price-feat">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#fbbf24" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                            <span>Toutes les fonctionnalités Premium</span>
                        </div>
                        <div class="price-feat">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#fbbf24" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                            <span>ShardGuard + Shard inclus</span>
                        </div>
                        <div class="price-feat">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#fbbf24" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                            <span>Mises à jour permanentes</span>
                        </div>
                        <div class="price-feat">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#fbbf24" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                            <span>Annulation en 1 clic</span>
                        </div>
                    </div>

                    <button class="btn-plan btn-plan-secondary" onclick="selectPlanAndScroll('monthly')">Choisir le mensuel</button>
                </div>

                <!-- Lifetime plan -->
                <div class="price-card featured">
                    <div class="ribbon">★ Meilleure offre — économisez 40%</div>
                    <div class="mb-2">
                        <span class="text-xs font-bold tracking-widest uppercase" style="color:#fbbf24;">À vie</span>
                    </div>
                    <div class="flex items-baseline gap-2 mb-1">
                        <span class="price-amount">49,97 €</span>
                        <span class="price-period">une fois</span>
                    </div>
                    <p class="text-white/40 text-sm mb-6">Paiement unique. Premium à vie sur le serveur.</p>

                    <div class="flex-1 mb-8">
                        <div class="price-feat">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#fbbf24" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                            <span>Toutes les fonctionnalités Premium</span>
                        </div>
                        <div class="price-feat">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#fbbf24" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                            <span>Aucun renouvellement, jamais</span>
                        </div>
                        <div class="price-feat">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#fbbf24" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                            <span>Équivaut à ~10 mois d'abonnement</span>
                        </div>
                        <div class="price-feat">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#fbbf24" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                            <span>Toutes les futures fonctionnalités</span>
                        </div>
                    </div>

                    <button class="btn-plan btn-plan-primary" onclick="selectPlanAndScroll('lifetime')">Choisir à vie</button>
                </div>
            </div>
        </div>
    </section>

    <!-- Premium features -->
    <section id="features" class="py-16">
        <div class="container-wide">
            <div class="text-center mb-14">
                <p class="text-sm font-bold tracking-widest text-white/40 uppercase mb-3">Fonctionnalités Premium</p>
                <h2 class="text-3xl md:text-5xl font-extrabold tracking-tight mb-4">Tout ce que vous débloquez</h2>
                <p class="text-white/40 max-w-xl mx-auto">Des limites étendues et des outils avancés sur les deux bots, pour transformer votre serveur.</p>
            </div>

            <!-- ShardGuard block -->
            <div class="feature-block">
                <div class="feature-block-header">
                    <img src="/image/shardguard.png" alt="ShardGuard">
                    <div>
                        <h3>ShardGuard</h3>
                        <p>Sécurité & Modération</p>
                    </div>
                </div>

                <div class="subsection-label">
                    <span>Limites étendues</span>
                    <div class="subsection-label-line"></div>
                </div>
