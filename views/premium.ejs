<!DOCTYPE html>
<html lang="fr" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <link rel="icon" type="image/png" href="/image/favicon.png">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Premium — SHARDTOWN</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: #000;
            background-image:
                radial-gradient(at 50% 0%, rgba(251, 191, 36, 0.12) 0px, transparent 50%),
                radial-gradient(at 0% 100%, rgba(139, 92, 246, 0.08) 0px, transparent 50%),
                radial-gradient(at 100% 100%, rgba(251, 191, 36, 0.06) 0px, transparent 50%);
            background-attachment: fixed;
            color: #fff;
            margin: 0;
            padding: 0;
        }

        .bg-glow {
            position: fixed;
            top: 0; left: 50%;
            transform: translateX(-50%);
            width: 100%; height: 100vh;
            background: radial-gradient(circle at 50% -20%, rgba(251, 191, 36, 0.08) 0%, transparent 70%);
            pointer-events: none;
            z-index: -1;
        }

        .container-wide {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 24px;
        }

        .nav-link {
            color: #888;
            transition: color 0.2s;
            font-size: 0.875rem;
            font-weight: 500;
            text-decoration: none;
        }
        .nav-link:hover { color: #fff; }

        .feature-card {
            background: #0a0a0a;
            border: 1px solid #1a1a1a;
            border-radius: 20px;
            padding: 32px;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .feature-card:hover { border-color: rgba(251,191,36,0.2); }

        .feature-row {
            display: flex;
            align-items: flex-start;
            gap: 12px;
            padding: 10px 0;
            border-bottom: 1px solid rgba(255,255,255,0.04);
        }
        .feature-row:last-child { border-bottom: none; }

        .check-icon {
            width: 16px;
            height: 16px;
            border-radius: 50%;
            background: rgba(251,191,36,0.15);
            border: 1px solid rgba(251,191,36,0.3);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            margin-top: 2px;
        }

        .code-input {
            background: #0a0a0a;
            border: 1px solid #2a2a2a;
            border-radius: 12px;
            color: #fff;
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 1rem;
            font-weight: 700;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            outline: none;
            transition: border-color 0.2s, box-shadow 0.2s;
            padding: 16px 24px;
            width: 100%;
        }
        .code-input::placeholder { letter-spacing: 0.06em; text-transform: none; font-weight: 400; color: #444; }
        .code-input:focus { border-color: rgba(251,191,36,0.5); box-shadow: 0 0 0 3px rgba(251,191,36,0.08); }

        .guild-select {
            background: #0a0a0a;
            border: 1px solid #2a2a2a;
            border-radius: 12px;
            color: #fff;
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 0.9rem;
            outline: none;
            transition: border-color 0.2s;
            padding: 14px 20px;
            width: 100%;
            appearance: none;
            cursor: pointer;
        }
        .guild-select:focus { border-color: rgba(251,191,36,0.5); }
        .guild-select option { background: #111; }

        .btn-premium {
            background: linear-gradient(135deg, #fbbf24, #f59e0b);
            color: #000;
            border: none;
            border-radius: 12px;
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-weight: 800;
            font-size: 0.95rem;
            padding: 16px 32px;
            cursor: pointer;
            transition: opacity 0.2s, transform 0.15s;
            letter-spacing: 0.01em;
            width: 100%;
        }
        .btn-premium:hover { opacity: 0.9; transform: translateY(-1px); }
        .btn-premium:active { transform: translateY(0); }
        .btn-premium:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }

        .badge-free {
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 6px;
            padding: 2px 8px;
            font-size: 0.7rem;
            font-weight: 700;
            letter-spacing: 0.06em;
            text-transform: uppercase;
            color: rgba(255,255,255,0.4);
        }

        .badge-premium {
            background: rgba(251,191,36,0.15);
            border: 1px solid rgba(251,191,36,0.3);
            border-radius: 6px;
            padding: 2px 8px;
            font-size: 0.7rem;
            font-weight: 700;
            letter-spacing: 0.06em;
            text-transform: uppercase;
            color: #fbbf24;
        }

        .comparison-row {
            display: grid;
            grid-template-columns: 1fr 120px 120px;
            gap: 16px;
            padding: 14px 20px;
            border-bottom: 1px solid rgba(255,255,255,0.04);
            align-items: center;
        }
        .comparison-row:last-child { border-bottom: none; }
        .comparison-header {
            background: #0a0a0a;
            border-radius: 12px 12px 0 0;
            padding: 16px 20px;
            border: 1px solid #1a1a1a;
            border-bottom: none;
        }
        .comparison-body {
            background: #0a0a0a;
            border-radius: 0 0 12px 12px;
            border: 1px solid #1a1a1a;
            overflow: hidden;
        }

        .alert-success {
            background: rgba(34,197,94,0.1);
            border: 1px solid rgba(34,197,94,0.25);
            border-radius: 12px;
            padding: 16px 20px;
            color: #86efac;
            font-size: 0.9rem;
            display: none;
        }
        .alert-error {
            background: rgba(239,68,68,0.1);
            border: 1px solid rgba(239,68,68,0.25);
            border-radius: 12px;
            padding: 16px 20px;
            color: #fca5a5;
            font-size: 0.9rem;
            display: none;
        }
    </style>
</head>
<body>
<div class="bg-glow"></div>

<!-- Header -->
<div class="fixed top-6 left-0 right-0 z-50 px-6">
    <header class="container-wide flex justify-between items-center bg-transparent rounded-full py-4 px-8 border border-white/10" style="background: rgba(0,0,0,0.6); backdrop-filter: blur(20px);">
        <a href="/" class="flex items-center gap-2">
            <img src="/image/shardtown.jpeg" alt="Shardtown Logo" class="w-10 h-10 rounded-full object-cover">
            <span class="font-bold tracking-tight text-xl uppercase">Shardtown</span>
        </a>
        <nav class="hidden md:flex items-center gap-8">
            <a href="/#products" class="nav-link">Produits</a>
            <a href="/premium" class="nav-link flex items-center gap-1.5" style="color:#fbbf24;">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="#fbbf24" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                Premium
            </a>
            <a href="/#services" class="nav-link">Services</a>
            <a href="/wiki" class="nav-link">Wiki</a>
            <a href="/status" class="nav-link">Statut</a>
        </nav>
        <% if (user) { %>
            <div class="flex items-center gap-3 px-4 py-2 bg-white/5 rounded-full border border-white/5">
                <% if (user.avatar) { %>
                    <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" class="w-7 h-7 rounded-full" alt="">
                <% } else { %>
                    <div class="w-7 h-7 rounded-full bg-white/10 flex items-center justify-center text-xs font-bold"><%= user.username.charAt(0).toUpperCase() %></div>
                <% } %>
                <span class="text-sm font-semibold"><%= user.username %></span>
            </div>
        <% } else { %>
            <a href="/login" class="px-5 py-2.5 rounded-full font-bold text-sm" style="background:#fff;color:#000;">Se connecter</a>
        <% } %>
    </header>
</div>

<main style="padding-top: 120px;">
    <!-- Hero -->
    <section class="py-20 text-center">
        <div class="container-wide">
            <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full mb-8" style="background:rgba(251,191,36,0.1);border:1px solid rgba(251,191,36,0.2);">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="#fbbf24" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                <span class="text-xs font-bold tracking-widest uppercase" style="color:#fbbf24;">Shardtown Premium</span>
            </div>
            <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight mb-6" style="line-height:0.92;">Tous les bots.<br><span style="color:#fbbf24;">Une seule offre.</span></h1>
            <p class="text-white/40 text-xl max-w-xl mx-auto mb-10">Débloquez l'ensemble des fonctionnalités avancées de ShardGuard et Shard sur votre serveur Discord.</p>
            <div class="flex justify-center gap-4 flex-wrap">
                <a href="#activate" class="px-8 py-4 rounded-full font-bold text-sm" style="background:linear-gradient(135deg,#fbbf24,#f59e0b);color:#000;">Activer Premium</a>
                <a href="#features" class="px-8 py-4 rounded-full font-bold text-sm border border-white/10 text-white/70 hover:text-white hover:border-white/20 transition-colors">Voir les fonctionnalités</a>
            </div>
        </div>
    </section>

    <!-- Comparison table -->
    <section id="features" class="py-16">
        <div class="container-wide">
            <div class="text-center mb-12">
                <p class="text-sm font-bold tracking-widest text-white/40 uppercase mb-3">Fonctionnalités</p>
                <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight">Gratuit vs Premium</h2>
            </div>

            <div class="grid md:grid-cols-2 gap-8 max-w-5xl mx-auto">

                <!-- ShardGuard -->
                <div>
                    <div class="flex items-center gap-3 mb-4">
                        <img src="/image/shardguard.png" class="w-9 h-9 rounded-xl object-cover border border-white/5" alt="">
                        <div>
                            <p class="font-extrabold text-sm">ShardGuard</p>
                            <p class="text-white/30 text-xs">Sécurité & Modération</p>
                        </div>
                    </div>
                    <div class="feature-card" style="padding:0; overflow:hidden;">
                        <div style="display:grid;grid-template-columns:1fr 80px 80px;gap:12px;padding:12px 20px;border-bottom:1px solid #1a1a1a;">
                            <span class="text-xs font-bold text-white/30 uppercase tracking-wider">Fonctionnalité</span>
                            <span class="text-xs font-bold text-white/30 uppercase tracking-wider text-center">Gratuit</span>
                            <span class="text-xs font-bold uppercase tracking-wider text-center" style="color:#fbbf24;">Premium</span>
                        </div>
                        <div style="padding:0 0 8px 0;">
                            <div class="comparison-row"><span class="text-sm text-white/70">Vérification Captcha</span><span class="text-center text-white/40">✓</span><span class="text-center" style="color:#fbbf24;">✓</span></div>
                            <div class="comparison-row"><span class="text-sm text-white/70">Mots interdits</span><span class="text-center text-xs text-white/40">3 max</span><span class="text-center text-xs" style="color:#fbbf24;">Illimités</span></div>
                            <div class="comparison-row"><span class="text-sm text-white/70">Règles auto-mod</span><span class="text-center text-xs text-white/40">3 max</span><span class="text-center text-xs" style="color:#fbbf24;">20 max</span></div>
                            <div class="comparison-row"><span class="text-sm text-white/70">Sanctions progressives</span><span class="text-center text-white/40">✓</span><span class="text-center" style="color:#fbbf24;">✓</span></div>
                            <div class="comparison-row"><span class="text-sm text-white/70">Anti-raid automatique</span><span class="text-center text-white/20">—</span><span class="text-center" style="color:#fbbf24;">✓</span></div>
                            <div class="comparison-row"><span class="text-sm text-white/70">Quarantaine auto</span><span class="text-center text-white/20">—</span><span class="text-center" style="color:#fbbf24;">✓</span></div>
                            <div class="comparison-row"><span class="text-sm text-white/70">Alerte modérateur DM</span><span class="text-center text-white/20">—</span><span class="text-center" style="color:#fbbf24;">✓</span></div>
                            <div class="comparison-row"><span class="text-sm text-white/70">Liste noire globale</span><span class="text-center text-white/20">—</span><span class="text-center" style="color:#fbbf24;">✓</span></div>
                            <div class="comparison-row" style="border-bottom:none;"><span class="text-sm text-white/70">Backup & restauration</span><span class="text-center text-white/20">—</span><span class="text-center" style="color:#fbbf24;">✓</span></div>
                        </div>
                    </div>
                </div>

                <!-- Shard -->
                <div>
                    <div class="flex items-center gap-3 mb-4">
                        <img src="/image/shard.png" class="w-9 h-9 rounded-xl object-cover border border-white/5" alt="">
                        <div>
                            <p class="font-extrabold text-sm">Shard</p>
                            <p class="text-white/30 text-xs">Engagement & Automatisation</p>
                        </div>
                    </div>
                    <div class="feature-card" style="padding:0; overflow:hidden;">
                        <div style="display:grid;grid-template-columns:1fr 80px 80px;gap:12px;padding:12px 20px;border-bottom:1px solid #1a1a1a;">
                            <span class="text-xs font-bold text-white/30 uppercase tracking-wider">Fonctionnalité</span>
                            <span class="text-xs font-bold text-white/30 uppercase tracking-wider text-center">Gratuit</span>
                            <span class="text-xs font-bold uppercase tracking-wider text-center" style="color:#fbbf24;">Premium</span>
                        </div>
                        <div style="padding:0 0 8px 0;">
                            <div class="comparison-row"><span class="text-sm text-white/70">Paliers XP</span><span class="text-center text-xs text-white/40">3 max</span><span class="text-center text-xs" style="color:#fbbf24;">20 max</span></div>
                            <div class="comparison-row"><span class="text-sm text-white/70">Multiplicateur XP par rôle</span><span class="text-center text-white/20">—</span><span class="text-center" style="color:#fbbf24;">✓</span></div>
                            <div class="comparison-row"><span class="text-sm text-white/70">Giveaways simultanés</span><span class="text-center text-xs text-white/40">1 max</span><span class="text-center text-xs" style="color:#fbbf24;">5 max</span></div>
                            <div class="comparison-row"><span class="text-sm text-white/70">Sondages anonymes</span><span class="text-center text-white/20">—</span><span class="text-center" style="color:#fbbf24;">✓</span></div>
                            <div class="comparison-row"><span class="text-sm text-white/70">Hubs vocaux temp.</span><span class="text-center text-xs text-white/40">1 max</span><span class="text-center text-xs" style="color:#fbbf24;">5 max</span></div>
                            <div class="comparison-row"><span class="text-sm text-white/70">Rappels automatiques</span><span class="text-center text-white/20">—</span><span class="text-center" style="color:#fbbf24;">✓</span></div>
                            <div class="comparison-row"><span class="text-sm text-white/70">Messages programmés</span><span class="text-center text-white/20">—</span><span class="text-center" style="color:#fbbf24;">✓</span></div>
                            <div class="comparison-row"><span class="text-sm text-white/70">Panel de tickets</span><span class="text-center text-white/20">—</span><span class="text-center" style="color:#fbbf24;">✓</span></div>
                            <div class="comparison-row"><span class="text-sm text-white/70">Parrainage</span><span class="text-center text-white/20">—</span><span class="text-center" style="color:#fbbf24;">✓</span></div>
                            <div class="comparison-row"><span class="text-sm text-white/70">Alertes Twitch / YouTube</span><span class="text-center text-white/20">—</span><span class="text-center" style="color:#fbbf24;">✓</span></div>
                            <div class="comparison-row" style="border-bottom:none;"><span class="text-sm text-white/70">Stats d'activité</span><span class="text-center text-white/20">—</span><span class="text-center" style="color:#fbbf24;">✓</span></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Activate section -->
    <section id="activate" class="py-20">
        <div class="container-wide">
            <div class="max-w-lg mx-auto">
                <div class="text-center mb-10">
                    <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl mb-6" style="background:rgba(251,191,36,0.1);border:1px solid rgba(251,191,36,0.2);">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#fbbf24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></rect></svg>
                    </div>
                    <h2 class="text-3xl font-extrabold tracking-tight mb-3">Activer Premium</h2>
                    <p class="text-white/40">Entrez votre code d'activation et sélectionnez le serveur à upgrader.</p>
                </div>

                <% if (!user) { %>
                    <div style="background:#0a0a0a;border:1px solid #1a1a1a;border-radius:20px;padding:40px;text-align:center;">
                        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="1.5" class="mx-auto mb-4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                        <p class="text-white/50 mb-6">Connectez-vous avec Discord pour activer Premium sur votre serveur.</p>
                        <a href="/login" class="inline-block px-8 py-3.5 rounded-full font-bold text-sm" style="background:#fff;color:#000;">Se connecter avec Discord</a>
                    </div>
                <% } else { %>
                    <div style="background:#0a0a0a;border:1px solid #1a1a1a;border-radius:20px;padding:40px;">
                        <div id="alert-success" class="alert-success mb-6">
                            <div class="flex items-start gap-3">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#86efac" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                                <div>
                                    <p class="font-bold mb-1">Premium activé avec succès !</p>
                                    <p id="alert-success-msg" class="text-sm opacity-80"></p>
                                </div>
                            </div>
                        </div>
                        <div id="alert-error" class="alert-error mb-6">
                            <div class="flex items-start gap-3">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#fca5a5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                                <p id="alert-error-msg" class="font-semibold"></p>
                            </div>
                        </div>

                        <div class="space-y-4">
                            <div>
                                <label class="block text-xs font-bold text-white/40 uppercase tracking-widest mb-2">Code d'activation</label>
                                <input type="text" id="code-input" class="code-input" placeholder="Entrez votre code..." maxlength="32" autocomplete="off" autocorrect="off" spellcheck="false">
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-white/40 uppercase tracking-widest mb-2">Serveur cible</label>
                                <div style="position:relative;">
                                    <select id="guild-select" class="guild-select">
                                        <option value="">— Sélectionnez un serveur —</option>
                                        <% adminGuilds.forEach(function(guild) { %>
                                            <option value="<%= guild.id %>"><%= guild.name %></option>
                                        <% }); %>
                                    </select>
                                    <svg style="position:absolute;right:16px;top:50%;transform:translateY(-50%);pointer-events:none;" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.3)" stroke-width="2.5" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
                                </div>
                            </div>
                            <button id="redeem-btn" class="btn-premium mt-2" onclick="redeemCode()">
                                <span id="redeem-btn-text">Activer Premium</span>
                            </button>
                        </div>
                    </div>
                <% } %>
            </div>
        </div>
    </section>
</main>

<!-- Footer -->
<footer class="py-12 border-t border-white/5">
    <div class="container-wide flex flex-col md:flex-row justify-between items-center gap-4">
        <div class="flex items-center gap-2">
            <img src="/image/shardtown.jpeg" alt="" class="w-7 h-7 rounded-full object-cover">
            <span class="font-bold text-sm uppercase tracking-tight">Shardtown</span>
        </div>
        <div class="flex items-center gap-6">
            <a href="/terms" class="text-xs text-white/30 hover:text-white/60 transition-colors">Conditions</a>
            <a href="/privacy" class="text-xs text-white/30 hover:text-white/60 transition-colors">Confidentialité</a>
            <a href="/status" class="text-xs text-white/30 hover:text-white/60 transition-colors">Statut</a>
        </div>
        <p class="text-xs text-white/20">© 2025 Shardtown. Tous droits réservés.</p>
    </div>
</footer>

<script>
async function redeemCode() {
    const code = document.getElementById('code-input').value.trim();
    const guildId = document.getElementById('guild-select').value;
    const btn = document.getElementById('redeem-btn');
    const btnText = document.getElementById('redeem-btn-text');
    const alertSuccess = document.getElementById('alert-success');
    const alertError = document.getElementById('alert-error');

    alertSuccess.style.display = 'none';
    alertError.style.display = 'none';

    if (!code) {
        document.getElementById('alert-error-msg').textContent = 'Veuillez entrer un code d\'activation.';
        alertError.style.display = 'block';
        return;
    }
    if (!guildId) {
        document.getElementById('alert-error-msg').textContent = 'Veuillez sélectionner un serveur.';
        alertError.style.display = 'block';
        return;
    }

    btn.disabled = true;
    btnText.textContent = 'Activation en cours...';

    try {
        const res = await fetch('/api/redeem-code', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ code, guildId })
        });
        const data = await res.json();
        if (data.success) {
            document.getElementById('alert-success-msg').textContent = data.message || 'Premium activé sur votre serveur.';
            alertSuccess.style.display = 'block';
            document.getElementById('code-input').value = '';
            btnText.textContent = 'Activer Premium';
        } else {
            document.getElementById('alert-error-msg').textContent = data.error || 'Une erreur est survenue.';
            alertError.style.display = 'block';
            btnText.textContent = 'Activer Premium';
        }
    } catch {
        document.getElementById('alert-error-msg').textContent = 'Erreur réseau. Veuillez réessayer.';
        alertError.style.display = 'block';
        btnText.textContent = 'Activer Premium';
    } finally {
        btn.disabled = false;
    }
}

document.getElementById('code-input')?.addEventListener('keydown', function(e) {
    if (e.key === 'Enter') redeemCode();
});
</script>
</body>
</html>
