<!DOCTYPE html>
<html lang="fr" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <link rel="icon" type="image/png" href="/image/favicon.png">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Premium — SHARDTOWN</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: #000;
            background-image:
                radial-gradient(at 50% 0%, rgba(251, 191, 36, 0.12) 0px, transparent 50%),
                radial-gradient(at 0% 100%, rgba(139, 92, 246, 0.08) 0px, transparent 50%),
                radial-gradient(at 100% 100%, rgba(251, 191, 36, 0.06) 0px, transparent 50%);
            background-attachment: fixed;
            color: #fff;
            margin: 0;
            padding: 0;
        }

        .bg-glow {
            position: fixed;
            top: 0; left: 50%;
            transform: translateX(-50%);
            width: 100%; height: 100vh;
            background: radial-gradient(circle at 50% -20%, rgba(251, 191, 36, 0.08) 0%, transparent 70%);
            pointer-events: none;
            z-index: -1;
        }

        .container-wide {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 24px;
        }

        .nav-link {
            color: #888;
            transition: color 0.2s;
            font-size: 0.875rem;
            font-weight: 500;
            text-decoration: none;
        }
        .nav-link:hover { color: #fff; }

        .feature-card {
            background: #0a0a0a;
            border: 1px solid #1a1a1a;
            border-radius: 20px;
            padding: 32px;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .feature-card:hover { border-color: rgba(251,191,36,0.2); }

        .feature-row {
            display: flex;
            align-items: flex-start;
            gap: 12px;
            padding: 10px 0;
            border-bottom: 1px solid rgba(255,255,255,0.04);
        }
        .feature-row:last-child { border-bottom: none; }

        .check-icon {
            width: 16px;
            height: 16px;
            border-radius: 50%;
            background: rgba(251,191,36,0.15);
            border: 1px solid rgba(251,191,36,0.3);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            margin-top: 2px;
        }

        .code-input {
            background: #0a0a0a;
            border: 1px solid #2a2a2a;
            border-radius: 12px;
            color: #fff;
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 1rem;
            font-weight: 700;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            outline: none;
            transition: border-color 0.2s, box-shadow 0.2s;
            padding: 16px 24px;
            width: 100%;
        }
        .code-input::placeholder { letter-spacing: 0.06em; text-transform: none; font-weight: 400; color: #444; }
        .code-input:focus { border-color: rgba(251,191,36,0.5); box-shadow: 0 0 0 3px rgba(251,191,36,0.08); }

        .guild-select {
            background: #0a0a0a;
            border: 1px solid #2a2a2a;
            border-radius: 12px;
            color: #fff;
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 0.9rem;
            outline: none;
            transition: border-color 0.2s;
            padding: 14px 20px;
            width: 100%;
            appearance: none;
            cursor: pointer;
        }
        .guild-select:focus { border-color: rgba(251,191,36,0.5); }
        .guild-select option { background: #111; }

        .btn-premium {
            background: linear-gradient(135deg, #fbbf24, #f59e0b);
            color: #000;
            border: none;
            border-radius: 12px;
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-weight: 800;
            font-size: 0.95rem;
            padding: 16px 32px;
            cursor: pointer;
            transition: opacity 0.2s, transform 0.15s;
            letter-spacing: 0.01em;
            width: 100%;
        }
        .btn-premium:hover { opacity: 0.9; transform: translateY(-1px); }
        .btn-premium:active { transform: translateY(0); }
        .btn-premium:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }

        .badge-free {
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 6px;
            padding: 2px 8px;
            font-size: 0.7rem;
            font-weight: 700;
            letter-spacing: 0.06em;
            text-transform: uppercase;
            color: rgba(255,255,255,0.4);
        }

        .badge-premium {
            background: rgba(251,191,36,0.15);
            border: 1px solid rgba(251,191,36,0.3);
            border-radius: 6px;
            padding: 2px 8px;
            font-size: 0.7rem;
            font-weight: 700;
            letter-spacing: 0.06em;
            text-transform: uppercase;
            color: #fbbf24;
        }

        .feat-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            padding: 13px 24px;
            border-bottom: 1px solid rgba(255,255,255,0.04);
        }
        .feat-row:last-child { border-bottom: none; }
        .feat-label { font-size: 0.875rem; color: rgba(255,255,255,0.65); flex: 1; min-width: 0; }
        .feat-pills { display: flex; align-items: center; gap: 8px; flex-shrink: 0; }
        .pill {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            font-size: 0.72rem;
            font-weight: 700;
            padding: 3px 10px;
            border-radius: 100px;
            white-space: nowrap;
        }
        .pill-free {
            background: rgba(255,255,255,0.05);
            color: rgba(255,255,255,0.35);
            border: 1px solid rgba(255,255,255,0.08);
        }
        .pill-premium {
            background: rgba(251,191,36,0.12);
            color: #fbbf24;
            border: 1px solid rgba(251,191,36,0.25);
        }
        .pill-none {
            background: transparent;
            color: rgba(255,255,255,0.15);
            border: 1px solid rgba(255,255,255,0.06);
        }
        .feat-table-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 10px 24px 10px;
            border-bottom: 1px solid #1a1a1a;
        }
        .feat-table-header-labels {
            display: flex;
            gap: 8px;
            flex-shrink: 0;
        }

        .alert-success {
            background: rgba(34,197,94,0.1);
            border: 1px solid rgba(34,197,94,0.25);
            border-radius: 12px;
            padding: 16px 20px;
            color: #86efac;
            font-size: 0.9rem;
            display: none;
        }
        .alert-error {
            background: rgba(239,68,68,0.1);
            border: 1px solid rgba(239,68,68,0.25);
            border-radius: 12px;
            padding: 16px 20px;
            color: #fca5a5;
            font-size: 0.9rem;
            display: none;
        }
    </style>
</head>
<body>
<div class="bg-glow"></div>

<!-- Header -->
<div class="fixed top-6 left-0 right-0 z-50 px-6">
    <header class="container-wide flex justify-between items-center bg-transparent rounded-full py-4 px-8 border border-white/10" style="background: rgba(0,0,0,0.6); backdrop-filter: blur(20px);">
        <a href="/" class="flex items-center gap-2">
            <img src="/image/shardtown.jpeg" alt="Shardtown Logo" class="w-10 h-10 rounded-full object-cover">
            <span class="font-bold tracking-tight text-xl uppercase">Shardtown</span>
        </a>
        <nav class="hidden md:flex items-center gap-8">
            <a href="/#products" class="nav-link">Produits</a>
            <a href="/#services" class="nav-link">Services</a>
            <a href="/wiki" class="nav-link">Wiki</a>
            <a href="/status" class="nav-link">Statut</a>
        </nav>
        <% if (user) { %>
            <div class="flex items-center gap-3 px-4 py-2 bg-white/5 rounded-full border border-white/5">
                <% if (user.avatar) { %>
                    <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" class="w-7 h-7 rounded-full" alt="">
                <% } else { %>
                    <div class="w-7 h-7 rounded-full bg-white/10 flex items-center justify-center text-xs font-bold"><%= user.username.charAt(0).toUpperCase() %></div>
                <% } %>
                <span class="text-sm font-semibold"><%= user.username %></span>
            </div>
        <% } else { %>
            <a href="/login?returnTo=/premium" class="px-5 py-2.5 rounded-full font-bold text-sm" style="background:#fff;color:#000;">Se connecter</a>
        <% } %>
    </header>
</div>

<main style="padding-top: 120px;">
    <!-- Hero -->
    <section class="py-20 text-center">
        <div class="container-wide">
            <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full mb-8" style="background:rgba(251,191,36,0.1);border:1px solid rgba(251,191,36,0.2);">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="#fbbf24" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                <span class="text-xs font-bold tracking-widest uppercase" style="color:#fbbf24;">Shardtown Premium</span>
            </div>
            <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight mb-6" style="line-height:0.92;">Tous les bots.<br><span style="color:#fbbf24;">Une seule offre.</span></h1>
            <p class="text-white/40 text-xl max-w-xl mx-auto mb-10">Débloquez l'ensemble des fonctionnalités avancées de ShardGuard et Shard sur votre serveur Discord.</p>
            <div class="flex justify-center gap-4 flex-wrap">
                <a href="#activate" class="px-8 py-4 rounded-full font-bold text-sm" style="background:linear-gradient(135deg,#fbbf24,#f59e0b);color:#000;">Activer Premium</a>
                <a href="#features" class="px-8 py-4 rounded-full font-bold text-sm border border-white/10 text-white/70 hover:text-white hover:border-white/20 transition-colors">Voir les fonctionnalités</a>
            </div>
        </div>
    </section>

    <!-- Comparison table -->
    <section id="features" class="py-16">
        <div class="container-wide">
            <div class="text-center mb-12">
                <p class="text-sm font-bold tracking-widest text-white/40 uppercase mb-3">Fonctionnalités</p>
                <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight">Gratuit vs Premium</h2>
            </div>

            <div class="grid md:grid-cols-2 gap-6 max-w-5xl mx-auto">

                <!-- ShardGuard -->
                <div class="feature-card" style="padding:0;overflow:hidden;">
                    <div class="feat-table-header">
                        <div class="flex items-center gap-3">
                            <img src="/image/shardguard.png" class="w-8 h-8 rounded-xl object-cover border border-white/5" alt="">
                            <div>
                                <p class="font-extrabold text-sm">ShardGuard</p>
                                <p class="text-white/30 text-xs">Sécurité & Modération</p>
                            </div>
                        </div>
                        <div class="feat-table-header-labels">
                            <span class="pill pill-free">Gratuit</span>
                            <span class="pill pill-premium">★ Premium</span>
                        </div>
                    </div>
                    <div class="feat-row">
                        <span class="feat-label">Vérification Captcha</span>
                        <div class="feat-pills"><span class="pill pill-free">✓</span><span class="pill pill-premium">✓</span></div>
                    </div>
                    <div class="feat-row">
                        <span class="feat-label">Mots interdits</span>
                        <div class="feat-pills"><span class="pill pill-free">3 max</span><span class="pill pill-premium">Illimités</span></div>
                    </div>
                    <div class="feat-row">
                        <span class="feat-label">Règles auto-mod</span>
                        <div class="feat-pills"><span class="pill pill-free">3 max</span><span class="pill pill-premium">20 max</span></div>
                    </div>
                    <div class="feat-row">
                        <span class="feat-label">Sanctions progressives</span>
                        <div class="feat-pills"><span class="pill pill-free">✓</span><span class="pill pill-premium">✓</span></div>
                    </div>
                    <div class="feat-row">
                        <span class="feat-label">Anti-raid automatique</span>
                        <div class="feat-pills"><span class="pill pill-none">—</span><span class="pill pill-premium">✓</span></div>
                    </div>
                    <div class="feat-row">
                        <span class="feat-label">Quarantaine automatique</span>
                        <div class="feat-pills"><span class="pill pill-none">—</span><span class="pill pill-premium">✓</span></div>
                    </div>
                    <div class="feat-row">
                        <span class="feat-label">Alerte modérateur DM</span>
                        <div class="feat-pills"><span class="pill pill-none">—</span><span class="pill pill-premium">✓</span></div>
                    </div>
                    <div class="feat-row">
                        <span class="feat-label">Liste noire globale</span>
                        <div class="feat-pills"><span class="pill pill-none">—</span><span class="pill pill-premium">✓</span></div>
                    </div>
                    <div class="feat-row" style="border-bottom:none;">
                        <span class="feat-label">Backup & restauration</span>
                        <div class="feat-pills"><span class="pill pill-none">—</span><span class="pill pill-premium">✓</span></div>
                    </div>
                </div>

                <!-- Shard -->
                <div class="feature-card" style="padding:0;overflow:hidden;">
                    <div class="feat-table-header">
                        <div class="flex items-center gap-3">
                            <img src="/image/shard.png" class="w-8 h-8 rounded-xl object-cover border border-white/5" alt="">
                            <div>
                                <p class="font-extrabold text-sm">Shard</p>
                                <p class="text-white/30 text-xs">Engagement & Automatisation</p>
                            </div>
                        </div>
                        <div class="feat-table-header-labels">
                            <span class="pill pill-free">Gratuit</span>
                            <span class="pill pill-premium">★ Premium</span>
                        </div>
                    </div>
                    <div class="feat-row">
                        <span class="feat-label">Paliers XP</span>
                        <div class="feat-pills"><span class="pill pill-free">3 max</span><span class="pill pill-premium">20 max</span></div>
                    </div>
                    <div class="feat-row">
                        <span class="feat-label">Multiplicateur XP par rôle</span>
                        <div class="feat-pills"><span class="pill pill-none">—</span><span class="pill pill-premium">✓</span></div>
                    </div>
                    <div class="feat-row">
                        <span class="feat-label">Giveaways simultanés</span>
                        <div class="feat-pills"><span class="pill pill-free">1 max</span><span class="pill pill-premium">5 max</span></div>
                    </div>
                    <div class="feat-row">
                        <span class="feat-label">Sondages anonymes</span>
                        <div class="feat-pills"><span class="pill pill-none">—</span><span class="pill pill-premium">✓</span></div>
                    </div>
                    <div class="feat-row">
                        <span class="feat-label">Hubs vocaux temporaires</span>
                        <div class="feat-pills"><span class="pill pill-free">1 max</span><span class="pill pill-premium">5 max</span></div>
                    </div>
                    <div class="feat-row">
                        <span class="feat-label">Rappels automatiques</span>
                        <div class="feat-pills"><span class="pill pill-none">—</span><span class="pill pill-premium">✓</span></div>
                    </div>
                    <div class="feat-row">
                        <span class="feat-label">Messages programmés</span>
                        <div class="feat-pills"><span class="pill pill-none">—</span><span class="pill pill-premium">✓</span></div>
                    </div>
                    <div class="feat-row">
                        <span class="feat-label">Panel de tickets</span>
                        <div class="feat-pills"><span class="pill pill-none">—</span><span class="pill pill-premium">✓</span></div>
                    </div>
                    <div class="feat-row">
                        <span class="feat-label">Parrainage</span>
                        <div class="feat-pills"><span class="pill pill-none">—</span><span class="pill pill-premium">✓</span></div>
                    </div>
                    <div class="feat-row">
                        <span class="feat-label">Alertes Twitch / YouTube</span>
                        <div class="feat-pills"><span class="pill pill-none">—</span><span class="pill pill-premium">✓</span></div>
                    </div>
                    <div class="feat-row" style="border-bottom:none;">
                        <span class="feat-label">Stats d'activité</span>
                        <div class="feat-pills"><span class="pill pill-none">—</span><span class="pill pill-premium">✓</span></div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Activate section -->
    <section id="activate" class="py-20">
        <div class="container-wide">
            <div class="max-w-lg mx-auto">
                <div class="text-center mb-10">
                    <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl mb-6" style="background:rgba(251,191,36,0.1);border:1px solid rgba(251,191,36,0.2);">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#fbbf24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                    </div>
                    <h2 class="text-3xl font-extrabold tracking-tight mb-3">Obtenir Premium</h2>
                    <p class="text-white/40">Sélectionnez votre serveur et payez par carte pour activer Premium.</p>
                </div>

                <% if (!user) { %>
                    <div style="background:#0a0a0a;border:1px solid #1a1a1a;border-radius:20px;padding:40px;text-align:center;">
                        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="1.5" class="mx-auto mb-4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                        <p class="text-white/50 mb-6">Connectez-vous avec Discord pour activer Premium sur votre serveur.</p>
                        <a href="/login?returnTo=/premium" class="inline-block px-8 py-3.5 rounded-full font-bold text-sm" style="background:#fff;color:#000;">Se connecter avec Discord</a>
                    </div>
                <% } else { %>
                    <div style="background:#0a0a0a;border:1px solid #1a1a1a;border-radius:20px;padding:40px;">

                        <% const paymentStatus = typeof paymentResult !== 'undefined' ? paymentResult : null; %>

                        <% if (paymentStatus === 'success') { %>
                        <div class="alert-success mb-6" style="display:block;">
                            <div class="flex items-start gap-3">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#86efac" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                                <div>
                                    <p class="font-bold mb-1">Paiement confirmé !</p>
                                    <p class="text-sm opacity-80">Premium sera activé sur votre serveur dès réception de la confirmation Stripe (quelques secondes).</p>
                                </div>
                            </div>
                        </div>
                        <% } %>

                        <% if (paymentStatus === 'cancelled') { %>
                        <div class="alert-error mb-6" style="display:block;">
                            <div class="flex items-start gap-3">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#fca5a5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                                <p class="font-semibold">Paiement annulé.</p>
                            </div>
                        </div>
                        <% } %>

                        <div id="alert-error" class="alert-error mb-6">
                            <div class="flex items-start gap-3">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#fca5a5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                                <p id="alert-error-msg" class="font-semibold"></p>
                            </div>
                        </div>

                        <div class="space-y-4">
                            <div>
                                <label class="block text-xs font-bold text-white/40 uppercase tracking-widest mb-2">Serveur cible</label>
                                <div style="position:relative;">
                                    <select id="guild-select" class="guild-select">
                                        <option value="">— Sélectionnez un serveur —</option>
                                        <% adminGuilds.forEach(function(guild) { %>
                                            <option value="<%= guild.id %>"><%= guild.name %></option>
                                        <% }); %>
                                    </select>
                                    <svg style="position:absolute;right:16px;top:50%;transform:translateY(-50%);pointer-events:none;" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.3)" stroke-width="2.5" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
                                </div>
                            </div>

                            <button id="buy-btn" class="btn-premium" onclick="startCheckout()">
                                <span id="buy-btn-text">
                                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="display:inline;vertical-align:-2px;margin-right:6px;"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
                                    Payer avec Stripe — 4.97 €
                                </span>
                            </button>
                        </div>
                    </div>
                <% } %>
            </div>
        </div>
    </section>
</main>

<!-- Footer -->
<footer class="py-12 border-t border-white/5">
    <div class="container-wide flex flex-col md:flex-row justify-between items-center gap-4">
        <div class="flex items-center gap-2">
            <img src="/image/shardtown.jpeg" alt="" class="w-7 h-7 rounded-full object-cover">
            <span class="font-bold text-sm uppercase tracking-tight">Shardtown</span>
        </div>
        <div class="flex items-center gap-6">
            <a href="/terms" class="text-xs text-white/30 hover:text-white/60 transition-colors">Conditions</a>
            <a href="/privacy" class="text-xs text-white/30 hover:text-white/60 transition-colors">Confidentialité</a>
            <a href="/status" class="text-xs text-white/30 hover:text-white/60 transition-colors">Statut</a>
        </div>
        <p class="text-xs text-white/20">© 2025 Shardtown. Tous droits réservés.</p>
    </div>
</footer>

<script>
async function startCheckout() {
    const guildId = document.getElementById('guild-select')?.value;
    const alertError = document.getElementById('alert-error');
    alertError.style.display = 'none';

    if (!guildId) {
        document.getElementById('alert-error-msg').textContent = 'Veuillez sélectionner un serveur.';
        alertError.style.display = 'block';
        return;
    }

    const btn = document.getElementById('buy-btn');
    const btnText = document.getElementById('buy-btn-text');
    btn.disabled = true;
    btnText.innerHTML = 'Redirection vers Stripe...';

    try {
        const res = await fetch('/api/create-checkout', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ guildId })
        });
        const data = await res.json();
        if (data.success && data.url) {
            window.location.href = data.url;
        } else {
            document.getElementById('alert-error-msg').textContent = data.error || 'Impossible de créer la session de paiement.';
            alertError.style.display = 'block';
            btn.disabled = false;
            btnText.innerHTML = '<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="display:inline;vertical-align:-2px;margin-right:6px;"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>Payer avec Stripe — 4,97 €';
        }
    } catch {
        document.getElementById('alert-error-msg').textContent = 'Erreur réseau. Veuillez réessayer.';
        alertError.style.display = 'block';
        btn.disabled = false;
        btnText.innerHTML = '<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="display:inline;vertical-align:-2px;margin-right:6px;"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>Payer avec Stripe — 4,97 €';
    }
}
</script>
</body>
