    <!-- Activate section -->
    <section id="activate" class="py-20">
        <div class="container-wide">
            <div class="max-w-lg mx-auto">
                <div class="text-center mb-10">
                    <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl mb-6" style="background:rgba(251,191,36,0.1);border:1px solid rgba(251,191,36,0.2);">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#fbbf24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                    </div>
                    <h2 class="text-3xl font-extrabold tracking-tight mb-3">Obtenir Premium</h2>
                    <p class="text-white/40">Sélectionnez votre serveur et payez par carte pour activer Premium.</p>
                </div>

                <% if (!user) { %>
                    <div style="background:#0a0a0a;border:1px solid #1a1a1a;border-radius:20px;padding:40px;text-align:center;">
                        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="1.5" class="mx-auto mb-4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                        <p class="text-white/50 mb-6">Connectez-vous avec Discord pour activer Premium sur votre serveur.</p>
                        <a href="/login?returnTo=/premium" class="inline-block px-8 py-3.5 rounded-full font-bold text-sm" style="background:#fff;color:#000;">Se connecter avec Discord</a>
                    </div>
                <% } else { %>
                    <div style="background:#0a0a0a;border:1px solid #1a1a1a;border-radius:20px;padding:40px;">

                        <% const paymentStatus = typeof paymentResult !== 'undefined' ? paymentResult : null; %>

                        <% if (paymentStatus === 'success') { %>
                        <div class="alert-success mb-6" style="display:block;">
                            <div class="flex items-start gap-3">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#86efac" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                                <div>
                                    <p class="font-bold mb-1">Paiement confirmé !</p>
                                    <p class="text-sm opacity-80">Premium sera activé sur votre serveur dès réception de la confirmation Stripe (quelques secondes).</p>
                                </div>
                            </div>
                        </div>
                        <% } %>

                        <% if (paymentStatus === 'cancelled') { %>
                        <div class="alert-error mb-6" style="display:block;">
                            <div class="flex items-start gap-3">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#fca5a5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                                <p class="font-semibold">Paiement annulé.</p>
                            </div>
                        </div>
                        <% } %>

                        <div id="alert-error" class="alert-error mb-6">
                            <div class="flex items-start gap-3">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#fca5a5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                                <p id="alert-error-msg" class="font-semibold"></p>
                            </div>
                        </div>

                        <div class="space-y-5">
                            <div>
                                <label class="block text-xs font-bold text-white/40 uppercase tracking-widest mb-2">Formule</label>
                                <div class="plan-toggle">
                                    <label class="plan-toggle-option" data-plan="monthly">
                                        <input type="radio" name="plan" value="monthly">
                                        <span class="plan-toggle-name">Mensuel</span>
                                        <span class="plan-toggle-price">4,97 €<span class="plan-toggle-sub"> / mois</span></span>
                                    </label>
                                    <label class="plan-toggle-option active" data-plan="lifetime">
                                        <input type="radio" name="plan" value="lifetime" checked>
                                        <span class="plan-toggle-name">À vie</span>
                                        <span class="plan-toggle-price">49,97 €<span class="plan-toggle-sub"> une fois</span></span>
                                    </label>
                                </div>
                            </div>

                            <div>
                                <label class="block text-xs font-bold text-white/40 uppercase tracking-widest mb-2">Serveur cible</label>
                                <div style="position:relative;">
                                    <select id="guild-select" class="guild-select">
                                        <option value="">— Sélectionnez un serveur —</option>
                                        <% adminGuilds.forEach(function(guild) { %>
                                            <option value="<%= guild.id %>"><%= guild.name %></option>
                                        <% }); %>
                                    </select>
                                    <svg style="position:absolute;right:16px;top:50%;transform:translateY(-50%);pointer-events:none;" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.3)" stroke-width="2.5" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
                                </div>
                            </div>

                            <button id="buy-btn" class="btn-premium" onclick="startCheckout()">
                                <span id="buy-btn-text">
                                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="display:inline;vertical-align:-2px;margin-right:6px;"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
                                    Payer avec Stripe — 49,97 €
                                </span>
                            </button>
                            <p class="text-center text-xs text-white/30">Paiement sécurisé via Stripe. Vous pouvez annuler l'abonnement mensuel à tout moment.</p>
                        </div>
                    </div>
                <% } %>
            </div>
        </div>
    </section>
</main>

<!-- Footer -->
<footer class="py-12 border-t border-white/5">
    <div class="container-wide flex flex-col md:flex-row justify-between items-center gap-4">
        <div class="flex items-center gap-2">
            <img src="/image/shardtown.jpeg" alt="" class="w-7 h-7 rounded-full object-cover">
            <span class="font-bold text-sm uppercase tracking-tight">Shardtown</span>
        </div>
        <div class="flex items-center gap-6">
            <a href="/terms" class="text-xs text-white/30 hover:text-white/60 transition-colors">Conditions</a>
            <a href="/privacy" class="text-xs text-white/30 hover:text-white/60 transition-colors">Confidentialité</a>
            <a href="/status" class="text-xs text-white/30 hover:text-white/60 transition-colors">Statut</a>
        </div>
        <p class="text-xs text-white/20">© 2025 Shardtown. Tous droits réservés.</p>
    </div>
</footer>

<script>
const PLAN_LABEL = {
    monthly: 'Payer avec Stripe — 4,97 € / mois',
    lifetime: 'Payer avec Stripe — 49,97 €'
};
const CARD_SVG = '<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="display:inline;vertical-align:-2px;margin-right:6px;"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>';

function getSelectedPlan() {
    const checked = document.querySelector('input[name="plan"]:checked');
    return checked ? checked.value : 'lifetime';
}

function refreshButtonLabel() {
    const btnText = document.getElementById('buy-btn-text');
    if (!btnText) return;
    btnText.innerHTML = CARD_SVG + PLAN_LABEL[getSelectedPlan()];
}

document.querySelectorAll('.plan-toggle-option').forEach(opt => {
    opt.addEventListener('click', () => {
        document.querySelectorAll('.plan-toggle-option').forEach(o => o.classList.remove('active'));
        opt.classList.add('active');
        const input = opt.querySelector('input');
        if (input) input.checked = true;
        refreshButtonLabel();
    });
});

function selectPlanAndScroll(plan) {
    const opt = document.querySelector(`.plan-toggle-option[data-plan="${plan}"]`);
    if (opt) opt.click();
    const target = document.getElementById('activate');
    if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
}

async function startCheckout() {
    const guildId = document.getElementById('guild-select')?.value;
    const plan = getSelectedPlan();
    const alertError = document.getElementById('alert-error');
    alertError.style.display = 'none';

    if (!guildId) {
        document.getElementById('alert-error-msg').textContent = 'Veuillez sélectionner un serveur.';
        alertError.style.display = 'block';
        return;
    }

    const btn = document.getElementById('buy-btn');
    const btnText = document.getElementById('buy-btn-text');
    btn.disabled = true;
    btnText.innerHTML = 'Redirection vers Stripe...';

    try {
        const res = await fetch('/api/create-checkout', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ guildId, plan })
        });
        const data = await res.json();
        if (data.success && data.url) {
            window.location.href = data.url;
        } else {
            document.getElementById('alert-error-msg').textContent = data.error || 'Impossible de créer la session de paiement.';
            alertError.style.display = 'block';
            btn.disabled = false;
            refreshButtonLabel();
        }
    } catch {
        document.getElementById('alert-error-msg').textContent = 'Erreur réseau. Veuillez réessayer.';
        alertError.style.display = 'block';
        btn.disabled = false;
        refreshButtonLabel();
    }
}
</script>
</body>
</html>
