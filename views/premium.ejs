                    </div>
                    <div class="limit-card">
                        <div class="limit-label">Giveaways simultanés</div>
                        <div class="limit-compare">
                            <span class="limit-from">1 max</span>
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="rgba(251,191,36,0.5)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
