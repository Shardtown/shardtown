<!DOCTYPE html>
<html lang="fr" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <link rel="icon" type="image/png" href="/image/favicon.png">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Premium — SHARDTOWN</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #000000;
            --text: #ffffff;
            --accent: #ffffff;
            --muted: #888888;
            --border: #1a1a1a;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: #000;
            background-image:
                radial-gradient(at 50% 0%, rgba(37, 99, 235, 0.2) 0px, transparent 50%),
                radial-gradient(at 0% 100%, rgba(139, 92, 246, 0.1) 0px, transparent 50%),
                radial-gradient(at 100% 100%, rgba(236, 72, 153, 0.1) 0px, transparent 50%),
                radial-gradient(at 50% 50%, rgba(37, 99, 235, 0.05) 0px, transparent 50%);
            background-attachment: fixed;
            color: var(--text);
            margin: 0;
            padding: 0;
        }

        .bg-glow {
            position: fixed;
            top: 0; left: 50%;
            transform: translateX(-50%);
            width: 100%; height: 100vh;
            background: radial-gradient(circle at 50% -20%, rgba(37, 99, 235, 0.1) 0%, transparent 70%);
            pointer-events: none;
            z-index: -1;
        }

        .container-wide {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 24px;
        }

        .nav-link {
            color: var(--muted);
            transition: color 0.2s;
            font-size: 0.875rem;
            font-weight: 500;
            text-decoration: none;
        }
        .nav-link:hover { color: var(--text); }

        .btn-white {
            background: #fff;
            color: #000;
            padding: 10px 24px;
            border-radius: 100px;
            font-weight: 700;
            font-size: 0.875rem;
            transition: opacity 0.2s;
            text-decoration: none;
            display: inline-block;
        }
        .btn-white:hover { opacity: 0.9; }

        .hero-title {
            font-size: clamp(3rem, 8vw, 6rem);
            font-weight: 800;
            line-height: 0.9;
            letter-spacing: -0.02em;
            margin-bottom: 2rem;
        }

        .section-label {
            font-size: 0.875rem;
            font-weight: 700;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            color: rgba(255,255,255,0.4);
            margin-bottom: 1rem;
        }

        .feature-card {
            background: #0a0a0a;
            border: 1px solid #1a1a1a;
            border-radius: 24px;
            padding: 40px;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .feature-card:hover { border-color: #333; transform: translateY(-4px); }

        .feature-row {
            display: flex;
            align-items: flex-start;
            gap: 12px;
            padding: 10px 0;
            border-bottom: 1px solid rgba(255,255,255,0.04);
        }
        .feature-row:last-child { border-bottom: none; }

        .check-icon {
            width: 16px;
            height: 16px;
            border-radius: 50%;
            background: rgba(251,191,36,0.15);
            border: 1px solid rgba(251,191,36,0.3);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            margin-top: 2px;
        }

        .code-input {
            background: #0a0a0a;
            border: 1px solid #2a2a2a;
            border-radius: 12px;
            color: #fff;
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 1rem;
            font-weight: 700;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            outline: none;
            transition: border-color 0.2s, box-shadow 0.2s;
            padding: 16px 24px;
            width: 100%;
        }
        .code-input::placeholder { letter-spacing: 0.06em; text-transform: none; font-weight: 400; color: #444; }
        .code-input:focus { border-color: rgba(251,191,36,0.5); box-shadow: 0 0 0 3px rgba(251,191,36,0.08); }

        .custom-select-wrapper { position: relative; width: 100%; }
        .custom-select-trigger {
            width: 100%;
            padding: 14px 18px;
            background: rgba(255,255,255,0.03);
            border: 1px solid #2a2a2a;
            color: #fff;
            border-radius: 12px;
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 0.9rem;
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            align-items: center;
            transition: border-color 0.2s, box-shadow 0.2s;
        }
        .custom-select-trigger span { color: #fff; }
        .custom-select-trigger.placeholder span { color: rgba(255,255,255,0.3); }
        .custom-select-trigger:after {
            content: "";
            width: 8px; height: 8px;
            border-right: 2px solid rgba(255,255,255,0.4);
            border-bottom: 2px solid rgba(255,255,255,0.4);
            transform: rotate(45deg);
            margin-bottom: 4px;
            transition: transform 0.2s;
        }
        .custom-select-wrapper.open .custom-select-trigger {
            border-color: rgba(251,191,36,0.5);
            box-shadow: 0 0 0 3px rgba(251,191,36,0.08);
        }
        .custom-select-wrapper.open .custom-select-trigger:after {
            transform: rotate(-135deg);
            border-color: #fbbf24;
        }
        .custom-options {
            position: absolute;
            top: calc(100% + 8px);
            left: 0; right: 0;
            background: #0f0f0f;
            border: 1px solid #1a1a1a;
            border-radius: 14px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            display: none;
            z-index: 1000;
            max-height: 250px;
            overflow-y: auto;
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            padding: 6px;
        }
        .custom-select-wrapper.open .custom-options { display: block; }
        .custom-option {
            padding: 10px 14px;
            cursor: pointer;
            transition: background 0.15s, color 0.15s;
            font-size: 0.875rem;
            color: rgba(255,255,255,0.65);
            border-radius: 9px;
        }
        .custom-option:hover { background: rgba(255,255,255,0.05); color: #fff; }
        .custom-option.selected {
            background: rgba(251,191,36,0.1);
            color: #fbbf24;
            font-weight: 700;
        }
        .hidden-select { display: none; }

        .btn-premium {
            background: linear-gradient(135deg, #fbbf24, #f59e0b);
            color: #000;
            border: none;
            border-radius: 12px;
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-weight: 800;
            font-size: 0.95rem;
            padding: 16px 32px;
            cursor: pointer;
            transition: opacity 0.2s, transform 0.15s;
            letter-spacing: 0.01em;
            width: 100%;
        }
        .btn-premium:hover { opacity: 0.9; transform: translateY(-1px); }
        .btn-premium:active { transform: translateY(0); }
        .btn-premium:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }

        .badge-free {
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 6px;
            padding: 2px 8px;
            font-size: 0.7rem;
            font-weight: 700;
            letter-spacing: 0.06em;
            text-transform: uppercase;
            color: rgba(255,255,255,0.4);
        }

        .badge-premium {
            background: rgba(251,191,36,0.15);
            border: 1px solid rgba(251,191,36,0.3);
            border-radius: 6px;
            padding: 2px 8px;
            font-size: 0.7rem;
            font-weight: 700;
            letter-spacing: 0.06em;
            text-transform: uppercase;
            color: #fbbf24;
        }

        .feat-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            padding: 13px 24px;
            border-bottom: 1px solid rgba(255,255,255,0.04);
        }
        .feat-row:last-child { border-bottom: none; }
        .feat-label { font-size: 0.875rem; color: rgba(255,255,255,0.65); flex: 1; min-width: 0; }
        .feat-pills { display: flex; align-items: center; gap: 8px; flex-shrink: 0; }
        .pill {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            font-size: 0.72rem;
            font-weight: 700;
            padding: 3px 10px;
            border-radius: 100px;
            white-space: nowrap;
        }
        .pill-free {
            background: rgba(255,255,255,0.05);
            color: rgba(255,255,255,0.35);
            border: 1px solid rgba(255,255,255,0.08);
        }
        .pill-premium {
            background: rgba(251,191,36,0.12);
            color: #fbbf24;
            border: 1px solid rgba(251,191,36,0.25);
        }
        .pill-none {
            background: transparent;
            color: rgba(255,255,255,0.15);
            border: 1px solid rgba(255,255,255,0.06);
        }
        .feat-table-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 10px 24px 10px;
            border-bottom: 1px solid #1a1a1a;
        }
        .feat-table-header-labels {
            display: flex;
            gap: 8px;
            flex-shrink: 0;
        }

        .alert-success {
            background: rgba(34,197,94,0.1);
            border: 1px solid rgba(34,197,94,0.25);
            border-radius: 12px;
            padding: 16px 20px;
            color: #86efac;
            font-size: 0.9rem;
            display: none;
        }
        .alert-error {
            background: rgba(239,68,68,0.1);
            border: 1px solid rgba(239,68,68,0.25);
            border-radius: 12px;
            padding: 16px 20px;
            color: #fca5a5;
            font-size: 0.9rem;
            display: none;
        }

        .pricing-grid-bg {
            position: absolute;
            inset: 0;
            background-image:
                linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
                linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
            background-size: 56px 56px;
            -webkit-mask-image: radial-gradient(ellipse at center, black 30%, transparent 75%);
                    mask-image: radial-gradient(ellipse at center, black 30%, transparent 75%);
            pointer-events: none;
        }

        .access-pill {
            display: inline-flex;
            align-items: center;
            gap: 12px;
            padding: 12px 26px;
            border-radius: 100px;
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.08);
            font-size: 0.78rem;
            font-weight: 700;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: rgba(255,255,255,0.85);
        }
        .access-pill-tail {
            color: rgba(255,255,255,0.4);
            font-weight: 500;
            letter-spacing: 0.02em;
            text-transform: none;
        }

        .price-card {
            position: relative;
            background: #0a0a0a;
            border: 1px solid #1a1a1a;
            border-radius: 24px;
            padding: 36px 32px;
            display: flex;
            flex-direction: column;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .price-card:hover { transform: translateY(-4px); border-color: #333; }
        .price-card.featured {
            border-color: rgba(251,191,36,0.4);
            background:
                linear-gradient(180deg, rgba(251,191,36,0.05), transparent 35%),
                #0a0a0a;
            box-shadow: 0 0 80px -30px rgba(251,191,36,0.35);
        }
        .price-card.featured:hover { border-color: rgba(251,191,36,0.65); }
        .price-card .ribbon {
            position: absolute;
            top: -14px;
            left: 50%;
            transform: translateX(-50%);
            background: linear-gradient(135deg, #fbbf24, #f59e0b);
            color: #000;
            font-size: 0.7rem;
            font-weight: 800;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            padding: 7px 18px;
            border-radius: 100px;
            white-space: nowrap;
            box-shadow: 0 4px 20px -4px rgba(251,191,36,0.5);
        }

        .price-card-name {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 1.35rem;
            font-weight: 800;
            letter-spacing: -0.01em;
            margin-bottom: 6px;
        }
        .price-card-tag {
            color: rgba(255,255,255,0.4);
            font-size: 0.85rem;
            margin-bottom: 22px;
        }

        .price-mode-pill {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 7px 14px;
            border-radius: 100px;
            background: rgba(255,255,255,0.04);
            border: 1px solid rgba(255,255,255,0.08);
            font-size: 0.68rem;
            font-weight: 800;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            color: rgba(255,255,255,0.55);
            align-self: flex-start;
            margin-bottom: 22px;
        }

        .price-compare {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 0.82rem;
            margin-bottom: 8px;
            min-height: 22px;
        }
        .price-compare-old {
            color: rgba(255,255,255,0.28);
            text-decoration: line-through;
            text-decoration-color: rgba(255,255,255,0.2);
        }
        .price-compare-save {
            color: #4ade80;
            font-weight: 700;
        }

        .price-amount-block {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            margin-bottom: 8px;
        }
        .price-currency {
            font-size: 0.95rem;
            font-weight: 800;
            color: rgba(255,255,255,0.4);
            letter-spacing: 0.04em;
            margin-top: 18px;
        }
        .price-amount {
            font-size: 4.5rem;
            font-weight: 800;
            line-height: 0.95;
            letter-spacing: -0.045em;
            color: #fff;
        }

        .price-amount-desc {
            color: rgba(255,255,255,0.55);
            font-size: 0.85rem;
            margin-bottom: 28px;
        }
        .price-amount-desc .struck {
            text-decoration: line-through;
            text-decoration-color: rgba(251,191,36,0.6);
            color: rgba(255,255,255,0.35);
        }

        .price-features {
            flex: 1;
            margin-bottom: 26px;
        }
        .price-feat {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 7px 0;
            font-size: 0.875rem;
            color: rgba(255,255,255,0.85);
            font-weight: 600;
        }
        .price-feat.muted {
            color: rgba(255,255,255,0.55);
            font-weight: 500;
        }
        .price-feat svg {
            flex-shrink: 0;
            color: #4ade80;
        }

        .btn-plan {
            display: block;
            width: 100%;
            padding: 16px 24px;
            border-radius: 14px;
            font-weight: 800;
            font-size: 0.95rem;
            text-align: center;
            cursor: pointer;
            transition: opacity 0.2s, transform 0.15s, box-shadow 0.2s;
            border: none;
            font-family: 'Plus Jakarta Sans', sans-serif;
            text-decoration: none;
            letter-spacing: 0.005em;
        }
        .btn-plan-primary {
            background: linear-gradient(135deg, #fbbf24, #f59e0b);
            color: #000;
            box-shadow: 0 8px 24px -8px rgba(251,191,36,0.6);
        }
        .btn-plan-secondary {
            background: rgba(255,255,255,0.05);
            color: #fff;
            border: 1px solid rgba(255,255,255,0.12);
        }
        .btn-plan:hover { opacity: 0.92; transform: translateY(-1px); }

        .plan-toggle {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 8px;
            background: #060606;
            border: 1px solid #1a1a1a;
            border-radius: 14px;
            padding: 6px;
        }
        .plan-toggle-option {
            display: flex;
            flex-direction: column;
            align-items: flex-start;
            gap: 2px;
            padding: 12px 16px;
            border-radius: 10px;
            cursor: pointer;
            transition: background 0.2s;
            border: 1px solid transparent;
        }
        .plan-toggle-option:hover { background: rgba(255,255,255,0.03); }
        .plan-toggle-option.active {
            background: rgba(251,191,36,0.08);
            border-color: rgba(251,191,36,0.3);
        }
        .plan-toggle-option input { display: none; }
        .plan-toggle-name {
            font-size: 0.78rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            color: rgba(255,255,255,0.5);
        }
        .plan-toggle-option.active .plan-toggle-name { color: #fbbf24; }
        .plan-toggle-price {
            font-size: 1rem;
            font-weight: 800;
            color: #fff;
        }
        .plan-toggle-sub {
            font-size: 0.7rem;
            color: rgba(255,255,255,0.35);
            font-weight: 500;
        }

        .compare-table {
            background: #0a0a0a;
            border: 1px solid #1a1a1a;
            border-radius: 24px;
            overflow: hidden;
            margin-bottom: 32px;
            position: relative;
        }
        .compare-table:last-child { margin-bottom: 0; }

        .compare-table-header {
            display: grid;
            grid-template-columns: 1fr 140px 140px;
            align-items: center;
            padding: 24px 28px;
            background: linear-gradient(180deg, rgba(255,255,255,0.02), transparent);
            border-bottom: 1px solid #181818;
        }
        .compare-bot {
            display: flex;
            align-items: center;
            gap: 14px;
        }
        .compare-bot img {
            width: 40px; height: 40px;
            border-radius: 11px;
            object-fit: cover;
            border: 1px solid rgba(255,255,255,0.08);
        }
        .compare-bot h3 {
            font-size: 1.1rem;
            font-weight: 800;
            letter-spacing: -0.01em;
        }
        .compare-bot p {
            font-size: 0.78rem;
            color: rgba(255,255,255,0.4);
        }
        .compare-col-label {
            text-align: center;
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.1em;
        }
        .compare-col-free { color: rgba(255,255,255,0.4); }
        .compare-col-premium {
            color: #fbbf24;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 5px;
        }

        .compare-row {
            display: grid;
            grid-template-columns: 1fr 140px 140px;
            align-items: center;
            padding: 16px 28px;
            border-bottom: 1px solid rgba(255,255,255,0.04);
            transition: background 0.15s;
        }
        .compare-row:last-child { border-bottom: none; }
        .compare-row:hover { background: rgba(255,255,255,0.015); }

        .compare-feat {
            font-size: 0.9rem;
            color: rgba(255,255,255,0.85);
            font-weight: 500;
        }
        .compare-cell {
            text-align: center;
            font-size: 0.875rem;
            font-weight: 600;
        }
        .compare-cell-free { color: rgba(255,255,255,0.4); }
        .compare-cell-premium {
            color: #fbbf24;
            position: relative;
        }
        .compare-cell-premium-bg {
            background: rgba(251,191,36,0.025);
        }

        .check-yes {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 22px; height: 22px;
            border-radius: 50%;
        }
        .check-yes-free {
            background: rgba(255,255,255,0.06);
            color: rgba(255,255,255,0.5);
        }
        .check-yes-premium {
            background: rgba(251,191,36,0.15);
            color: #fbbf24;
        }
        .check-no {
            display: inline-block;
            color: rgba(255,255,255,0.15);
            font-weight: 700;
        }

        .premium-col-divider {
            position: absolute;
            top: 0; bottom: 0;
            right: 168px;
            width: 1px;
            background: linear-gradient(180deg, transparent, rgba(251,191,36,0.15) 10%, rgba(251,191,36,0.15) 90%, transparent);
            pointer-events: none;
        }
        .premium-col-bg {
            position: absolute;
            top: 0; bottom: 0;
            right: 28px;
            width: 140px;
            background: linear-gradient(180deg, rgba(251,191,36,0.04), rgba(251,191,36,0.01));
            pointer-events: none;
        }

        @media (max-width: 720px) {
            .compare-table-header,
            .compare-row {
                grid-template-columns: 1fr 80px 80px;
                padding-left: 16px;
                padding-right: 16px;
            }
            .premium-col-divider { right: 96px; }
            .premium-col-bg { right: 16px; width: 80px; }
            .compare-bot p { display: none; }
        }
    </style>
</head>
<body>
<div class="bg-glow"></div>

<!-- Header -->
<div class="fixed top-6 left-0 right-0 z-50 px-6">
    <header id="main-header" class="container-wide flex justify-between items-center bg-transparent rounded-full transition-all duration-300 py-4 px-8 border border-white/10">
        <a href="/" class="flex items-center gap-2">
            <img src="/image/shardtown.jpeg" alt="Shardtown Logo" class="w-10 h-10 rounded-full object-cover">
            <span class="font-bold tracking-tight text-xl uppercase">Shardtown</span>
        </a>
        <nav class="hidden md:flex items-center gap-8">
            <a href="/#products" class="nav-link">Produits</a>
            <a href="/#services" class="nav-link">Services</a>
            <a href="/wiki" class="nav-link">Wiki</a>
            <a href="/status" class="nav-link">Statut</a>
            <a href="/premium" class="nav-link" style="color:#fff">Premium</a>
        </nav>
        <% if (user) { %>
            <div class="flex items-center gap-3">
                <div class="hidden md:flex items-center gap-3 px-4 py-2 bg-white/5 rounded-full border border-white/5">
                    <% if (user.avatar) { %>
                        <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" class="w-7 h-7 rounded-full border border-white/10" alt="">
                    <% } else { %>
                        <div class="w-7 h-7 rounded-full bg-white/10 flex items-center justify-center text-xs font-bold"><%= user.username.charAt(0).toUpperCase() %></div>
                    <% } %>
                    <span class="font-bold text-sm"><%= user.username %></span>
                </div>
                <a href="/dashboard" class="btn-white">Dashboard</a>
            </div>
        <% } else { %>
            <div class="flex items-center gap-3">
                <a href="/login?returnTo=/premium" class="btn-white">Se connecter</a>
            </div>
        <% } %>
    </header>
</div>

<script>
    window.addEventListener('scroll', () => {
        const header = document.getElementById('main-header');
        if (window.scrollY > 50) {
            header.classList.remove('bg-transparent', 'border-white/10');
            header.classList.add('bg-white/5', 'backdrop-blur-lg', 'border-white/5');
        } else {
            header.classList.add('bg-transparent', 'border-white/10');
            header.classList.remove('bg-white/5', 'backdrop-blur-lg', 'border-white/5');
        }
    });
</script>

