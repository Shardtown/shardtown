                    <div class="field mb-0">
                        <label>Durée (optionnel)</label>
                        <div class="flex gap-3 items-center">
                            <input type="number" id="pollDuration" placeholder="Laisser vide = sans limite" min="1" style="flex:1">
                            <div class="custom-select-wrapper" style="width:140px;flex-shrink:0">
                                <div class="custom-select-trigger" onclick="toggleDropdown(this)"><span>Heures</span></div>
                                <div class="custom-options">
