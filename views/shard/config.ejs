                            <div class="custom-select-trigger" onclick="toggleDropdown(this)"><span>Non</span></div>
                            <div class="custom-options">
                                <div class="custom-option selected" data-value="0" onclick="selectOption(this,'pollAnonymous')">Non</div>
                                <div class="custom-option" data-value="1" onclick="selectOption(this,'pollAnonymous')">Oui — résultats masqués</div>
