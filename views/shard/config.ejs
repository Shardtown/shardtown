        </form>
    </main>

    <!-- Save bar -->
    <div id="save-bar" class="footer-bar">
        <p class="text-xs font-bold uppercase tracking-widest text-white/50">Modifications non enregistrées</p>
        <button type="submit" form="configForm" class="btn-white" onclick="saveConfig()">Enregistrer</button>
    </div>

    <!-- Notifications -->
    <div id="notification-container" class="fixed top-6 right-6 z-[3000] flex flex-col gap-4 w-80 items-end"></div>

    <!-- Modal alerte -->
    <div id="alert-overlay" class="fixed inset-0 bg-black/60 backdrop-blur-xl z-[2000] hidden items-center justify-center p-6">
        <div class="bg-[#0a0a0a]/80 border border-white/10 rounded-[32px] p-10 max-w-sm w-full text-center shadow-[0_32px_64px_-12px_rgba(0,0,0,0.8)]">
            <h3 id="alert-title" class="text-xl font-bold uppercase mb-4 tracking-widest text-white">Alerte</h3>
            <p id="alert-msg" class="text-white/40 mb-10 text-base leading-relaxed font-medium"></p>
            <button onclick="hideAlert()" class="btn-white w-full py-4 text-xs uppercase tracking-[0.2em]">Compris</button>
        </div>
    </div>

    <script>
        const initialData = new FormData(document.getElementById('configForm'));
        const saveBar = document.getElementById('save-bar');

        function checkChanges() {
            const currentData = new FormData(document.getElementById('configForm'));
            const allKeys = new Set([...initialData.keys(), ...currentData.keys()]);
            let changed = false;
            for (const key of allKeys) {
                if (initialData.get(key) !== currentData.get(key)) { changed = true; break; }
            }
            if (changed) saveBar.classList.add('visible');
            else saveBar.classList.remove('visible');
        }

        document.getElementById('configForm').addEventListener('input', checkChanges);
        document.getElementById('configForm').addEventListener('change', checkChanges);

        function toggleDropdown(trigger) { trigger.parentElement.classList.toggle('open'); }

        function selectOption(option, name) {
            const wrapper = option.closest('.custom-select-wrapper');
            const select = wrapper.querySelector('select');
            const trigger = wrapper.querySelector('.custom-select-trigger span');
            select.value = option.dataset.value;
            trigger.textContent = option.textContent;
            wrapper.querySelectorAll('.custom-option').forEach(o => o.classList.remove('selected'));
            option.classList.add('selected');
            wrapper.classList.remove('open');
            checkChanges();
        }

        window.addEventListener('click', (e) => {
            if (!e.target.closest('.custom-select-wrapper')) {
                document.querySelectorAll('.custom-select-wrapper').forEach(w => w.classList.remove('open'));
            }
            if (!e.target.closest('#schedDtWrapper')) {
                document.getElementById('schedDtWrapper')?.classList.remove('open');
            }
        });

        let _calYear = new Date().getFullYear();
        let _calMonth = new Date().getMonth();
        let _calDay = null;

        function toggleCalendar() {
            const wrapper = document.getElementById('schedDtWrapper');
            wrapper.classList.toggle('open');
            if (wrapper.classList.contains('open')) renderCalendar();
        }

        function renderCalendar() {
            const MONTHS = ['Janvier','Février','Mars','Avril','Mai','Juin','Juillet','Août','Septembre','Octobre','Novembre','Décembre'];
            document.getElementById('calMonthLabel').textContent = MONTHS[_calMonth] + ' ' + _calYear;
            const grid = document.getElementById('calGrid');
            grid.innerHTML = '';
            const firstDow = new Date(_calYear, _calMonth, 1).getDay();
            const daysInMonth = new Date(_calYear, _calMonth + 1, 0).getDate();
            const daysInPrev = new Date(_calYear, _calMonth, 0).getDate();
            const today = new Date();
            const offset = firstDow === 0 ? 6 : firstDow - 1;
            for (let i = offset - 1; i >= 0; i--) {
                const el = document.createElement('div');
                el.className = 'cal-day other-month';
                el.textContent = daysInPrev - i;
                grid.appendChild(el);
            }
            for (let d = 1; d <= daysInMonth; d++) {
                const el = document.createElement('div');
                el.className = 'cal-day';
                el.textContent = d;
                if (d === today.getDate() && _calMonth === today.getMonth() && _calYear === today.getFullYear()) el.classList.add('today');
                if (_calDay === d) el.classList.add('selected');
                el.onclick = () => { _calDay = d; renderCalendar(); updateSchedDt(); };
                grid.appendChild(el);
            }
            const total = offset + daysInMonth;
            const remaining = total % 7 === 0 ? 0 : 7 - (total % 7);
            for (let i = 1; i <= remaining; i++) {
                const el = document.createElement('div');
                el.className = 'cal-day other-month';
                el.textContent = i;
                grid.appendChild(el);
            }
        }

        function calPrevMonth() {
            _calMonth--;
            if (_calMonth < 0) { _calMonth = 11; _calYear--; }
            renderCalendar();
        }

        function calNextMonth() {
            _calMonth++;
            if (_calMonth > 11) { _calMonth = 0; _calYear++; }
            renderCalendar();
        }

        function updateSchedDt() {
            if (!_calDay) return;
            const h = String(Math.min(23, Math.max(0, parseInt(document.getElementById('calHour').value) || 0))).padStart(2, '0');
            const m = String(Math.min(59, Math.max(0, parseInt(document.getElementById('calMinute').value) || 0))).padStart(2, '0');
            const month = String(_calMonth + 1).padStart(2, '0');
            const day = String(_calDay).padStart(2, '0');
            const val = `${_calYear}-${month}-${day}T${h}:${m}`;
            document.getElementById('schedNextRun').value = val;
            const SHORT_MONTHS = ['Jan','Fév','Mar','Avr','Mai','Jun','Jul','Aoû','Sep','Oct','Nov','Déc'];
            document.getElementById('schedDtLabel').textContent = `${_calDay} ${SHORT_MONTHS[_calMonth]} ${_calYear} à ${h}:${m}`;
        }

        function resetSchedDt() {
            _calDay = null;
            _calYear = new Date().getFullYear();
            _calMonth = new Date().getMonth();
            document.getElementById('schedNextRun').value = '';
            document.getElementById('schedDtLabel').textContent = 'Choisir une date';
            document.getElementById('calHour').value = 12;
            document.getElementById('calMinute').value = 0;
        }

        function insertVar(fieldName, value) {
            const el = document.querySelector(`[name="${fieldName}"]`);
            const start = el.selectionStart, end = el.selectionEnd;
            el.value = el.value.slice(0, start) + value + el.value.slice(end);
            el.selectionStart = el.selectionEnd = start + value.length;
            el.focus();
            checkChanges();
        }

        function showSection(sectionId, element) {
            document.querySelectorAll('.content-section').forEach(s => s.classList.remove('active'));
            document.querySelectorAll('.nav-item').forEach(i => i.classList.remove('active'));
            document.getElementById('section-' + sectionId).classList.add('active');
            element.classList.add('active');
        }

        function showAlert(title, msg) {
            document.getElementById('alert-title').textContent = title;
            document.getElementById('alert-msg').textContent = msg;
            const o = document.getElementById('alert-overlay');
            o.classList.remove('hidden'); o.classList.add('flex');
        }
        function hideAlert() {
            const o = document.getElementById('alert-overlay');
            o.classList.add('hidden'); o.classList.remove('flex');
        }

        function showNotification(title, msg, type = 'success') {
            const container = document.getElementById('notification-container');
            const toast = document.createElement('div');
            toast.className = "relative bg-[#0a0a0a]/90 backdrop-blur-xl border border-white/10 rounded-2xl p-5 shadow-2xl overflow-hidden translate-x-full transition-all duration-500 opacity-0";
            toast.innerHTML = `
                <div class="flex items-start gap-4">
                    <div class="w-10 h-10 rounded-xl ${type === 'success' ? 'bg-green-500/10 text-green-500' : 'bg-red-500/10 text-red-500'} flex items-center justify-center shrink-0">
                        ${type === 'success'
                            ? '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>'
                            : '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>'}
                    </div>
                    <div class="flex-1">
                        <div class="text-xs font-black uppercase tracking-widest text-white mb-1">${title}</div>
                        <div class="text-xs text-white/40 leading-relaxed font-medium">${msg}</div>
                    </div>
                </div>
                <div class="absolute bottom-0 left-0 h-[3px] bg-white/20 w-full">
                    <div class="h-full bg-white/40 transition-all duration-[4000ms] ease-linear w-full" id="pb"></div>
                </div>`;
            container.appendChild(toast);
            setTimeout(() => { toast.classList.remove('translate-x-full', 'opacity-0'); toast.querySelector('#pb').style.width = '0%'; }, 100);
            setTimeout(() => { toast.classList.add('translate-x-full', 'opacity-0'); setTimeout(() => toast.remove(), 500); }, 4500);
        }

        function updateColorPreview(inputName, previewId, hexId, value) {
            document.getElementById(previewId).style.background = value;
            document.getElementById(hexId).textContent = value;
            checkChanges();
        }

        async function sendTest(type) {
            const btnId = type === 'welcome' ? 'test-welcome-btn' : 'test-leave-btn';
            const btn = document.getElementById(btnId);
            const p = type === 'welcome' ? 'welcome' : 'leave';
            const channelId = document.querySelector(`[name="${p}ChannelId"]`).value;
            const message = document.querySelector(`[name="${p}Message"]`).value;
            const title = document.querySelector(`[name="${p}Title"]`).value;
            const footer = document.querySelector(`[name="${p}Footer"]`).value;
            const color = document.querySelector(`[name="${p}Color"]`).value;

            if (!channelId) {
                showNotification("Erreur", "Aucun salon sélectionné.", "error");
                return;
            }

            const originalHTML = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = `<svg class="animate-spin" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-6.219-8.56"></path></svg> Envoi...`;

            try {
                const res = await fetch('/shard/guild/<%= guild.id %>/test', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ type, channelId, message, title, footer, color })
                });
                const result = await res.json();
                if (result.success) {
                    showNotification("Test envoyé", `Message de ${type === 'welcome' ? 'bienvenue' : 'départ'} envoyé dans le salon.`);
                } else {
                    showNotification("Erreur", result.error || "Impossible d'envoyer le message.", "error");
                }
            } catch (err) {
                showNotification("Erreur", err.message, "error");
            } finally {
                btn.innerHTML = originalHTML;
                btn.disabled = false;
            }
        }

        function selectEmbedChannel(option) {
            const wrapper = option.closest('.custom-select-wrapper');
            wrapper.querySelector('.custom-select-trigger span').textContent = option.textContent;
            wrapper.querySelectorAll('.custom-option').forEach(o => o.classList.remove('selected'));
            option.classList.add('selected');
            wrapper.classList.remove('open');
            document.getElementById('embedChannelId').value = option.dataset.value;
        }

        async function sendEmbed() {
            const channelId = document.getElementById('embedChannelId').value;
            if (!channelId) return showNotification('Erreur', 'Aucun salon sélectionné.', 'error');
            const btn = document.getElementById('send-embed-btn');
            const orig = btn.innerHTML;
            btn.disabled = true; btn.innerHTML = 'Envoi...';
            try {
                const res = await fetch('/shard/guild/<%= guild.id %>/send-embed', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        channelId,
                        title: document.getElementById('embedTitle').value,
                        description: document.getElementById('embedDescription').value,
                        footer: document.getElementById('embedFooter').value,
                        color: document.getElementById('embedColor').value,
                        image: document.getElementById('embedImage').value
                    })
                });
                const result = await res.json();
                if (result.success) showNotification('Embed envoyé', 'L\'embed a été posté avec succès.');
                else showNotification('Erreur', result.error || 'Impossible d\'envoyer l\'embed.', 'error');
            } catch (err) { showNotification('Erreur', err.message, 'error'); }
            finally { btn.innerHTML = orig; btn.disabled = false; }
        }

        let _pendingReactions = <%- safeJson(Array.isArray(settings.autoReactions) ? settings.autoReactions : JSON.parse(settings.autoReactions || '[]')) %>;

        function emojiPreview(emoji) {
            const m = emoji.match(/^<a?:(\w+):(\d+)>$/);
            if (m) {
                const animated = emoji.startsWith('<a:');
                return `<img src="https://cdn.discordapp.com/emojis/${m[2]}.${animated ? 'gif' : 'webp'}?size=32" style="width:22px;height:22px;vertical-align:middle;border-radius:4px;">`;
            }
            return `<span style="font-size:1.3rem;line-height:1;">${emoji}</span>`;
        }

        function addReaction() {
            const text = document.getElementById('newReactionText').value.trim();
            const emoji = document.getElementById('newReactionEmoji').value.trim();
            if (!text) return showNotification('Erreur', 'Entrez un texte.', 'error');
            if (!emoji) return showNotification('Erreur', 'Entrez un emoji.', 'error');
            if (_pendingReactions.find(r => r.text === text && r.emoji === emoji))
                return showNotification('Erreur', 'Cette réaction existe déjà.', 'error');
            _pendingReactions.push({ text, emoji });
            const empty = document.getElementById('reactions-empty');
            if (empty) empty.remove();
            const id = `reaction-${encodeURIComponent(text)}-${encodeURIComponent(emoji)}`;
            document.getElementById('reactions-list').insertAdjacentHTML('beforeend', `
                <div class="flex items-center justify-between bg-white/[0.03] border border-white/5 rounded-2xl px-5 py-4" id="${id}">
                    <div class="flex items-center gap-4">
                        <span class="text-white/60 text-sm font-bold">"${text}"</span>
                        ${emojiPreview(emoji)}
                    </div>
                    <button type="button" onclick="removeReaction('${encodeURIComponent(text)}','${encodeURIComponent(emoji)}')" class="text-xs font-bold uppercase tracking-widest text-white/30 hover:text-red-400 transition-colors">Supprimer</button>
                </div>`);
            document.getElementById('newReactionText').value = '';
            document.getElementById('newReactionEmoji').value = '';
            saveReactions();
        }

        function removeReaction(encodedText, encodedEmoji) {
            const text = decodeURIComponent(encodedText);
            const emoji = decodeURIComponent(encodedEmoji);
            _pendingReactions = _pendingReactions.filter(r => !(r.text === text && r.emoji === emoji));
            const el = document.getElementById(`reaction-${encodedText}-${encodedEmoji}`);
            if (el) el.remove();
            if (_pendingReactions.length === 0 && !document.getElementById('reactions-empty')) {
                document.getElementById('reactions-list').insertAdjacentHTML('beforeend', '<p class="text-white/20 text-sm" id="reactions-empty">Aucune réaction configurée.</p>');
            }
            saveReactions();
        }

        async function saveReactions() {
            await fetch('/shard/guild/<%= guild.id %>/reactions', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ autoReactions: _pendingReactions })
            });
            showNotification('Réactions', 'Réactions mises à jour.');
        }

        let _pendingRewards = <%- safeJson(Array.isArray(settings.levelRewards) ? settings.levelRewards : JSON.parse(settings.levelRewards || '[]')) %>;

        function addReward() {
            const level = parseInt(document.getElementById('newRewardLevel').value);
            const roleId = document.querySelector('[name="newRewardRole"]').value;
            if (!level || !roleId) return showNotification('Erreur', 'Sélectionnez un niveau et un rôle.', 'error');
            if (_pendingRewards.find(r => r.level === level)) return showNotification('Erreur', 'Ce niveau a déjà une récompense.', 'error');
            _pendingRewards.push({ level, roleId });
            _pendingRewards.sort((a,b) => a.level - b.level);
            const roleName = document.querySelector(`[name="newRewardRole"] option[value="${roleId}"]`)?.textContent || roleId;
            const empty = document.getElementById('rewards-empty');
            if (empty) empty.remove();
            const id = `reward-${level}-${roleId}`;
            document.getElementById('rewards-list').insertAdjacentHTML('beforeend', `
                <div class="flex items-center justify-between bg-white/[0.03] border border-white/5 rounded-2xl px-5 py-4" id="${id}">
                    <div class="flex items-center gap-4">
                        <span class="text-xs font-black uppercase tracking-widest text-blue-400">Niveau ${level}</span>
                        <span class="text-white/60 text-sm font-bold">@${roleName}</span>
                    </div>
                    <button type="button" onclick="removeReward(${level},'${roleId}')" class="text-xs font-bold uppercase tracking-widest text-white/30 hover:text-red-400 transition-colors">Supprimer</button>
                </div>`);
            document.getElementById('newRewardLevel').value = '';
            saveRewards();
        }

        function removeReward(level, roleId) {
            _pendingRewards = _pendingRewards.filter(r => !(r.level === level && r.roleId === roleId));
            const el = document.getElementById(`reward-${level}-${roleId}`);
            if (el) el.remove();
            if (_pendingRewards.length === 0 && !document.getElementById('rewards-empty')) {
                document.getElementById('rewards-list').insertAdjacentHTML('beforeend', '<p class="text-white/20 text-sm" id="rewards-empty">Aucune récompense configurée.</p>');
            }
            saveRewards();
        }

        async function saveRewards() {
            await fetch('/shard/guild/<%= guild.id %>/rewards', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ levelRewards: _pendingRewards })
            });
            showNotification('Récompenses', 'Récompenses mises à jour.');
        }

        let _thresholds = <%- safeJson(settings.levelThresholds) %>;

        function syncThresholdsInput() {
            document.getElementById('levelThresholdsData').value = JSON.stringify(_thresholds);
            checkChanges();
        }

        function updateThreshold(index, value) {
            _thresholds[index] = parseInt(value) || 1;
            syncThresholdsInput();
        }

        function removeThreshold(index) {
            _thresholds.splice(index, 1);
            rebuildThresholdsList();
            syncThresholdsInput();
        }

        function addThreshold() {
            const last = _thresholds[_thresholds.length - 1] || 100;
            _thresholds.push(Math.round(last * 1.5));
            rebuildThresholdsList();
            syncThresholdsInput();
        }

        function rebuildThresholdsList() {
            const list = document.getElementById('thresholds-list');
            list.innerHTML = _thresholds.map((xp, i) => `
                <div class="flex items-center gap-4 bg-white/[0.02] border border-white/5 rounded-2xl px-5 py-3" id="threshold-row-${i}">
                    <span class="text-xs font-black uppercase tracking-widest text-white/30 w-28 shrink-0">Niveau ${i} → ${i+1}</span>
                    <input type="number" class="threshold-input flex-1" data-index="${i}" value="${xp}" min="1" oninput="updateThreshold(${i}, this.value)" style="width:100%;">
                    <span class="text-xs text-white/20">XP</span>
                    <button type="button" onclick="removeThreshold(${i})" class="text-xs font-bold uppercase tracking-widest text-white/20 hover:text-red-400 transition-colors ml-2">Retirer</button>
                </div>`).join('');
        }

        const POLL_EMOJIS = ['🔵', '🟢', '🟡', '🟠', '🔴'];

        function updatePollChoiceNumbers() {
            const rows = document.querySelectorAll('.poll-choice-row');
            rows.forEach((row, i) => {
                row.querySelector('span').textContent = i + 1;
                row.querySelector('input').placeholder = `Choix ${i + 1}`;
                const btn = row.querySelector('button');
                btn.style.visibility = rows.length > 2 ? 'visible' : 'hidden';
            });
            document.getElementById('add-choice-btn').style.display = rows.length >= 5 ? 'none' : 'flex';
        }

        function addPollChoice() {
            const rows = document.querySelectorAll('.poll-choice-row');
            if (rows.length >= 5) return;
            const n = rows.length + 1;
            document.getElementById('poll-choices').insertAdjacentHTML('beforeend', `
                <div class="flex items-center gap-2 poll-choice-row">
                    <span class="text-xs font-black text-white/30 w-6 shrink-0 text-center">${n}</span>
                    <input type="text" class="poll-choice flex-1" placeholder="Choix ${n}">
                    <button type="button" onclick="removePollChoice(this)" class="text-white/20 hover:text-red-400 transition-colors shrink-0">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                    </button>
                </div>`);
            updatePollChoiceNumbers();
        }

        function removePollChoice(btn) {
            const rows = document.querySelectorAll('.poll-choice-row');
            if (rows.length <= 2) return;
            btn.closest('.poll-choice-row').remove();
            updatePollChoiceNumbers();
        }

        async function createPoll() {
            const channelId = document.querySelector('[name="pollChannelId"]').value;
            const question = document.getElementById('pollQuestion').value.trim();
            const choices = [...document.querySelectorAll('.poll-choice')].map(i => i.value.trim()).filter(Boolean);
            const duration = parseInt(document.getElementById('pollDuration').value);
            const unit = document.getElementById('pollDurUnit').value;
            if (!channelId) return showNotification('Erreur', 'Sélectionnez un salon.', 'error');
            if (!question) return showNotification('Erreur', 'Entrez une question.', 'error');
            if (choices.length < 2) return showNotification('Erreur', 'Entrez au moins 2 choix.', 'error');
            let endsAt = null;
            if (duration && !isNaN(duration)) {
                let ms = duration * 3600000;
                if (unit === 'days') ms = duration * 86400000;
                if (unit === 'minutes') ms = duration * 60000;
                endsAt = new Date(Date.now() + ms).toISOString();
            }
            const pollAnonEl = document.getElementById('pollAnonymous');
            const pollAnonymous = pollAnonEl ? pollAnonEl.value : '0';
            const res = await fetch('/shard/guild/<%= guild.id %>/poll', {
                method: 'POST', headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ channelId, question, choices, endsAt, pollAnonymous })
            });
            const result = await res.json();
            if (result.success) {
                showNotification('Sondage lancé', `📊 "${question}"`);
                document.getElementById('pollQuestion').value = '';
                document.getElementById('pollDuration').value = '';
                document.querySelectorAll('.poll-choice').forEach((el, i) => { el.value = ''; });
                const list = document.getElementById('polls-list');
                const empty = list.querySelector('p');
                if (empty) empty.remove();
                list.insertAdjacentHTML('afterbegin', `
                    <div class="flex items-start justify-between bg-white/[0.03] border border-white/5 rounded-2xl px-5 py-4" id="poll-${result.id}">
                        <div class="flex-1 min-w-0 mr-4">
                            <div class="font-bold text-sm mb-2">📊 ${question}</div>
                            <div class="flex flex-wrap gap-1 mb-2">${choices.map((c,i) => `<span class="text-[10px] font-bold uppercase tracking-widest bg-white/5 border border-white/5 px-2 py-1 rounded-lg text-white/40">${i+1}. ${c}</span>`).join('')}</div>
                            ${endsAt ? `<div class="text-xs text-white/20">Se termine le ${new Date(endsAt).toLocaleString('fr-FR')}</div>` : ''}
                        </div>
                        <button type="button" onclick="endPoll(${result.id})" class="text-xs font-bold uppercase tracking-widest text-white/30 hover:text-red-400 transition-colors shrink-0 mt-1">Clôturer</button>
                    </div>`);
            } else {
                showNotification('Erreur', result.error || 'Impossible de créer le sondage.', 'error');
            }
        }

        async function endPoll(id) {
            const res = await fetch(`/shard/guild/<%= guild.id %>/poll/${id}/end`, { method: 'POST' });
            const result = await res.json();
            if (result.success) {
                document.getElementById(`poll-${id}`)?.remove();
                const votes = result.results;
                const summary = votes.map(v => `${v.choice}: ${v.count} vote(s)`).join(' · ');
                showNotification('Sondage clôturé', summary || 'Aucun vote.');
                if (!document.querySelector('#polls-list [id^="poll-"]')) {
                    document.getElementById('polls-list').innerHTML = '<p class="text-white/20 text-sm">Aucun sondage actif.</p>';
                }
            } else {
                showNotification('Erreur', result.error || 'Erreur lors de la clôture.', 'error');
            }
        }

        async function createGiveaway() {
            const channelId = document.querySelector('[name="gwChannelId"]').value;
            const prize = document.getElementById('gwPrize').value.trim();
            const winners = parseInt(document.getElementById('gwWinners').value) || 1;
            const duration = parseInt(document.getElementById('gwDuration').value) || 24;
            const unit = document.getElementById('gwUnit').value;
            if (!channelId) return showNotification('Erreur', 'Sélectionnez un salon.', 'error');
            if (!prize) return showNotification('Erreur', 'Entrez un lot à gagner.', 'error');
            let ms = duration * 3600000;
            if (unit === 'days') ms = duration * 86400000;
            if (unit === 'minutes') ms = duration * 60000;
            const endsAt = new Date(Date.now() + ms).toISOString();
            const gwMinRoleEl = document.getElementById('gwMinRole');
            const gwMinLevelEl = document.getElementById('gwMinLevel');
            const gwMinRole = gwMinRoleEl ? gwMinRoleEl.value : '';
            const gwMinLevel = gwMinLevelEl ? parseInt(gwMinLevelEl.value) || 0 : 0;
            const res = await fetch('/shard/guild/<%= guild.id %>/giveaway', {
                method: 'POST', headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ channelId, prize, winnersCount: winners, endsAt, gwMinRole, gwMinLevel })
            });
            const result = await res.json();
            if (result.success) {
                showNotification('Giveaway lancé', `🎉 "${prize}" dans <#${channelId}>`);
                document.getElementById('gwPrize').value = '';
                document.getElementById('gwWinners').value = 1;
                document.getElementById('gwDuration').value = 24;
                const list = document.getElementById('giveaways-list');
                const empty = list.querySelector('p');
                if (empty) empty.remove();
                list.insertAdjacentHTML('afterbegin', `
                    <div class="flex items-center justify-between bg-white/[0.03] border border-white/5 rounded-2xl px-5 py-4">
                        <div>
                            <div class="font-bold text-sm mb-1">🎉 ${prize}</div>
                            <div class="text-xs text-white/30">${winners} gagnant(s) · se termine le ${new Date(endsAt).toLocaleString('fr-FR')}</div>
                        </div>
                        <button type="button" onclick="endGiveaway(${result.id})" class="text-xs font-bold uppercase tracking-widest text-white/30 hover:text-red-400 transition-colors">Terminer</button>
                    </div>`);
            } else {
                showNotification('Erreur', result.error || 'Impossible de créer le giveaway.', 'error');
            }
        }

        async function endGiveaway(id) {
            const res = await fetch(`/shard/guild/<%= guild.id %>/giveaway/${id}/end`, { method: 'POST' });
            const result = await res.json();
            if (result.success) {
                showNotification('Giveaway terminé', result.winners?.length ? `Gagnant(s) : ${result.winners.join(', ')}` : 'Aucun participant.');
                setTimeout(() => location.reload(), 1500);
            } else {
                showNotification('Erreur', result.error || 'Erreur lors de la clôture.', 'error');
            }
        }

        async function addScheduled() {
            const channelId = document.querySelector('[name="schedChannelId"]').value;
            const message = document.getElementById('schedMessage').value.trim();
            const interval = parseInt(document.getElementById('schedInterval').value) || 24;
            const unit = document.getElementById('schedUnit').value;
            const nextRunVal = document.getElementById('schedNextRun').value;
            if (!channelId) return showNotification('Erreur', 'Sélectionnez un salon.', 'error');
            if (!message) return showNotification('Erreur', 'Entrez un message.', 'error');
            if (!nextRunVal) return showNotification('Erreur', 'Définissez la première exécution.', 'error');
            const intervalHours = unit === 'days' ? interval * 24 : interval;
            const res = await fetch('/shard/guild/<%= guild.id %>/scheduled', {
                method: 'POST', headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ channelId, message, intervalHours, nextRun: new Date(nextRunVal).toISOString() })
            });
            const result = await res.json();
            if (result.success) {
                showNotification('Annonce planifiée', 'L\'annonce a été planifiée.');
                document.getElementById('schedMessage').value = '';
                document.getElementById('schedInterval').value = 24;
                resetSchedDt();
                const list = document.getElementById('scheduled-list');
                const empty = document.getElementById('scheduled-empty');
                if (empty) empty.remove();
                list.insertAdjacentHTML('beforeend', `
                    <div class="flex items-center justify-between bg-white/[0.03] border border-white/5 rounded-2xl px-5 py-4" id="sched-${result.id}">
                        <div class="flex-1 min-w-0 mr-4">
                            <div class="text-xs font-bold text-blue-400 mb-1">Salon sélectionné · toutes les ${intervalHours}h</div>
                            <div class="text-sm text-white/60 truncate">${message}</div>
                            <div class="text-xs text-white/20 mt-1">Prochaine : ${new Date(nextRunVal).toLocaleString('fr-FR')}</div>
                        </div>
                        <button type="button" onclick="removeScheduled(${result.id})" class="text-xs font-bold uppercase tracking-widest text-white/30 hover:text-red-400 transition-colors shrink-0">Supprimer</button>
                    </div>`);
            } else {
                showNotification('Erreur', result.error || 'Impossible de planifier.', 'error');
            }
        }

        async function removeScheduled(id) {
            const res = await fetch(`/shard/guild/<%= guild.id %>/scheduled/${id}`, { method: 'DELETE' });
            const result = await res.json();
            if (result.success) {
                document.getElementById(`sched-${id}`)?.remove();
                showNotification('Annonce supprimée', 'L\'annonce planifiée a été supprimée.');
                if (!document.querySelector('#scheduled-list [id^="sched-"]')) {
                    document.getElementById('scheduled-list').insertAdjacentHTML('beforeend', '<p class="text-white/20 text-sm" id="scheduled-empty">Aucune annonce planifiée.</p>');
                }
            } else {
                showNotification('Erreur', result.error || 'Erreur lors de la suppression.', 'error');
            }
        }

        async function addShopItem() {
            const roleId = document.querySelector('[name="newShopRole"]').value;
            const price = parseInt(document.getElementById('newShopPrice').value);
            if (!roleId) return showNotification('Erreur', 'Sélectionnez un rôle.', 'error');
            if (!price || price < 1) return showNotification('Erreur', 'Entrez un prix valide.', 'error');
            const res = await fetch('/shard/guild/<%= guild.id %>/shop', {
                method: 'POST', headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ roleId, price })
            });
            const result = await res.json();
            if (result.success) {
                showNotification('Article ajouté', 'L\'article a été ajouté au shop.');
                document.getElementById('newShopPrice').value = '';
                const list = document.getElementById('shop-list');
                const empty = document.getElementById('shop-empty');
                if (empty) empty.remove();
                const currency = document.querySelector('[name="economyCurrencyName"]')?.value || 'coins';
                const roleName = document.querySelector(`[name="newShopRole"] option[value="${roleId}"]`)?.textContent || roleId;
                list.insertAdjacentHTML('beforeend', `
                    <div class="flex items-center justify-between bg-white/[0.03] border border-white/5 rounded-2xl px-5 py-4" id="shop-${result.id}">
                        <div class="flex items-center gap-4">
                            <span class="text-sm font-bold text-white/80">@${roleName}</span>
                            <span class="text-xs font-black text-yellow-400">${price} ${currency}</span>
                        </div>
                        <button type="button" onclick="removeShopItem(${result.id})" class="text-xs font-bold uppercase tracking-widest text-white/30 hover:text-red-400 transition-colors">Supprimer</button>
                    </div>`);
            } else {
                showNotification('Erreur', result.error || 'Impossible d\'ajouter l\'article.', 'error');
            }
        }

        async function removeShopItem(id) {
            const res = await fetch(`/shard/guild/<%= guild.id %>/shop/${id}`, { method: 'DELETE' });
            const result = await res.json();
            if (result.success) {
                document.getElementById(`shop-${id}`)?.remove();
                showNotification('Article supprimé', 'L\'article a été retiré du shop.');
                if (!document.querySelector('#shop-list [id^="shop-"]')) {
                    document.getElementById('shop-list').insertAdjacentHTML('beforeend', '<p class="text-white/20 text-sm" id="shop-empty">Aucun article dans le shop.</p>');
                }
            } else {
                showNotification('Erreur', result.error || 'Erreur lors de la suppression.', 'error');
            }
        }

        async function sendTicketPanel() {
            const btn = document.getElementById('send-ticket-panel-btn');
            const channelId = document.querySelector('[name="ticketPanelChannelId"]').value;
            const title = document.querySelector('[name="ticketPanelTitle"]').value;
            const description = document.querySelector('[name="ticketPanelDescription"]').value;
            const color = document.querySelector('[name="ticketPanelColor"]').value;

            if (!channelId) return showNotification('Erreur', 'Sélectionnez un salon pour le panel.', 'error');

            const originalHTML = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = `<svg class="animate-spin" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-6.219-8.56"></path></svg> Envoi...`;

            try {
                const res = await fetch('/shard/guild/<%= guild.id %>/ticket-panel', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ channelId, title, description, color })
                });
                const result = await res.json();
                if (result.success) {
                    showNotification('Panel envoyé', 'Le panel de tickets a été envoyé dans le salon.');
                } else {
                    showNotification('Erreur', result.error || "Impossible d'envoyer le panel.", 'error');
                }
            } catch (err) {
                showNotification('Erreur', err.message, 'error');
            } finally {
                btn.disabled = false;
                btn.innerHTML = originalHTML;
            }
        }

        async function saveConfig() {
            const btn = document.querySelector('#save-bar .btn-white');
            const originalContent = btn.innerHTML;
            const originalClasses = btn.className;
            const formData = new FormData(document.getElementById('configForm'));
            const data = Object.fromEntries(formData.entries());

            btn.disabled = true;
            btn.style.width = btn.offsetWidth + 'px';
            btn.style.height = btn.offsetHeight + 'px';
            btn.className = "rounded-full text-xs font-bold uppercase transition-all flex items-center justify-center bg-orange-500/10 border border-orange-500/20 text-orange-500";
            btn.innerHTML = `<svg class="animate-spin" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-6.219-8.56"></path></svg>`;

            try {
                const response = await fetch('/shard/guild/<%= guild.id %>/config', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                const result = await response.json();

                if (result.success) {
                    btn.className = "rounded-full text-xs font-bold uppercase transition-all flex items-center justify-center bg-green-500/10 border border-green-500/20 text-green-500";
                    btn.innerHTML = `<div class="success-checkmark"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="16 9 10.5 14.5 8 12"></polyline></svg></div>`;
                    showNotification("Configuration", "Vos modifications ont été enregistrées.");
                    const updatedData = new FormData(document.getElementById('configForm'));
                    for (let [key, value] of updatedData.entries()) initialData.set(key, value);
                    setTimeout(() => {
                        saveBar.classList.remove('visible');
                        setTimeout(() => { btn.className = originalClasses; btn.innerHTML = originalContent; btn.style.width = ''; btn.style.height = ''; btn.disabled = false; }, 400);
                    }, 2000);
                } else {
                    throw new Error(result.error || "Erreur inconnue");
                }
            } catch (err) {
                btn.className = "rounded-full text-xs font-bold uppercase transition-all flex items-center justify-center bg-red-500/10 border border-red-500/20 text-red-500";
                btn.innerHTML = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>`;
                showNotification("Erreur", err.message, "error");
                setTimeout(() => { btn.className = originalClasses; btn.innerHTML = originalContent; btn.style.width = ''; btn.style.height = ''; btn.disabled = false; }, 3000);
            }
        }

        let _xpMultRoleId = null;
        function selectXpMultRole(el) {
            _xpMultRoleId = el.dataset.value;
            document.getElementById('xp-mult-role-label').textContent = el.textContent;
            el.closest('.custom-select-wrapper').classList.remove('open');
        }

        function addXpMult() {
            const roleId = _xpMultRoleId;
            const mult = parseFloat(document.getElementById('xp-mult-value').value);
            if (!roleId) return showNotification('Erreur', 'Sélectionnez un rôle.', 'error');
            if (!mult || mult <= 0) return showNotification('Erreur', 'Entrez un multiplicateur valide.', 'error');
            const label = document.getElementById('xp-mult-role-label').textContent;
            const list = document.getElementById('xp-multipliers-list');
            const empty = document.getElementById('xp-mult-empty');
            if (empty) empty.remove();
            const div = document.createElement('div');
            div.className = 'flex items-center gap-3 bg-white/[0.03] border border-white/5 rounded-2xl px-4 py-3';
            div.setAttribute('data-xp-mult', '');
            div.innerHTML = `<span class="font-bold text-sm flex-1">${label}</span><span class="text-xs font-black text-yellow-400">×${mult}</span><button type="button" onclick="removeXpMult(this)" class="text-white/20 hover:text-red-400 transition-colors"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg></button><input type="hidden" name="xpMultRoleId[]" value="${roleId}"><input type="hidden" name="xpMultValue[]" value="${mult}">`;
            list.appendChild(div);
            _xpMultRoleId = null;
            document.getElementById('xp-mult-role-label').textContent = '— Rôle —';
            document.getElementById('xp-mult-value').value = '';
        }

        function removeXpMult(btn) {
            btn.closest('[data-xp-mult]').remove();
            if (!document.querySelector('[data-xp-mult]')) {
                const list = document.getElementById('xp-multipliers-list');
                if (!document.getElementById('xp-mult-empty')) {
                    list.insertAdjacentHTML('afterbegin', '<p class="text-white/20 text-sm" id="xp-mult-empty">Aucun multiplicateur configuré.</p>');
                }
            }
        }

        async function doBackupShard() {
            try {
                const r = await fetch('/shard/guild/<%= guild.id %>/backup', { method: 'POST' });
                const data = await r.json();
                if (data.success) showNotification('Backup', 'Backup créé avec succès !', 'success');
                else showNotification('Erreur', data.error || 'Erreur lors du backup', 'error');
            } catch { showNotification('Erreur', 'Erreur réseau', 'error'); }
        }

        async function doRestoreShard() {
            if (!confirm('⚠️ Restaurer le dernier backup ? La configuration actuelle sera écrasée.')) return;
            try {
                const r = await fetch('/shard/guild/<%= guild.id %>/restore', { method: 'POST' });
                const data = await r.json();
                if (data.success) { showNotification('Restauration', 'Configuration restaurée !', 'success'); setTimeout(() => location.reload(), 1500); }
                else showNotification('Erreur', data.error || 'Erreur lors de la restauration', 'error');
            } catch { showNotification('Erreur', 'Erreur réseau', 'error'); }
        }

    </script>
</body>
</html>
