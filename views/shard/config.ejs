                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="17 8 12 3 7 8"></polyline><line x1="12" y1="3" x2="12" y2="15"></line></svg>
                        </div>
                        <div>
                            <h3 class="font-bold text-sm uppercase tracking-widest">Backup & Restauration</h3>
                            <p class="text-xs text-white/30 mt-0.5">Sauvegardez et restaurez toute la configuration Shard en un clic</p>
                        </div>
                    </div>
                    <div class="flex gap-4">
                        <button type="button" onclick="doBackupShard()" class="btn-white" style="border-radius:14px;padding:10px 24px;font-size:0.8rem;">
                            Créer un backup
                        </button>
                        <button type="button" onclick="doRestoreShard()" class="flex items-center gap-2 px-6 py-3 rounded-[14px] text-sm font-bold border border-white/10 text-white/50 hover:text-white hover:border-white/30 transition-all">
                            Restaurer le dernier backup
                        </button>
                    </div>
