                            <p class="text-white/20 text-sm">Aucun sondage actif.</p>
                        <% } else { %>
                            <% polls.forEach(p => { const pChoices = typeof p.choices === 'string' ? JSON.parse(p.choices) : p.choices; %>
                            <div class="flex items-start justify-between bg-white/[0.03] border border-white/5 rounded-2xl px-5 py-4">
                                <div class="flex-1 min-w-0 mr-4">
