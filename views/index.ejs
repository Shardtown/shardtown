<!DOCTYPE html>
<html lang="fr" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <link rel="icon" type="image/png" href="/image/favicon.png">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SHARDTOWN</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #000000;
            --text: #ffffff;
            --accent: #ffffff;
            --muted: #888888;
            --border: #1a1a1a;
        }
        
        body { 
            font-family: 'Plus Jakarta Sans', sans-serif; 
            background: #000;
            background-image: 
                radial-gradient(at 50% 0%, rgba(37, 99, 235, 0.2) 0px, transparent 50%),
                radial-gradient(at 0% 100%, rgba(139, 92, 246, 0.1) 0px, transparent 50%),
                radial-gradient(at 100% 100%, rgba(236, 72, 153, 0.1) 0px, transparent 50%),
                radial-gradient(at 50% 50%, rgba(37, 99, 235, 0.05) 0px, transparent 50%);
            background-attachment: fixed;
            color: var(--text); 
            margin: 0;
            padding: 0;
        }

        .bg-glow {
            position: fixed;
            top: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 100%;
            height: 100vh;
            background: radial-gradient(circle at 50% -20%, rgba(37, 99, 235, 0.1) 0%, transparent 70%);
            pointer-events: none;
            z-index: -1;
        }

        .container-wide {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 24px;
        }

        .nav-link {
            color: var(--muted);
            transition: color 0.2s;
            font-size: 0.875rem;
            font-weight: 500;
        }

        .nav-link:hover { color: var(--text); }

        .btn-white {
            background: #fff;
            color: #000;
            padding: 10px 24px;
            border-radius: 100px;
            font-weight: 700;
            font-size: 0.875rem;
            transition: opacity 0.2s;
        }

        .btn-white:hover { opacity: 0.9; }

        .hero-title {
            font-size: clamp(3rem, 8vw, 6rem);
            font-weight: 800;
            line-height: 0.9;
            letter-spacing: -0.02em;
            margin-bottom: 2rem;
        }

        .product-card {
            background: #0a0a0a;
            border: 1px solid #1a1a1a;
            padding: 40px;
            border-radius: 24px;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            overflow: hidden;
        }

        .product-card:hover { border-color: #333; transform: translateY(-4px); }

        .service-card {
            background: #0a0a0a;
            border: 1px solid #1a1a1a;
            padding: 40px;
            border-radius: 24px;
        }

        .guild-row {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 12px 16px;
            border-radius: 14px;
            border: 1px solid #1a1a1a;
            background: #0a0a0a;
            transition: all 0.2s;
            text-decoration: none;
            color: inherit;
        }

        .guild-row:hover { border-color: #333; background: #111; }

        .guild-icon {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            object-fit: cover;
            border: 1px solid rgba(255,255,255,0.05);
            flex-shrink: 0;
        }

        .badge {
            font-size: 0.65rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            padding: 4px 10px;
            border-radius: 8px;
        }
        .badge-active { background: rgba(37, 99, 235, 0.1); color: #60a5fa; border: 1px solid rgba(37, 99, 235, 0.2); }
        .badge-inactive { background: rgba(255,255,255,0.05); color: #555; border: 1px solid #1a1a1a; }

        @media (max-width: 768px) {
            .pricing-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>
    <div class="bg-glow"></div>

    <!-- Header -->
    <div class="fixed top-6 left-0 right-0 z-50 px-6">
        <header id="main-header" class="container-wide flex justify-between items-center bg-transparent rounded-full transition-all duration-300 py-4 px-8 border border-white/10">
            <a href="/" class="flex items-center gap-2">
                <img src="/image/shardtown.jpeg" alt="Shardtown Logo" class="w-10 h-10 rounded-full object-cover">
                <span class="font-bold tracking-tight text-xl uppercase">Shardtown</span>
            </a>
            <nav class="hidden md:flex items-center gap-8">
                <a href="#products" class="nav-link">Produits</a>
                <a href="#services" class="nav-link">Services</a>
                <a href="#about" class="nav-link">À propos</a>
                <a href="/wiki" class="nav-link">Wiki</a>
                <a href="/status" class="nav-link">Statut</a>
            </nav>
            <% if (user) { %>
                <div class="flex items-center gap-4">
                    <div class="hidden md:flex items-center gap-3 px-4 py-2 bg-white/5 rounded-full border border-white/5">
                        <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" class="w-7 h-7 rounded-full border border-white/10" alt="">
                        <span class="font-bold text-sm"><%= user.username %></span>
                    </div>
                    <a href="/dashboard" class="btn-white">Dashboard</a>
                </div>
            <% } else { %>
                <a href="/dashboard" class="btn-white">Dashboard</a>
            <% } %>
        </header>
    </div>

    <script>
        console.log(
            '%c' +
            '███  █  █  ██  ███  ███  ████  ██  █   █ █  █\n' +
            '█    █  █ █  █ █  █ █  █  █   █  █ █   █ ██ █\n' +
            '███  ████ ████ ███  █  █  █   █  █ █ █ █ █ ██\n' +
            '  █  █  █ █  █ █ █  █  █  █   █  █ ██ ██ █  █\n' +
            '███  █  █ █  █ █  █ ███   █    ██  █   █ █  █\n',
            'color: #3b82f6; font-family: monospace; font-size: 13px; line-height: 1; font-weight: bold;'
        );
        console.log('%c© 2026 Shardtown — shardtown.fr', 'color: #444; font-family: monospace; font-size: 10px;');

        window.addEventListener('scroll', () => {
            const header = document.getElementById('main-header');
            if (window.scrollY > 50) {
                header.classList.remove('bg-transparent', 'border-white/10');
                header.classList.add('bg-white/5', 'backdrop-blur-lg', 'border-white/5');
            } else {
                header.classList.add('bg-transparent', 'border-white/10');
                header.classList.remove('bg-white/5', 'backdrop-blur-lg', 'border-white/5');
            }
        });
    </script>

    <!-- Hero -->
    <main class="pt-40">
        <section class="container-wide text-center py-20">
            <div class="mb-12">
                <p class="text-sm font-bold tracking-widest text-white/40 uppercase mb-4">Présentation de</p>
                <h1 class="hero-title">SHARDTOWN</h1>
            </div>
            <div class="max-w-3xl mx-auto">
                <h2 class="text-2xl md:text-3xl font-bold mb-6 tracking-tight">
                    L'ÉCOSYSTÈME DIGITAL DE RÉFÉRENCE.<br>
                    <span class="text-white/40 uppercase text-lg">CONCEPTION, SÉCURISATION ET AUTOMATISATION DE VOS PROJETS LES PLUS AMBITIEUX.</span>
                </h2>
                <a href="#products" class="text-sm font-bold tracking-widest hover:opacity-70 transition-opacity">DÉCOUVRIR NOS SOLUTIONS ></a>
            </div>
        </section>

        <!-- Products -->
        <section id="products" class="py-24">
            <div class="container-wide">
                <div class="mb-16 text-center">
                    <p class="text-sm font-bold tracking-widest text-white/40 uppercase mb-4">Nos Produits</p>
                </div>

                <div class="grid md:grid-cols-2 gap-6 max-w-4xl mx-auto">
                    <div class="product-card text-left">
                        <div class="flex items-center gap-5 mb-6">
                            <img src="/image/shardguard.png" alt="ShardGuard Logo" class="w-14 h-14 rounded-2xl object-cover border border-white/5">
                            <h3 class="text-2xl font-bold">ShardGuard</h3>
                        </div>
                        <p class="text-white/50 leading-relaxed mb-8">Système de vérification avancé pour protéger votre communauté contre les raids de bots et autres interactions indésirables. Intègre un anti-raid configurable, des rôles de vérification, des logs de modération et un système de captcha personnalisable.</p>
                        <div class="flex flex-wrap gap-2">
                            <span class="text-xs font-bold px-3 py-1 rounded-full bg-white/5 border border-white/10 text-white/50">Anti-raid</span>
                            <span class="text-xs font-bold px-3 py-1 rounded-full bg-white/5 border border-white/10 text-white/50">Captcha</span>
                            <span class="text-xs font-bold px-3 py-1 rounded-full bg-white/5 border border-white/10 text-white/50">Modération</span>
                            <span class="text-xs font-bold px-3 py-1 rounded-full bg-white/5 border border-white/10 text-white/50">Logs</span>
                        </div>
                    </div>

                    <div class="product-card text-left">
                        <div class="flex items-center gap-5 mb-6">
                            <img src="/image/shard.png" alt="Shard Logo" class="w-14 h-14 rounded-2xl object-cover border border-white/5">
                            <h3 class="text-2xl font-bold">Shard</h3>
                        </div>
                        <p class="text-white/50 leading-relaxed mb-8">Bot multifonction pour animer et automatiser votre serveur. Gestion d'anniversaires, système d'économie avec shop et récompenses quotidiennes, giveaways, sondages, messages planifiés, embeds personnalisés et messages de bienvenue configurables.</p>
                        <div class="flex flex-wrap gap-2">
                            <span class="text-xs font-bold px-3 py-1 rounded-full bg-white/5 border border-white/10 text-white/50">Économie</span>
                            <span class="text-xs font-bold px-3 py-1 rounded-full bg-white/5 border border-white/10 text-white/50">Giveaways</span>
                            <span class="text-xs font-bold px-3 py-1 rounded-full bg-white/5 border border-white/10 text-white/50">Sondages</span>
                            <span class="text-xs font-bold px-3 py-1 rounded-full bg-white/5 border border-white/10 text-white/50">Anniversaires</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Services -->
        <section id="services" class="py-24">
            <div class="container-wide">
                <p class="text-sm font-bold tracking-widest text-white/40 uppercase mb-4">Nos Services</p>
                <div class="grid md:grid-cols-2 gap-16 items-center">
                    <div>
                        <h2 class="text-4xl font-bold mb-8 leading-tight">Des solutions sur mesure pour vos projets digitaux.</h2>
                        <p class="text-white/50 text-lg mb-8">Nous accompagnons les projets les plus ambitieux dans la création d'environnements sécurisés, engageants et automatisés.</p>
                    </div>
                    <div class="grid gap-6">
                        <div class="service-card">
                            <h3 class="text-xl font-bold mb-2">Configuration Serveurs Discord</h3>
                            <p class="text-white/50 mb-6">Des serveurs Discord clé en main, prêts à accueillir vos utilisateurs avec une structure professionnelle, sécurisée et optimisée.</p>
                            <button class="px-6 py-3 bg-white text-black rounded-full font-bold text-sm">En savoir plus</button>
                        </div>
                        <div class="service-card">
                            <h3 class="text-xl font-bold mb-2">Développement Bots Discord</h3>
                            <p class="text-white/50 mb-6">Création de bots Discord sur mesure et d'outils personnalisés pour automatiser et enrichir les fonctionnalités de votre écosystème.</p>
                            <button class="px-6 py-3 border border-white/10 rounded-full font-bold text-sm">Démarrer un projet</button>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <footer class="py-20">
        <div class="container-wide">
            <div class="flex flex-col md:flex-row justify-between items-center gap-8">
                <div class="flex items-center gap-2">
                    <img src="/image/shardtown.jpeg" alt="Shardtown Logo" class="w-6 h-6 rounded-full object-cover">
                    <span class="font-bold tracking-tight text-sm uppercase">Shardtown</span>
                </div>
                <div class="flex gap-8">
                    <a href="/status" class="text-xs font-bold text-white/30 hover:text-white transition-colors">Statut</a>
                    <a href="/terms" class="text-xs font-bold text-white/30 hover:text-white transition-colors">Conditions Générales</a>
                    <a href="/privacy" class="text-xs font-bold text-white/30 hover:text-white transition-colors">Politique de Confidentialité</a>
                    <a href="/admin" class="text-xs font-bold text-white/30 hover:text-white transition-colors">Administrateur</a>
                </div>
                <p class="text-xs font-bold text-white/30">Copyright © 2026 Shardtown. Tous droits réservés.</p>
            </div>
        </div>
    </footer>
</body>
</html>
