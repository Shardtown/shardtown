<!DOCTYPE html>
<html lang="fr" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <link rel="icon" type="image/png" href="/image/favicon.png">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SHARDTOWN</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #000000;
            --text: #ffffff;
            --accent: #ffffff;
            --muted: #888888;
            --border: #1a1a1a;
        }
        
        body { 
            font-family: 'Plus Jakarta Sans', sans-serif; 
            background: #000;
            background-image: 
                radial-gradient(at 50% 0%, rgba(37, 99, 235, 0.2) 0px, transparent 50%),
                radial-gradient(at 0% 100%, rgba(139, 92, 246, 0.1) 0px, transparent 50%),
                radial-gradient(at 100% 100%, rgba(236, 72, 153, 0.1) 0px, transparent 50%),
                radial-gradient(at 50% 50%, rgba(37, 99, 235, 0.05) 0px, transparent 50%);
            background-attachment: fixed;
            color: var(--text); 
            margin: 0;
            padding: 0;
        }

        .bg-glow {
            position: fixed;
            top: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 100%;
            height: 100vh;
            background: radial-gradient(circle at 50% -20%, rgba(37, 99, 235, 0.1) 0%, transparent 70%);
            pointer-events: none;
            z-index: -1;
        }

        .container-wide {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 24px;
        }

        .nav-link {
            color: var(--muted);
            transition: color 0.2s;
            font-size: 0.875rem;
            font-weight: 500;
        }

        .nav-link:hover { color: var(--text); }

        .btn-white {
            background: #fff;
            color: #000;
            padding: 10px 24px;
            border-radius: 100px;
            font-weight: 700;
            font-size: 0.875rem;
            transition: opacity 0.2s;
        }

        .btn-white:hover { opacity: 0.9; }

        .hero-title {
            font-size: clamp(3rem, 8vw, 6rem);
            font-weight: 800;
            line-height: 0.9;
            letter-spacing: -0.02em;
            margin-bottom: 2rem;
        }

        .product-card {
            background: #0a0a0a;
            border: 1px solid #1a1a1a;
            padding: 40px;
            border-radius: 24px;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            overflow: hidden;
        }

        .product-card { cursor: pointer; }
        .product-card:hover { border-color: #333; transform: translateY(-4px); }

        .modal-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.8);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            z-index: 200;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 24px;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s cubic-bezier(0.4,0,0.2,1);
        }
        .modal-overlay.open {
            opacity: 1;
            pointer-events: all;
        }
        .modal-box {
            background: #0a0a0a;
            border: 1px solid #222;
            border-radius: 28px;
            padding: 48px;
            max-width: 600px;
            width: 100%;
            max-height: 90vh;
            overflow-y: auto;
            transform: translateY(24px) scale(0.97);
            transition: transform 0.3s cubic-bezier(0.4,0,0.2,1);
        }
        .modal-overlay.open .modal-box {
            transform: translateY(0) scale(1);
        }
        .modal-feature {
            display: flex;
            align-items: flex-start;
            gap: 14px;
            padding: 14px 0;
            border-bottom: 1px solid rgba(255,255,255,0.04);
        }
        .modal-feature:last-child { border-bottom: none; padding-bottom: 0; }
        .modal-feature:first-child { padding-top: 0; }
        .modal-feature-icon {
            width: 36px;
            height: 36px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .service-card {
            background: #0a0a0a;
            border: 1px solid #1a1a1a;
            padding: 40px;
            border-radius: 24px;
        }

        .guild-row {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 12px 16px;
            border-radius: 14px;
            border: 1px solid #1a1a1a;
            background: #0a0a0a;
            transition: all 0.2s;
            text-decoration: none;
            color: inherit;
        }

        .guild-row:hover { border-color: #333; background: #111; }

        .guild-icon {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            object-fit: cover;
            border: 1px solid rgba(255,255,255,0.05);
            flex-shrink: 0;
        }

        .badge {
            font-size: 0.65rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            padding: 4px 10px;
            border-radius: 8px;
        }
        .badge-active { background: rgba(37, 99, 235, 0.1); color: #60a5fa; border: 1px solid rgba(37, 99, 235, 0.2); }
        .badge-inactive { background: rgba(255,255,255,0.05); color: #555; border: 1px solid #1a1a1a; }

        @media (max-width: 768px) {
            .pricing-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
