        let _logFilterTimeout = null;
        function applyLogFilters() {
            clearTimeout(_logFilterTimeout);
            _logFilterTimeout = setTimeout(fetchFilteredLogs, 300);
        }

        async function fetchFilteredLogs() {
            const search = document.getElementById('log-search')?.value || '';
            const event  = _logFilters.event;
            const status = _logFilters.status;
            const tbody  = document.getElementById('logs-tbody');
            const empty  = document.getElementById('logs-empty');

            const params = new URLSearchParams();
            if (event  !== 'all') params.set('event',  event);
            if (status !== 'all') params.set('status', status);
            if (search)           params.set('search', search);

            tbody.style.opacity = '0.4';
            try {
                const res  = await safeFetch(`/shardguard/api/guild/<%= guild.id %>/logs?${params}`);
                const data = await res.json();
                if (!data.success) return;

                tbody.innerHTML = data.logs.map(log => {
                    const s = (log.status || '').toLowerCase();
                    const ok = s.includes('success') || s.includes('réussi') || s.includes('join') || s.includes('arrivée');
                    const date = new Date(log.timestamp).toLocaleString('fr-FR', { day: '2-digit', month: '2-digit', hour: '2-digit', minute: '2-digit' });
                    return `<tr class="log-row border-b border-white/5 hover:bg-white/[0.02] transition-colors">
                        <td class="p-6 text-xs text-white/40 font-bold">${date}</td>
                        <td class="p-6">
                            <div class="font-bold text-sm">${log.username || ''}</div>
                            <div class="text-[10px] text-white/20 font-mono">${log.userId || ''}</div>
                        </td>
                        <td class="p-6 text-xs font-bold uppercase tracking-widest text-white/60">${log.event || ''}</td>
                        <td class="p-6 text-right">
                            <span class="status-pill ${ok ? 'status-success' : 'status-failed'}">${log.status || ''}</span>
                        </td>
                    </tr>`;
                }).join('');

                if (empty) empty.classList.toggle('hidden', data.logs.length > 0);
            } catch (e) { console.error(e); }
            tbody.style.opacity = '1';
        }

