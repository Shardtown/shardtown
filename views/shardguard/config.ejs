        function confirmQuickAdd() {
            const input = document.getElementById('quick-add-input');
            if (!input.value.trim()) return;
            
            const words = input.value.split(',').map(w => w.trim()).filter(w => w.length > 0);
            const container = document.getElementById('bannedwords_container');
            const currentWords = Array.from(container.querySelectorAll('input')).map(i => i.value.toLowerCase());
            
            let added = 0;
            for (const word of words) {
                if (!currentWords.includes(word.toLowerCase())) {
                    addBannedWord();
                    const inputs = container.querySelectorAll('input');
                    inputs[inputs.length - 1].value = word;
                    added++;
                }
            }
            if (added > 0) {
                showNotification("Succès", `${added} mot(s) ajouté(s) à la liste.`);
                checkChanges();
            }
            input.value = '';
            document.getElementById('quick-add-panel').classList.add('hidden');
        }

