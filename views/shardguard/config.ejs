<!DOCTYPE html>
<html lang="fr" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ShardGuard | Configuration</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        :root {
            --bg: #000000;
            --text: #ffffff;
            --accent: #ffffff;
            --muted: #888888;
            --border: #1a1a1a;
            --sidebar-width: 280px;
        }
        
        body { 
            font-family: 'Plus Jakarta Sans', sans-serif; 
            background: #000;
            background-image: 
                radial-gradient(at 50% 0%, rgba(37, 99, 235, 0.15) 0px, transparent 50%),
                radial-gradient(at 100% 100%, rgba(37, 99, 235, 0.05) 0px, transparent 50%);
            background-attachment: fixed;
            color: var(--text); 
            margin: 0;
            padding: 0;
            display: flex;
            height: 100vh;
            overflow: hidden;
        }

        .bg-glow {
            position: fixed;
            top: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 100%;
            height: 100vh;
            background: radial-gradient(circle at 50% -20%, rgba(37, 99, 235, 0.1) 0%, transparent 70%);
            pointer-events: none;
            z-index: -1;
        }

        /* Sidebar Custom */
        .sidebar {
            width: var(--sidebar-width);
            background: rgba(10, 10, 10, 0.5);
            backdrop-filter: blur(20px);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            padding: 32px 20px;
            z-index: 50;
        }

        .nav-item {
            padding: 12px 16px;
            border-radius: 12px;
            cursor: pointer;
            color: var(--muted);
            font-weight: 600;
            margin-bottom: 4px;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            gap: 12px;
            border: 1px solid transparent;
            font-size: 0.875rem;
        }

        .nav-item:hover {
            background: rgba(255,255,255,0.03);
            color: var(--text);
        }

        .nav-item.active {
            background: #fff;
            color: #000;
        }

        .nav-item svg {
            width: 18px;
            height: 18px;
        }

        /* Content Area */
        .main-content {
            flex: 1;
            padding: 40px 60px;
            overflow-y: auto;
            position: relative;
        }

        .content-section { display: none; width: 100%; }
        .content-section.active { display: block; animation: fadeIn 0.4s ease; }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .success-checkmark {
            display: flex;
            align-items: center;
            justify-content: center;
            animation: successScale 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
        }

        .success-checkmark svg {
            stroke-dasharray: 100;
            stroke-dashoffset: 100;
            animation: drawCheck 1.2s ease forwards 0.5s;
        }

        .success-checkmark circle {
            stroke-dasharray: 100;
            stroke-dashoffset: 100;
            animation: drawCircle 1s ease forwards;
        }

        @keyframes drawCircle { to { stroke-dashoffset: 0; } }
        @keyframes drawCheck { to { stroke-dashoffset: 0; } }
        @keyframes successScale { from { transform: scale(0.5); opacity: 0; } to { transform: scale(1); opacity: 1; } }

        .shard-card {
            background: #0a0a0a;
            border: 1px solid #1a1a1a;
            padding: 32px;
            border-radius: 24px;
            margin-bottom: 24px;
        }

        /* Forms */
        .field { margin-bottom: 24px; }
        label { 
            display: block; 
            margin-bottom: 8px; 
            font-weight: 700; 
            font-size: 0.7rem; 
            color: var(--muted); 
            text-transform: uppercase; 
            letter-spacing: 1.5px; 
        }

        textarea, input[type="text"], input[type="number"] { 
            width: 100%; 
            padding: 14px 18px; 
            background: rgba(255, 255, 255, 0.03); 
            border: 1px solid #1a1a1a; 
            color: white; 
            border-radius: 14px; 
            font-size: 0.9rem;
            outline: none;
            transition: all 0.2s;
        }

        textarea:focus, input[type="text"]:focus, input[type="number"]:focus { 
            border-color: #fff; 
            background: rgba(255, 255, 255, 0.05);
        }

        /* Custom Dropdown Styling */
        .custom-select-wrapper { position: relative; width: 100%; }
        .custom-select-trigger {
            width: 100%; 
            padding: 14px 18px; 
            background: rgba(255, 255, 255, 0.03); 
            border: 1px solid #1a1a1a; 
            color: white; 
            border-radius: 14px; 
            font-size: 0.9rem;
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            align-items: center;
            transition: all 0.2s;
        }
        .custom-select-trigger:after {
            content: "";
            width: 8px; height: 8px;
            border-right: 2px solid #555;
            border-bottom: 2px solid #555;
            transform: rotate(45deg);
            margin-bottom: 4px;
        }
        .custom-select-wrapper.open .custom-select-trigger { border-color: #fff; }
        .custom-options {
            position: absolute;
            top: calc(100% + 8px); left: 0; right: 0;
            background: #0f0f0f;
            border: 1px solid #1a1a1a;
            border-radius: 14px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            display: none;
            z-index: 1000;
            max-height: 250px;
            overflow-y: auto;
            backdrop-filter: blur(20px);
        }
        .custom-select-wrapper.open .custom-options { display: block; }
        .custom-option {
            padding: 10px 18px;
            cursor: pointer;
            transition: all 0.2s;
            font-size: 0.85rem;
            color: var(--muted);
        }
        .custom-option:hover { background: rgba(255,255,255,0.05); color: #fff; }
        .custom-option.selected { background: rgba(255,255,255,0.1); color: #fff; font-weight: 700; }
        .hidden-select { display: none; }

        /* Save Bar */
        .footer-bar {
            position: fixed;
            bottom: 32px;
            right: 40px;
            background: rgba(10, 10, 10, 0.8);
            backdrop-filter: blur(20px);
            padding: 12px 24px;
            border-radius: 100px;
            border: 1px solid #1a1a1a;
            display: flex;
            align-items: center;
            gap: 24px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.4);
            z-index: 100;
            opacity: 0;
            pointer-events: none;
            transform: translateY(20px);
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .footer-bar.visible { opacity: 1; pointer-events: all; transform: translateY(0); }

        .btn-white {
            background: #fff;
            color: #000;
            padding: 10px 24px;
            border-radius: 100px;
            font-weight: 700;
            font-size: 0.875rem;
            transition: opacity 0.2s;
            cursor: pointer;
            border: none;
        }
        .btn-white:hover { opacity: 0.9; }

        /* Scrollbar */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.1); border-radius: 10px; }
        
        .status-pill { 
            padding: 4px 10px; 
            border-radius: 8px; 
            font-size: 0.65rem; 
            font-weight: 800; 
            text-transform: uppercase;
            display: inline-flex;
            align-items: center;
            gap: 4px;
        }
        .status-success { background: rgba(34, 197, 94, 0.1); color: #4ade80; }
        .status-failed { background: rgba(239, 68, 68, 0.1); color: #f87171; }

        .rule-item {
            display: flex;
            align-items: center;
            gap: 12px;
            background: rgba(255, 255, 255, 0.02);
            padding: 6px 12px;
            border-radius: 12px;
            border: 1px solid #1a1a1a;
            margin-bottom: 8px;
        }
        .rule-input { background: transparent !important; border: none !important; padding: 10px 0 !important; }
    </style>
</head>
<body>
    <div class="bg-glow"></div>

    <aside class="sidebar">
        <div class="mb-8">
            <a href="/shardguard/server" class="flex items-center gap-2 text-white/40 hover:text-white transition-colors text-xs font-bold uppercase tracking-widest px-2">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"></path></svg>
                Retour aux serveurs
            </a>
        </div>

        <div class="mb-10">
            <div class="text-xs font-bold text-white/30 uppercase mb-3 tracking-widest px-2">Application</div>
            <div class="relative group" id="botSelector">
                <div class="flex items-center gap-3 p-2 bg-white/[0.03] border border-white/10 rounded-xl cursor-pointer hover:bg-white/[0.06] transition-all" onclick="toggleBotDropdown()">
                    <img src="/image/shardguard.png" class="w-6 h-6 rounded-md" alt="ShardGuard">
                    <div class="flex-1 min-w-0">
                        <div class="font-bold text-sm truncate">ShardGuard</div>
                    </div>
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-white/20"><path d="m6 9 6 6 6-6"></path></svg>
                </div>
                <!-- Dropdown -->
                <div id="botDropdown" class="absolute left-0 right-0 top-full mt-2 p-1 bg-[#0f0f0f]/90 backdrop-blur-xl border border-white/10 rounded-xl opacity-0 invisible transition-all z-50">
                    <div class="text-[9px] font-bold text-white/20 uppercase px-2 pt-2 pb-1 tracking-widest">Changer d'application</div>
                    <a href="/shardguard/guild/<%= guild.id %>" class="flex items-center gap-2 p-2 rounded-lg bg-white/[0.06] border border-white/10 mb-1 cursor-default">
                        <img src="/image/shardguard.png" class="w-5 h-5 rounded-md" alt="ShardGuard">
                        <span class="font-bold text-sm">ShardGuard</span>
                        <span class="ml-auto text-[9px] font-bold text-blue-400 uppercase tracking-widest">Actif</span>
                    </a>
                    <a href="/shard/guild/<%= guild.id %>" class="flex items-center gap-2 p-2 rounded-lg hover:bg-white/[0.04] transition-colors">
                        <img src="/image/shard.png" class="w-5 h-5 rounded-md" alt="Shard">
                        <span class="font-bold text-sm">Shard</span>
                    </a>
                </div>
            </div>
        </div>

        <script>
            function toggleBotDropdown() {
                const dropdown = document.getElementById('botDropdown');
                dropdown.classList.toggle('opacity-0');
                dropdown.classList.toggle('invisible');
            }
            // Fermer si clic ailleurs
            window.addEventListener('click', function(e) {
                if (!document.getElementById('botSelector').contains(e.target)) {
                    const dropdown = document.getElementById('botDropdown');
                    dropdown.classList.add('opacity-0');
                    dropdown.classList.add('invisible');
                }
            });
        </script>

        <nav class="flex-1">
            <div class="nav-item active" onclick="showSection('general', this)">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="9" y1="3" x2="9" y2="21"></line></svg>
                Général
            </div>
            <div class="nav-item" onclick="showSection('rules', this)">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line></svg>
                Règlement
            </div>
            <div class="nav-item" onclick="showSection('verification', this)">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
                Captcha
            </div>
            <div class="nav-item" onclick="showSection('security', this)">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><path d="M12 8v4"></path><path d="M12 16h.01"></path></svg>
                Sécurité
            </div>
            <div class="nav-item" onclick="showSection('stats', this)">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 20V10"></path><path d="M12 20V4"></path><path d="M6 20v-6"></path></svg>
                Statistiques
            </div>
            <div class="nav-item" onclick="showSection('logs', this)">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"></path><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path></svg>
                Historique
            </div>
            <div class="nav-item" onclick="showSection('audit', this)">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><path d="m9 12 2 2 4-4"></path></svg>
                Audit Panel
            </div>
        </nav>

        <div class="mt-auto p-4 bg-white/5 rounded-2xl border border-white/5">
            <div class="text-[10px] font-bold text-white/30 uppercase mb-3 tracking-widest">Serveur Actif</div>
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center overflow-hidden">
                    <% if (guild.icon) { %>
                        <img src="https://cdn.discordapp.com/icons/<%= guild.id %>/<%= guild.icon %>.png" class="w-full h-full object-cover">
                    <% } else { %>
                        <span class="font-bold text-white/20"><%= guild.name[0] %></span>
                    <% } %>
                </div>
                <div class="font-bold text-sm truncate"><%= guild.name %></div>
            </div>
        </div>
    </aside>

    <main class="main-content">
        <form action="/shardguard/guild/<%= guild.id %>/config" method="POST" id="configForm">
            <!-- Section Général -->
            <div id="section-general" class="content-section active">
                <div class="mb-12">
                    <p class="text-xs font-bold tracking-widest text-white/30 uppercase mb-2">Configuration</p>
                    <h1 class="text-3xl font-bold uppercase">Général</h1>
                </div>

                <div class="grid grid-cols-2 gap-6 mb-8">
                    <div class="shard-card">
                        <p class="text-[10px] font-bold text-white/30 uppercase mb-1 tracking-widest">Membres</p>
                        <p class="text-3xl font-bold"><%= stats.totalMembers %></p>
                    </div>
                    <div class="shard-card border-blue-500/30">
                        <p class="text-[10px] font-bold text-blue-500/50 uppercase mb-1 tracking-widest">Vérifiés</p>
                        <p class="text-3xl font-bold text-blue-500"><%= stats.verifiedMembers %></p>
                    </div>
                </div>

                <div class="shard-card">
                    <div class="field">
                        <label>Langue du Bot</label>
                        <div class="custom-select-wrapper">
                            <div class="custom-select-trigger" onclick="toggleDropdown(this)">
                                <span><%= settings.language === 'en' ? 'English (🇺🇸)' : 'Français (🇫🇷)' %></span>
                            </div>
                            <div class="custom-options">
                                <div class="custom-option <%= settings.language === 'fr' ? 'selected' : '' %>" data-value="fr" onclick="selectOption(this, 'language')">Français (🇫🇷)</div>
                                <div class="custom-option <%= settings.language === 'en' ? 'selected' : '' %>" data-value="en" onclick="selectOption(this, 'language')">English (🇺🇸)</div>
                            </div>
                            <select name="language" class="hidden-select">
                                <option value="fr" <%= settings.language === 'fr' ? 'selected' : '' %>>fr</option>
                                <option value="en" <%= settings.language === 'en' ? 'selected' : '' %>>en</option>
                            </select>
                        </div>
                    </div>
                    
                    <div class="field">
                        <label>Rôle de Vérification</label>
                        <div class="custom-select-wrapper">
                            <% const currentRole = roles.find(r => r.id === settings.verifiedRole); %>
                            <div class="custom-select-trigger" onclick="toggleDropdown(this)">
                                <span><%= currentRole ? currentRole.name : '-- Aucun rôle --' %></span>
                            </div>
                            <div class="custom-options">
                                <div class="custom-option <%= !settings.verifiedRole ? 'selected' : '' %>" data-value="" onclick="selectOption(this, 'verifiedRole')">-- Aucun rôle --</div>
                                <% roles.forEach(role => { %>
                                    <% if (role.name !== '@everyone') { %>
                                        <div class="custom-option <%= settings.verifiedRole === role.id ? 'selected' : '' %>" data-value="<%= role.id %>" onclick="selectOption(this, 'verifiedRole')">
                                            <%= role.name %>
                                        </div>
                                    <% } %>
                                <% }) %>
                            </div>
                            <select name="verifiedRole" class="hidden-select">
                                <option value="">none</option>
                                <% roles.forEach(role => { %>
                                    <option value="<%= role.id %>" <%= settings.verifiedRole === role.id ? 'selected' : '' %>><%= role.id %></option>
                                <% }) %>
                            </select>
                        </div>
                    </div>

                    <div class="field">
                        <label>Salon de Vérification</label>
                        <div class="flex gap-4">
                            <div class="custom-select-wrapper flex-1">
                                <% const currentChannel = channels.find(c => c.id === settings.verificationChannelId); %>
                                <div class="custom-select-trigger" onclick="toggleDropdown(this)">
                                    <span><%= currentChannel ? '# ' + currentChannel.name : '-- Sélectionner un salon --' %></span>
                                </div>
                                <div class="custom-options">
                                    <div class="custom-option <%= !settings.verificationChannelId ? 'selected' : '' %>" data-value="" onclick="selectOption(this, 'verificationChannelId')">-- Sélectionner un salon --</div>
                                    <% channels.forEach(channel => { %>
                                        <div class="custom-option <%= settings.verificationChannelId === channel.id ? 'selected' : '' %>" data-value="<%= channel.id %>" onclick="selectOption(this, 'verificationChannelId')">
                                            # <%= channel.name %>
                                        </div>
                                    <% }) %>
                                </div>
                                <select name="verificationChannelId" id="verificationChannelId" class="hidden-select">
                                    <option value="">none</option>
                                    <% channels.forEach(channel => { %>
                                        <option value="<%= channel.id %>" <%= settings.verificationChannelId === channel.id ? 'selected' : '' %>><%= channel.id %></option>
                                    <% }) %>
                                </select>
                            </div>
                            <button type="button" onclick="deploySpecific('verification', event)" class="btn-white px-8">Envoyer</button>
                        </div>
                    </div>

                    <div class="field">
                        <label>Verrouillage Serveur</label>
                        <div class="custom-select-wrapper">
                            <div class="custom-select-trigger" onclick="toggleDropdown(this)">
                                <span><%= settings.serverLocked === 'true' ? 'Verrouillé (Code requis)' : 'Ouvert à tous' %></span>
                            </div>
                            <div class="custom-options">
                                <div class="custom-option <%= settings.serverLocked === 'false' ? 'selected' : '' %>" data-value="false" onclick="selectOption(this, 'serverLocked')">Ouvert à tous</div>
                                <div class="custom-option <%= settings.serverLocked === 'true' ? 'selected' : '' %>" data-value="true" onclick="selectOption(this, 'serverLocked')">Verrouillé (Code requis)</div>
                            </div>
                            <select name="serverLocked" class="hidden-select">
                                <option value="false" <%= settings.serverLocked === 'false' ? 'selected' : '' %>>false</option>
                                <option value="true" <%= settings.serverLocked === 'true' ? 'selected' : '' %>>true</option>
                            </select>
                        </div>
                    </div>

                    <div class="field">
                        <label>Code d'Accès</label>
                        <input type="text" name="accessCode" value="<%= settings.accessCode || '' %>" placeholder="Ex: WELCOME-2024">
                    </div>
                </div>

            </div>

            <!-- Section Règlement -->
            <div id="section-rules" class="content-section">
                <div class="mb-12">
                    <p class="text-xs font-bold tracking-widest text-white/30 uppercase mb-2">Configuration</p>
                    <h1 class="text-3xl font-bold uppercase">Règlement</h1>
                </div>

                <div class="grid grid-cols-2 gap-8">
                    <div class="shard-card">
                        <div class="flex items-center justify-between mb-8">
                            <h3 class="font-bold uppercase text-xs tracking-widest">Version Française 🇫🇷</h3>
                            <button type="button" onclick="addRule('fr')" class="text-[10px] font-bold uppercase tracking-widest px-3 py-1 bg-white/5 rounded-full border border-white/10 hover:bg-white/10 transition-colors">Ajouter</button>
                        </div>
                        <div id="rules_fr_container" class="rules-list">
                            <% const rulesFr = settings.rules_fr ? (typeof settings.rules_fr === 'string' ? JSON.parse(settings.rules_fr) : settings.rules_fr) : []; %>
                            <% rulesFr.forEach(rule => { %>
                                <div class="rule-item">
                                    <div class="w-2 h-2 rounded-full bg-white/20 shrink-0"></div>
                                    <input type="text" name="rules_fr[]" class="rule-input" value="<%= rule %>">
                                    <button type="button" class="p-2 text-red-500/50 hover:text-red-500 transition-colors" onclick="this.parentElement.remove(); checkChanges();">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"></path><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"></path><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"></path></svg>
                                    </button>
                                </div>
                            <% }) %>
                        </div>
                    </div>

                    <div class="shard-card">
                        <div class="flex items-center justify-between mb-8">
                            <h3 class="font-bold uppercase text-xs tracking-widest">Version Anglaise 🇺🇸</h3>
                            <button type="button" onclick="addRule('en')" class="text-[10px] font-bold uppercase tracking-widest px-3 py-1 bg-white/5 rounded-full border border-white/10 hover:bg-white/10 transition-colors">Ajouter</button>
                        </div>
                        <div id="rules_en_container" class="rules-list">
                            <% const rulesEn = settings.rules_en ? (typeof settings.rules_en === 'string' ? JSON.parse(settings.rules_en) : settings.rules_en) : []; %>
                            <% rulesEn.forEach(rule => { %>
                                <div class="rule-item">
                                    <div class="w-2 h-2 rounded-full bg-white/20 shrink-0"></div>
                                    <input type="text" name="rules_en[]" class="rule-input" value="<%= rule %>">
                                    <button type="button" class="p-2 text-red-500/50 hover:text-red-500 transition-colors" onclick="this.parentElement.remove(); checkChanges();">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"></path><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"></path><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"></path></svg>
                                    </button>
                                </div>
                            <% }) %>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Section Vérification -->
            <div id="section-verification" class="content-section">
                <div class="mb-12">
                    <p class="text-xs font-bold tracking-widest text-white/30 uppercase mb-2">Configuration</p>
                    <h1 class="text-3xl font-bold uppercase">Système Captcha</h1>
                </div>

                <div class="shard-card">
                    <div class="grid grid-cols-2 gap-8">
                        <div class="field">
                            <label>Nombre de Chiffres</label>
                            <input type="number" name="captchaDigits" value="<%= settings.captchaDigits || 6 %>" min="4" max="8">
                        </div>
                        <div class="field">
                            <label>Niveau de Bruit</label>
                            <div class="custom-select-wrapper">
                                <div class="custom-select-trigger" onclick="toggleDropdown(this)">
                                    <span><%= settings.captchaNoise === 'high' ? 'Élevé' : (settings.captchaNoise === 'low' ? 'Faible' : 'Moyen') %></span>
                                </div>
                                <div class="custom-options">
                                    <div class="custom-option <%= settings.captchaNoise === 'low' ? 'selected' : '' %>" data-value="low" onclick="selectOption(this, 'captchaNoise')">Faible</div>
                                    <div class="custom-option <%= settings.captchaNoise === 'medium' ? 'selected' : '' %>" data-value="medium" onclick="selectOption(this, 'captchaNoise')">Moyen</div>
                                    <div class="custom-option <%= settings.captchaNoise === 'high' ? 'selected' : '' %>" data-value="high" onclick="selectOption(this, 'captchaNoise')">Élevé</div>
                                </div>
                                <select name="captchaNoise" class="hidden-select">
                                    <option value="low" <%= settings.captchaNoise === 'low' ? 'selected' : '' %>>low</option>
                                    <option value="medium" <%= settings.captchaNoise === 'medium' ? 'selected' : '' %>>medium</option>
                                    <option value="high" <%= settings.captchaNoise === 'high' ? 'selected' : '' %>>high</option>
                                </select>
                            </div>
                        </div>
                        <div class="field">
                            <label>Nombre d'Essais</label>
                            <input type="number" name="captchaAttempts" value="<%= settings.captchaAttempts || 3 %>" min="1" max="5">
                        </div>
                        <div class="field">
                            <label>Temps Limite (minutes)</label>
                            <input type="number" name="verificationTimeout" value="<%= settings.verificationTimeout || 15 %>" min="5" max="60">
                        </div>
                    </div>
                </div>

                <div class="shard-card mt-8">
                    <h3 class="font-bold text-xs uppercase tracking-wider mb-6 text-white/30">Actions Rapides</h3>
                    <div class="flex gap-4">
                        <button type="button" onclick="bulkAction('verify', this)" class="flex-1 p-4 bg-white/5 rounded-2xl text-sm font-bold uppercase border border-white/5 hover:bg-green-500/10 hover:border-green-500/20 hover:text-green-500 transition-all">
                            Vérifier tout le monde
                        </button>
                        <button type="button" onclick="bulkAction('kick', this)" class="flex-1 p-4 bg-white/5 rounded-2xl text-sm font-bold uppercase border border-white/5 hover:bg-red-500/10 hover:border-red-500/20 hover:text-red-500 transition-all">
                            Expulser les non-vérifiés
                        </button>
                    </div>
                </div>
            </div>

            <!-- Section Sécurité -->
            <div id="section-security" class="content-section">
                <div class="mb-12">
                    <p class="text-xs font-bold tracking-widest text-white/30 uppercase mb-2">Configuration</p>
                    <h1 class="text-3xl font-bold uppercase">Sécurité</h1>
                </div>

                <% if (!settings.isPremium) { %>
                <div class="shard-card mb-6" style="border-color: rgba(251,191,36,0.25); background: linear-gradient(180deg, rgba(251,191,36,0.04), transparent);">
                    <div class="flex items-center gap-4">
                        <div style="width:38px;height:38px;border-radius:10px;background:rgba(251,191,36,0.1);border:1px solid rgba(251,191,36,0.25);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="#fbbf24" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                        </div>
                        <div class="flex-1">
                            <p class="font-bold text-sm" style="color:#fbbf24;">Fonctionnalités Premium</p>
                            <p class="text-xs text-white/40 mt-1">L'anti-raid automatique et la quarantaine nécessitent Premium pour s'exécuter. Vous pouvez configurer les paramètres dès maintenant.</p>
                        </div>
                        <a href="/premium" class="px-4 py-2 rounded-full font-bold text-xs whitespace-nowrap" style="background:linear-gradient(135deg,#fbbf24,#f59e0b);color:#000;text-decoration:none;">Activer Premium</a>
                    </div>
                </div>
                <% } %>

                <!-- Anti-raid auto -->
                <div class="shard-card mb-6">
                    <div class="flex items-start justify-between gap-6 mb-6">
                        <div class="flex-1">
                            <p class="font-bold text-sm mb-1">Anti-raid automatique <span class="ml-2 inline-block text-[10px] font-bold px-2 py-0.5 rounded" style="background:rgba(251,191,36,0.12);color:#fbbf24;border:1px solid rgba(251,191,36,0.25);vertical-align:middle;">PREMIUM</span></p>
                            <p class="text-xs text-white/40 leading-relaxed">Détecte les vagues d'arrivées suspectes et passe automatiquement le serveur en niveau de vérification maximal.</p>
                        </div>
                        <div class="custom-select-wrapper flex-shrink-0" style="width:160px">
                            <div class="custom-select-trigger" onclick="toggleDropdown(this)">
                                <span><%= settings.antiRaidEnabled ? 'Activé' : 'Désactivé' %></span>
                            </div>
                            <div class="custom-options">
                                <div class="custom-option <%= !settings.antiRaidEnabled ? 'selected' : '' %>" data-value="0" onclick="selectOption(this,'antiRaidEnabled')">Désactivé</div>
                                <div class="custom-option <%= settings.antiRaidEnabled ? 'selected' : '' %>" data-value="1" onclick="selectOption(this,'antiRaidEnabled')">Activé</div>
                            </div>
                            <select name="antiRaidEnabled" class="hidden-select">
                                <option value="0" <%= !settings.antiRaidEnabled ? 'selected' : '' %>>0</option>
                                <option value="1" <%= settings.antiRaidEnabled ? 'selected' : '' %>>1</option>
                            </select>
                        </div>
                    </div>
                    <div class="grid grid-cols-2 gap-8">
                        <div class="field">
                            <label>Seuil (arrivées avant déclenchement)</label>
                            <input type="number" name="antiRaidThreshold" value="<%= settings.antiRaidThreshold || 10 %>" min="2" max="100">
                        </div>
                        <div class="field">
                            <label>Fenêtre temporelle (secondes)</label>
                            <input type="number" name="antiRaidWindow" value="<%= settings.antiRaidWindow || 10 %>" min="3" max="300">
                        </div>
                    </div>
                </div>

                <!-- Quarantaine auto -->
                <div class="shard-card mb-6">
                    <div class="flex items-start justify-between gap-6 mb-6">
                        <div class="flex-1">
                            <p class="font-bold text-sm mb-1">Quarantaine automatique <span class="ml-2 inline-block text-[10px] font-bold px-2 py-0.5 rounded" style="background:rgba(251,191,36,0.12);color:#fbbf24;border:1px solid rgba(251,191,36,0.25);vertical-align:middle;">PREMIUM</span></p>
                            <p class="text-xs text-white/40 leading-relaxed">Attribue automatiquement un rôle limité aux nouveaux membres pendant une durée fixée, en attendant validation.</p>
                        </div>
                        <div class="custom-select-wrapper flex-shrink-0" style="width:160px">
                            <div class="custom-select-trigger" onclick="toggleDropdown(this)">
                                <span><%= settings.quarantineEnabled ? 'Activé' : 'Désactivé' %></span>
                            </div>
                            <div class="custom-options">
                                <div class="custom-option <%= !settings.quarantineEnabled ? 'selected' : '' %>" data-value="0" onclick="selectOption(this,'quarantineEnabled')">Désactivé</div>
                                <div class="custom-option <%= settings.quarantineEnabled ? 'selected' : '' %>" data-value="1" onclick="selectOption(this,'quarantineEnabled')">Activé</div>
                            </div>
                            <select name="quarantineEnabled" class="hidden-select">
                                <option value="0" <%= !settings.quarantineEnabled ? 'selected' : '' %>>0</option>
                                <option value="1" <%= settings.quarantineEnabled ? 'selected' : '' %>>1</option>
                            </select>
                        </div>
                    </div>
                    <div class="grid grid-cols-2 gap-8">
                        <div class="field">
                            <label>Rôle de quarantaine</label>
                            <div class="custom-select-wrapper">
                                <% const qRole = roles.find(r => r.id === settings.quarantineRoleId); %>
                                <div class="custom-select-trigger" onclick="toggleDropdown(this)">
                                    <span><%= qRole ? qRole.name : '— Aucun rôle —' %></span>
                                </div>
                                <div class="custom-options">
                                    <div class="custom-option <%= !settings.quarantineRoleId ? 'selected' : '' %>" data-value="" onclick="selectOption(this, 'quarantineRoleId')">— Aucun rôle —</div>
                                    <% roles.forEach(role => { %>
                                        <% if (role.name !== '@everyone') { %>
                                            <div class="custom-option <%= settings.quarantineRoleId === role.id ? 'selected' : '' %>" data-value="<%= role.id %>" onclick="selectOption(this, 'quarantineRoleId')"><%= role.name %></div>
                                        <% } %>
                                    <% }) %>
                                </div>
                                <select name="quarantineRoleId" class="hidden-select">
                                    <option value="">none</option>
                                    <% roles.forEach(role => { %>
                                        <option value="<%= role.id %>" <%= settings.quarantineRoleId === role.id ? 'selected' : '' %>><%= role.id %></option>
                                    <% }) %>
                                </select>
                            </div>
                        </div>
                        <div class="field">
                            <label>Durée (minutes)</label>
                            <input type="number" name="quarantineDuration" value="<%= settings.quarantineDuration || 10 %>" min="1" max="1440">
                        </div>
                    </div>
                </div>

                <!-- Premium état -->
                <div class="shard-card">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="font-bold text-sm mb-1">Premium activé</p>
                            <p class="text-xs text-white/40">État du Premium ShardGuard sur ce serveur.</p>
                        </div>
                        <div class="custom-select-wrapper" style="width:160px">
                            <div class="custom-select-trigger" onclick="toggleDropdown(this)">
                                <span><%= settings.isPremium ? 'Activé' : 'Désactivé' %></span>
                            </div>
                            <div class="custom-options">
                                <div class="custom-option <%= !settings.isPremium ? 'selected' : '' %>" data-value="0" onclick="selectOption(this,'isPremiumSG')">Désactivé</div>
                                <div class="custom-option <%= settings.isPremium ? 'selected' : '' %>" data-value="1" onclick="selectOption(this,'isPremiumSG')">Activé</div>
                            </div>
                            <select name="isPremiumSG" class="hidden-select">
                                <option value="0" <%= !settings.isPremium ? 'selected' : '' %>>0</option>
                                <option value="1" <%= settings.isPremium ? 'selected' : '' %>>1</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Section Statistiques -->
            <div id="section-stats" class="content-section">
                <div class="mb-12">
                    <p class="text-xs font-bold tracking-widest text-white/30 uppercase mb-2">Données</p>
                    <h1 class="text-3xl font-bold uppercase">Analyses</h1>
                </div>

                <div class="grid grid-cols-2 gap-8">
                    <div class="shard-card">
                        <h3 class="font-bold text-xs uppercase tracking-widest mb-8">Flux des Membres (14j)</h3>
                        <div style="height:300px">
                            <canvas id="growthChart"></canvas>
                        </div>
                    </div>
                    <div class="shard-card">
                        <h3 class="font-bold text-xs uppercase tracking-widest mb-8">Performance Vérification</h3>
                        <div style="height:300px">
                            <canvas id="verificationChart"></canvas>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Section Historique -->
            <div id="section-logs" class="content-section">
                <div class="flex items-center justify-between mb-12">
                    <div>
                        <p class="text-xs font-bold tracking-widest text-white/30 uppercase mb-2">Activités</p>
                        <h1 class="text-3xl font-bold uppercase">Historique</h1>
                    </div>
                    <button type="button" onclick="syncLogs('logs', this)" class="btn-white text-[10px] uppercase tracking-widest px-6 flex items-center gap-2">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path><path d="M3 3v5h5"></path><path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"></path><path d="M16 16h5v5"></path></svg>
                        Rafraîchir
                    </button>
                </div>

                <div class="shard-card p-0 overflow-hidden">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-white/5 border-b border-white/5 text-[10px] font-bold uppercase tracking-widest text-white/40">
                                <th class="p-6">Date</th>
                                <th class="p-6">Utilisateur</th>
                                <th class="p-6">Action</th>
                                <th class="p-6 text-right">Statut</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% logs.forEach(log => { %>
                                <tr class="border-b border-white/5 hover:bg-white/[0.02] transition-colors">
                                    <td class="p-6 text-xs text-white/40 font-bold"><%= new Date(log.timestamp).toLocaleString('fr-FR', { day: '2-digit', month: '2-digit', hour: '2-digit', minute: '2-digit' }) %></td>
                                    <td class="p-6">
                                        <div class="font-bold text-sm"><%= log.username %></div>
                                        <div class="text-[10px] text-white/20 font-mono"><%= log.userId %></div>
                                    </td>
                                    <td class="p-6 text-xs font-bold uppercase tracking-widest text-white/60"><%= log.event %></td>
                                    <td class="p-6 text-right">
                                        <% 
                                            const status = log.status.toLowerCase();
                                            const isSuccess = status.includes('success') || status.includes('réussi') || status.includes('join') || status.includes('arrivée');
                                        %>
                                        <span class="status-pill <%= isSuccess ? 'status-success' : 'status-failed' %>">
                                            <%= log.status %>
                                        </span>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Section Audit -->
            <div id="section-audit" class="content-section">
                <div class="flex items-center justify-between mb-12">
                    <div>
                        <p class="text-xs font-bold tracking-widest text-white/30 uppercase mb-2">Sécurité</p>
                        <h1 class="text-3xl font-bold uppercase">Audit Panel</h1>
                    </div>
                    <button type="button" onclick="syncLogs('audit', this)" class="btn-white text-[10px] uppercase tracking-widest px-6 flex items-center gap-2">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path><path d="M3 3v5h5"></path><path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"></path><path d="M16 16h5v5"></path></svg>
                        Rafraîchir
                    </button>
                </div>

                <div id="section-audit-list" class="shard-card p-0 overflow-hidden divide-y divide-white/5">
                    <% auditLogs.forEach(log => { %>
                        <div class="p-6 hover:bg-white/[0.02] transition-colors cursor-pointer" onclick="showAuditDetails('<%= log.username %>', '<%= log.action %>', '<%= log.details.replace(/'/g, "\\'") %>', '<%= new Date(log.timestamp).toLocaleString('fr-FR') %>')">
                            <div class="flex items-center justify-between mb-2">
                                <div class="flex items-center gap-3">
                                    <div class="w-8 h-8 rounded-lg bg-blue-500/10 flex items-center justify-center text-blue-500">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><path d="m9 12 2 2 4-4"></path></svg>
                                    </div>
                                    <div>
                                        <div class="font-bold text-sm"><%= log.username %></div>
                                        <div class="text-[10px] text-white/40 font-bold uppercase tracking-widest"><%= log.action %></div>
                                    </div>
                                </div>
                                <div class="text-[10px] text-white/20 font-bold uppercase tracking-widest"><%= new Date(log.timestamp).toLocaleString('fr-FR') %></div>
                            </div>
                            <div class="text-xs text-white/30 truncate pl-11"><%= log.details %></div>
                        </div>
                    <% }) %>
                </div>
            </div>
        </form>
    </main>

    <div id="save-bar" class="footer-bar">
        <p class="text-xs font-bold uppercase tracking-widest text-white/50">Modifications non enregistrées</p>
        <button type="submit" form="configForm" class="btn-white">Enregistrer</button>
    </div>

    <!-- Notifications Container -->
    <div id="notification-container" class="fixed top-6 right-6 z-[3000] flex flex-col gap-4 w-80 items-end"></div>

    <!-- Modals -->
    <div id="alert-overlay" class="fixed inset-0 bg-black/60 backdrop-blur-xl z-[2000] hidden items-center justify-center p-6">
        <div class="bg-[#0a0a0a]/80 border border-white/10 rounded-[32px] p-10 max-w-sm w-full text-center shadow-[0_32px_64px_-12px_rgba(0,0,0,0.8)]">
            <h3 id="alert-title" class="text-xl font-bold uppercase mb-4 tracking-widest text-white">Alerte</h3>
            <p id="alert-msg" class="text-white/40 mb-10 text-base leading-relaxed font-medium"></p>
            <button onclick="hideAlert()" class="btn-white w-full py-4 text-xs uppercase tracking-[0.2em]">Compris</button>
        </div>
    </div>

    <div id="confirm-overlay" class="fixed inset-0 bg-black/60 backdrop-blur-xl z-[2000] hidden items-center justify-center p-6">
        <div class="bg-[#0a0a0a]/80 border border-white/10 rounded-[32px] p-10 max-w-sm w-full text-center shadow-[0_32px_64px_-12px_rgba(0,0,0,0.8)]">
            <h3 id="confirm-title" class="text-xl font-bold uppercase mb-4 tracking-widest text-white">Confirmation</h3>
            <p id="confirm-msg" class="text-white/40 mb-10 text-base leading-relaxed font-medium"></p>
            <div class="flex gap-4">
                <button onclick="hideConfirm()" class="flex-1 py-4 bg-white/5 rounded-2xl text-xs font-bold uppercase tracking-widest border border-white/5 hover:bg-white/10 transition-all text-white/60">Annuler</button>
                <button id="confirm-btn" class="flex-1 btn-white py-4 text-xs uppercase tracking-widest">Confirmer</button>
            </div>
        </div>
    </div>

    <script>
        const initialData = new FormData(document.getElementById('configForm'));
        const saveBar = document.getElementById('save-bar');
        
        function checkChanges() {
            const currentData = new FormData(document.getElementById('configForm'));
            let changed = false;
            
            // On compare les clés
            for (let [key, value] of currentData.entries()) {
                if (initialData.get(key) !== value) {
                    changed = true;
                    break;
                }
            }
            
            if (changed) saveBar.classList.add('visible');
            else saveBar.classList.remove('visible');
        }

        document.getElementById('configForm').addEventListener('input', checkChanges);

        function toggleDropdown(trigger) {
            trigger.parentElement.classList.toggle('open');
        }

        function selectOption(option, name) {
            const wrapper = option.closest('.custom-select-wrapper');
            const select = wrapper.querySelector('select');
            const trigger = wrapper.querySelector('.custom-select-trigger span');
            
            select.value = option.dataset.value;
            trigger.textContent = option.textContent;
            
            wrapper.querySelectorAll('.custom-option').forEach(opt => opt.classList.remove('selected'));
            option.classList.add('selected');
            wrapper.classList.remove('open');
            
            checkChanges();
        }

        window.addEventListener('click', (e) => {
            if (!e.target.closest('.custom-select-wrapper')) {
                document.querySelectorAll('.custom-select-wrapper').forEach(w => w.classList.remove('open'));
            }
        });

        function addRule(lang) {
            const container = document.getElementById(`rules_${lang}_container`);
            const div = document.createElement('div');
            div.className = 'rule-item';
            div.innerHTML = `
                <div class="w-2 h-2 rounded-full bg-white/20 shrink-0"></div>
                <input type="text" name="rules_${lang}[]" class="rule-input" value="" placeholder="Entrez une règle...">
                <button type="button" class="p-2 text-red-500/50 hover:text-red-500 transition-colors" onclick="this.parentElement.remove(); checkChanges();">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"></path><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"></path><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"></path></svg>
                </button>
            `;
            container.appendChild(div);
            checkChanges();
            div.querySelector('input').focus();
        }

        function showSection(sectionId, element) {
            document.querySelectorAll('.content-section').forEach(s => s.classList.remove('active'));
            document.querySelectorAll('.nav-item').forEach(i => i.classList.remove('active'));
            document.getElementById('section-' + sectionId).classList.add('active');
            element.classList.add('active');
        }

        function showAlert(title, msg) {
            document.getElementById('alert-title').textContent = title;
            document.getElementById('alert-msg').textContent = msg;
            document.getElementById('alert-overlay').classList.remove('hidden');
            document.getElementById('alert-overlay').classList.add('flex');
        }

        function hideAlert() {
            document.getElementById('alert-overlay').classList.add('hidden');
            document.getElementById('alert-overlay').classList.remove('flex');
        }

        let confirmCallback = null;
        function showConfirm(title, msg, callback) {
            document.getElementById('confirm-title').textContent = title;
            document.getElementById('confirm-msg').textContent = msg;
            confirmCallback = callback;
            document.getElementById('confirm-overlay').classList.remove('hidden');
            document.getElementById('confirm-overlay').classList.add('flex');
        }

        function hideConfirm() {
            document.getElementById('confirm-overlay').classList.add('hidden');
            document.getElementById('confirm-overlay').classList.remove('flex');
        }

        document.getElementById('confirm-btn').onclick = () => {
            if (confirmCallback) confirmCallback();
            hideConfirm();
        };

        async function deploySpecific(type, event) {
            if (event) event.preventDefault();
            showConfirm("Envoi", "Voulez-vous envoyer le message dans ce salon ?", () => {
                deployAction(type, event.currentTarget);
            });
        }

        async function deployAction(type, btn) {
            const originalText = btn.innerHTML;
            btn.innerHTML = "Envoi...";
            btn.disabled = true;

            const guildId = "<%= guild.id %>";
            const vChan = document.getElementById('verificationChannelId').value;

            try {
                const response = await fetch(`/shardguard/api/guild/${guildId}/deploy?type=${type}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ verificationChannelId: vChan })
                });
                const data = await response.json();
                if (data.success) {
                    btn.innerHTML = "Envoyé !";
                    setTimeout(() => { btn.innerHTML = originalText; btn.disabled = false; }, 3000);
                } else {
                    showAlert("Erreur", data.error || "Inconnue");
                    btn.innerHTML = originalText; btn.disabled = false;
                }
            } catch (err) {
                showAlert("Erreur", "Erreur réseau.");
                btn.innerHTML = originalText; btn.disabled = false;
            }
        }

        async function syncLogs(type, btn) {
            btn.classList.add('animate-spin');
            const guildId = "<%= guild.id %>";
            try {
                const response = await fetch(`/shardguard/api/guild/${guildId}/${type}`);
                const data = await response.json();
                if (data.success) {
                    // Refresh current section UI
                    window.location.reload(); 
                }
            } catch (err) { console.error(err); }
            setTimeout(() => btn.classList.remove('animate-spin'), 600);
        }

        async function bulkAction(action, btn) {
            const title = action === 'verify' ? "Vérification groupée" : "Expulsion groupée";
            const confirmMsg = action === 'verify' ? "Vérifier TOUS les membres ?" : "Expulser TOUS les non-vérifiés ?";
            
            showConfirm(title, confirmMsg, async () => {
                const originalContent = btn.innerHTML;
                const originalClasses = btn.className;
                
                // État Orange / Chargement
                btn.disabled = true;
                btn.style.width = btn.offsetWidth + 'px';
                btn.style.height = btn.offsetHeight + 'px';
                btn.className = originalClasses.replace('hover:bg-green-500/10', '').replace('hover:border-green-500/20', '').replace('hover:text-green-500', '').replace('hover:bg-red-500/10', '').replace('hover:border-red-500/20', '').replace('hover:text-red-500', '') + " bg-orange-500/10 border-orange-500/20 text-orange-500 flex items-center justify-center";
                btn.innerHTML = `
                    <svg class="animate-spin" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-6.219-8.56"></path></svg>
                `;

                const guildId = "<%= guild.id %>";
                try {
                    const response = await fetch(`/shardguard/api/guild/${guildId}/bulk/${action}`, { method: 'POST' });
                    const data = await response.json();
                    
                    if (data.success) {
                        // État Vert / Succès
                        btn.className = originalClasses.replace('hover:bg-green-500/10', '').replace('hover:border-green-500/20', '').replace('hover:text-green-500', '').replace('hover:bg-red-500/10', '').replace('hover:border-red-500/20', '').replace('hover:text-red-500', '') + " bg-green-500/10 border-green-500/20 text-green-500 flex items-center justify-center";
                        btn.innerHTML = `
                            <div class="success-checkmark">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                    <circle cx="12" cy="12" r="10"></circle>
                                    <polyline points="16 9 10.5 14.5 8 12"></polyline>
                                </svg>
                            </div>
                        `;
                        
                        showNotification(title, `${data.count} membres affectés avec succès.`);
                        
                        setTimeout(() => {
                            btn.className = originalClasses;
                            btn.innerHTML = originalContent;
                            btn.style.width = '';
                            btn.style.height = '';
                            btn.disabled = false;
                        }, 3000);
                    } else {
                        throw new Error(data.error || "Erreur inconnue");
                    }
                } catch (err) {
                    btn.className = originalClasses.replace('hover:bg-green-500/10', '').replace('hover:border-green-500/20', '').replace('hover:text-green-500', '').replace('hover:bg-red-500/10', '').replace('hover:border-red-500/20', '').replace('hover:text-red-500', '') + " bg-red-500/10 border-red-500/20 text-red-500 flex items-center justify-center";
                    btn.innerHTML = `
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
                    `;
                    showNotification("Erreur", err.message, "error");
                    setTimeout(() => {
                        btn.className = originalClasses;
                        btn.innerHTML = originalContent;
                        btn.style.width = '';
                        btn.style.height = '';
                        btn.disabled = false;
                    }, 3000);
                }
            });
        }

        function showNotification(title, msg, type = 'success') {
            const container = document.getElementById('notification-container');
            const toast = document.createElement('div');
            toast.className = "relative bg-[#0a0a0a]/90 backdrop-blur-xl border border-white/10 rounded-2xl p-5 shadow-2xl overflow-hidden translate-x-full transition-all duration-500 opacity-0";
            
            toast.innerHTML = `
                <div class="flex items-start gap-4">
                    <div class="w-10 h-10 rounded-xl ${type === 'success' ? 'bg-green-500/10 text-green-500' : 'bg-red-500/10 text-red-500'} flex items-center justify-center shrink-0">
                        ${type === 'success' ? 
                            '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>' :
                            '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>'
                        }
                    </div>
                    <div class="flex-1">
                        <div class="text-xs font-black uppercase tracking-widest text-white mb-1">${title}</div>
                        <div class="text-xs text-white/40 leading-relaxed font-medium">${msg}</div>
                    </div>
                </div>
                <!-- Progress Bar -->
                <div class="absolute bottom-0 left-0 h-[3px] bg-white/20 w-full">
                    <div class="h-full bg-white/40 transition-all duration-[10000ms] ease-linear w-full" id="progress-bar"></div>
                </div>
            `;
            
            container.appendChild(toast);
            
            // Trigger animation
            setTimeout(() => {
                toast.classList.remove('translate-x-full', 'opacity-0');
                toast.querySelector('#progress-bar').style.width = '0%';
            }, 100);
            
            // Auto remove
            setTimeout(() => {
                toast.classList.add('translate-x-full', 'opacity-0');
                setTimeout(() => toast.remove(), 500);
            }, 10000);
        }

        // Gestion de la sauvegarde AJAX
        document.getElementById('configForm').onsubmit = async function(e) {
            e.preventDefault();
            const btn = document.querySelector('#save-bar .btn-white');
            const originalContent = btn.innerHTML;
            const originalClasses = btn.className;
            const formData = new FormData(this);
            const data = Object.fromEntries(formData.entries());

            // Gérer les tableaux de règles
            data.rules_fr = Array.from(formData.getAll('rules_fr[]'));
            data.rules_en = Array.from(formData.getAll('rules_en[]'));

            // État Orange
            btn.disabled = true;
            btn.style.width = btn.offsetWidth + 'px';
            btn.style.height = btn.offsetHeight + 'px';
            btn.className = "rounded-full text-xs font-bold uppercase transition-all flex items-center justify-center bg-orange-500/10 border border-orange-500/20 text-orange-500";
            btn.innerHTML = `
                <svg class="animate-spin" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-6.219-8.56"></path></svg>
            `;

            try {
                const response = await fetch(this.action, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });

                if (response.ok || response.redirected) {
                    // État Vert
                    btn.className = "rounded-full text-xs font-bold uppercase transition-all flex items-center justify-center bg-green-500/10 border border-green-500/20 text-green-500";
                    btn.innerHTML = `
                        <div class="success-checkmark">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="12" cy="12" r="10"></circle>
                                <polyline points="16 9 10.5 14.5 8 12"></polyline>
                            </svg>
                        </div>
                    `;
                    
                    showNotification("Configuration", "Vos modifications ont été enregistrées.");
                    
                    // Mettre à jour les données initiales pour détecter de nouveaux changements
                    const updatedData = new FormData(this);
                    for (let [key, value] of updatedData.entries()) initialData.set(key, value);

                    // Attendre que l'animation soit vue avant de cacher la barre
                    setTimeout(() => {
                        saveBar.classList.remove('visible');
                        setTimeout(() => {
                            btn.className = originalClasses;
                            btn.innerHTML = originalContent;
                            btn.style.width = '';
                            btn.style.height = '';
                            btn.disabled = false;
                        }, 400); // Temps de la transition CSS de la barre
                    }, 2000);
                } else {
                    throw new Error("Erreur lors de la sauvegarde");
                }
            } catch (err) {
                btn.className = "rounded-full text-xs font-bold uppercase transition-all flex items-center justify-center bg-red-500/10 border border-red-500/20 text-red-500";
                btn.innerHTML = `
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
                `;
                showNotification("Erreur", err.message, "error");
                setTimeout(() => {
                    btn.className = originalClasses;
                    btn.innerHTML = originalContent;
                    btn.style.width = '';
                    btn.style.height = '';
                    btn.disabled = false;
                }, 3000);
            }
        };

        function showAuditDetails(user, action, details, date) {
            showAlert(`${user} - ${action}`, `${date}\n\n${details}`);
        }

        // Charts
        const chartData = JSON.parse(document.getElementById('chart-data').textContent);
        const labels = Object.keys(chartData);
        
        const growthCtx = document.getElementById('growthChart').getContext('2d');
        new Chart(growthCtx, {
            type: 'line',
            data: {
                labels: labels,
                datasets: [{
                    label: 'Arrivées',
                    data: labels.map(l => chartData[l].join),
                    borderColor: '#fff',
                    borderWidth: 2,
                    tension: 0.4,
                    pointRadius: 0,
                    fill: false
                }, {
                    label: 'Départs',
                    data: labels.map(l => chartData[l].leave),
                    borderColor: 'rgba(255,255,255,0.1)',
                    borderWidth: 1,
                    borderDash: [5, 5],
                    pointRadius: 0,
                    fill: false
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    y: { grid: { color: 'rgba(255,255,255,0.05)' }, ticks: { color: '#444' } },
                    x: { grid: { display: false }, ticks: { color: '#444' } }
                }
            }
        });

        const verifCtx = document.getElementById('verificationChart').getContext('2d');
        new Chart(verifCtx, {
            type: 'bar',
            data: {
                labels: labels,
                datasets: [{
                    label: 'Succès',
                    data: labels.map(l => chartData[l].success),
                    backgroundColor: '#fff',
                    borderRadius: 4
                }, {
                    label: 'Échecs',
                    data: labels.map(l => chartData[l].failed),
                    backgroundColor: 'rgba(255,255,255,0.1)',
                    borderRadius: 4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    y: { grid: { color: 'rgba(255,255,255,0.05)' }, ticks: { color: '#444' } },
                    x: { grid: { display: false }, ticks: { color: '#444' } }
                }
            }
        });
    </script>
    <script id="chart-data" type="application/json"><%- JSON.stringify(chartData) %></script>
</body>
</html>