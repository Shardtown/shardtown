        // ── Gestionnaire de membres ──────────────────────────────────────
        let _allMembers = [];
        let _memberFilter = 'all';
        let _memberSort = 'join_desc';
        let _membersLoaded = false;
        let _currentMember = null;

        async function loadMembers() {
            const loading = document.getElementById('members-loading');
            const table   = document.getElementById('members-table');
            const empty   = document.getElementById('members-empty');
            const count   = document.getElementById('members-count');
            const stats   = document.getElementById('members-stats');

            table.classList.add('hidden');
            empty.classList.add('hidden');
            count.classList.add('hidden');
            loading.classList.remove('hidden');

            try {
                const res  = await safeFetch(`/shardguard/api/guild/<%= guild.id %>/members`);
                const data = await res.json();
                if (!data.success) throw new Error();
                _allMembers  = data.members;
                _membersLoaded = true;

                const warned = _allMembers.filter(m => m.warns > 0).length;
                stats.innerHTML = `
                    <div class="shard-card text-center py-4">
                        <div class="text-2xl font-bold">${_allMembers.length}</div>
                        <div class="text-[10px] text-white/25 uppercase tracking-widest mt-1">Membres</div>
                    </div>
                    <div class="shard-card text-center py-4">
                        <div class="text-2xl font-bold text-orange-400">${warned}</div>
                        <div class="text-[10px] text-white/25 uppercase tracking-widest mt-1">Avertis</div>
                    </div>
                    <div class="shard-card text-center py-4">
                        <div class="text-2xl font-bold text-green-400">${_allMembers.length - warned}</div>
                        <div class="text-[10px] text-white/25 uppercase tracking-widest mt-1">Sans sanction</div>
                    </div>`;
                stats.style.removeProperty('display');
                renderMembers();
            } catch(e) {
                loading.innerHTML = `<p class="text-xs text-red-400 text-center py-10">Erreur lors du chargement.</p>`;
            }
        }

        function _sortMembers(arr) {
            return [...arr].sort((a,b) => {
                if (_memberSort === 'join_desc')  return new Date(b.joinedAt) - new Date(a.joinedAt);
                if (_memberSort === 'join_asc')   return new Date(a.joinedAt) - new Date(b.joinedAt);
                if (_memberSort === 'name_asc')   return a.displayName.localeCompare(b.displayName);
                if (_memberSort === 'warns_desc') return b.warns - a.warns;
                return 0;
            });
        }

        function filterMembers() { if (_membersLoaded) renderMembers(); }

        function selectMemberFilter(opt) {
            const w = opt.closest('.custom-select-wrapper');
            w.querySelector('.custom-select-trigger span').textContent = opt.textContent;
            w.querySelectorAll('.custom-option').forEach(o => o.classList.remove('selected'));
            opt.classList.add('selected'); w.classList.remove('open');
            _memberFilter = opt.dataset.value; renderMembers();
        }
        function selectMemberSort(opt) {
            const w = opt.closest('.custom-select-wrapper');
            w.querySelector('.custom-select-trigger span').textContent = opt.textContent;
            w.querySelectorAll('.custom-option').forEach(o => o.classList.remove('selected'));
            opt.classList.add('selected'); w.classList.remove('open');
            _memberSort = opt.dataset.value; renderMembers();
        }

        function renderMembers() {
            const loading = document.getElementById('members-loading');
            const table   = document.getElementById('members-table');
            const tbody   = document.getElementById('members-tbody');
            const empty   = document.getElementById('members-empty');
            const count   = document.getElementById('members-count');
            const search  = (document.getElementById('member-search')?.value || '').toLowerCase();

            loading.classList.add('hidden');

            let filtered = _allMembers.filter(m => {
                if (_memberFilter === 'warned' && m.warns === 0) return false;
                if (_memberFilter === 'nowarn' && m.warns > 0)   return false;
                if (search && !`${m.displayName} ${m.username} ${m.id}`.toLowerCase().includes(search)) return false;
                return true;
            });
            filtered = _sortMembers(filtered);

            if (filtered.length === 0) {
                table.classList.add('hidden'); empty.classList.remove('hidden'); count.classList.add('hidden'); return;
            }

            tbody.innerHTML = filtered.map((m, i) => {
                const joinDate = new Date(m.joinedAt).toLocaleDateString('fr-FR', { day:'2-digit', month:'2-digit', year:'numeric' });
                const topRole  = m.roles.find(r => r.color && r.color !== 0);
                const roleHex  = topRole ? '#'+topRole.color.toString(16).padStart(6,'0') : null;
                const rolePill = topRole
                    ? `<span class="text-[9px] font-bold px-2.5 py-1 rounded-full" style="background:${roleHex}18;color:${roleHex}cc">${topRole.name}</span>`
                    : '';
                const extraRoles = m.roles.filter(r => r.color && r.color !== 0).length - 1;
                const extraBadge = extraRoles > 0 ? `<span class="text-[9px] text-white/20 font-bold">+${extraRoles}</span>` : '';
                const warnBadge = m.warns > 0
                    ? `<span class="text-[9px] font-black px-2 py-0.5 rounded-full" style="background:rgba(249,115,22,0.1);color:rgba(249,115,22,0.85)">${m.warns} warn${m.warns > 1 ? 's' : ''}</span>`
                    : '';
                const border = i > 0 ? 'border-t border-white/[0.04]' : '';
                const mData  = encodeURIComponent(JSON.stringify(m));
                return `<div class="group flex items-center gap-5 px-6 py-4 cursor-pointer transition-colors hover:bg-white/[0.03] ${border}" onclick="openMemberModal(decodeURIComponent('${mData}'))">
                    <img src="${m.avatar}" class="w-10 h-10 rounded-2xl object-cover shrink-0" onerror="this.src='https://cdn.discordapp.com/embed/avatars/0.png'">
                    <div class="flex-1 min-w-0">
                        <div class="flex items-center gap-2.5 mb-0.5">
                            <span class="font-bold text-sm leading-tight">${m.displayName}</span>
                            ${warnBadge}
                        </div>
                        <span class="text-[10px] text-white/25 font-mono">${m.username}</span>
                    </div>
                    <div class="flex items-center gap-2 shrink-0">
                        ${rolePill}${extraBadge}
                    </div>
                    <div class="text-[10px] text-white/20 font-bold shrink-0">${joinDate}</div>
                    <svg class="text-white/10 group-hover:text-white/30 transition-colors shrink-0" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m9 18 6-6-6-6"></path></svg>
                </div>`;
            }).join('');

            table.classList.remove('hidden');
            empty.classList.add('hidden');
            count.textContent = `${filtered.length} membre${filtered.length > 1 ? 's' : ''}`;
            count.classList.remove('hidden');
        }

        function formatMuteRemaining(timedOutUntil) {
            if (!timedOutUntil) return null;
            const diff = new Date(timedOutUntil) - Date.now();
            if (diff <= 0) return null;
            const totalMin = Math.floor(diff / 60000);
            if (totalMin < 60) return `${totalMin}min`;
            const h = Math.floor(totalMin / 60), mn = totalMin % 60;
            if (h < 24) return mn > 0 ? `${h}h${mn}min` : `${h}h`;
            const d = Math.floor(h / 24), rh = h % 24;
            return rh > 0 ? `${d}j${rh}h` : `${d}j`;
        }

        function openMemberModal(raw) {
            const m = typeof raw === 'string' ? JSON.parse(raw) : raw;
            _currentMember = m;

            const joinDate   = new Date(m.joinedAt).toLocaleDateString('fr-FR', { day:'2-digit', month:'2-digit', year:'numeric', hour:'2-digit', minute:'2-digit' });
            const createDate = new Date(m.createdAt).toLocaleDateString('fr-FR', { day:'2-digit', month:'2-digit', year:'numeric' });

            const isMuted = m.timedOutUntil && new Date(m.timedOutUntil) > new Date();
            const muteRemaining = isMuted ? formatMuteRemaining(m.timedOutUntil) : null;

            document.getElementById('mm-header').innerHTML = `
                <div class="relative px-8 pt-8 pb-6" style="border-bottom:1px solid rgba(255,255,255,0.06)">
                    <div class="relative flex items-start gap-6 pr-12">
                        <div class="relative shrink-0">
                            <img src="${m.avatar}" class="w-[72px] h-[72px] rounded-2xl object-cover" style="box-shadow:0 8px 24px rgba(0,0,0,0.5)" onerror="this.src='https://cdn.discordapp.com/embed/avatars/0.png'">
                            ${isMuted ? `<div class="absolute -bottom-1.5 -right-1.5 w-5 h-5 rounded-full flex items-center justify-center" style="background:rgba(234,179,8,0.9);box-shadow:0 0 8px rgba(234,179,8,0.5)"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><line x1="1" y1="1" x2="23" y2="23"></line><path d="M9 9v3a3 3 0 0 0 5.12 2.12"></path></svg></div>` : ''}
                        </div>
                        <div class="flex-1 min-w-0 pt-1">
                            <div class="flex items-center gap-3 flex-wrap">
                                <span class="text-xl font-bold leading-tight">${m.displayName}</span>
                                ${m.warns > 0 ? `<span class="text-[9px] font-black uppercase tracking-widest px-2.5 py-1 rounded-full" style="background:rgba(249,115,22,0.15);color:rgba(249,115,22,1)">${m.warns} warn${m.warns > 1 ? 's' : ''}</span>` : ''}
                                ${isMuted ? `<span class="text-[9px] font-black uppercase tracking-widest px-2.5 py-1 rounded-full" style="background:rgba(234,179,8,0.12);color:rgba(234,179,8,0.9)">Muté${muteRemaining ? ' · ' + muteRemaining : ''}</span>` : ''}
                            </div>
                            <div class="text-sm font-medium mt-1" style="color:rgba(255,255,255,0.35);font-family:monospace">${m.username}</div>
                            <button type="button" onclick="navigator.clipboard.writeText('${m.id}');this.textContent='✓ Copié'" class="mt-2 inline-flex items-center gap-1.5 transition-colors font-mono" style="font-size:10px;font-weight:600;color:rgba(255,255,255,0.15)" onmouseover="this.style.color='rgba(255,255,255,0.45)'" onmouseout="this.style.color='rgba(255,255,255,0.15)'">
                                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="9" y="9" width="13" height="13" rx="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
                                ${m.id}
                            </button>
                        </div>
                    </div>
                </div>`;

            const rolesHtml = m.roles.length > 0
                ? m.roles.map(r => {
                    const hex = r.color && r.color !== 0 ? '#'+r.color.toString(16).padStart(6,'0') : null;
                    return hex
                        ? `<span class="inline-flex items-center gap-1.5 text-[10px] font-bold px-2.5 py-1 rounded-full" style="border:1px solid ${hex}30;color:${hex};background:${hex}12"><span class="w-1.5 h-1.5 rounded-full shrink-0" style="background:${hex}"></span>${r.name}</span>`
                        : `<span class="inline-flex items-center gap-1.5 text-[10px] font-bold px-2.5 py-1 rounded-full" style="border:1px solid rgba(255,255,255,0.08);color:rgba(255,255,255,0.4)"><span class="w-1.5 h-1.5 rounded-full shrink-0" style="background:rgba(255,255,255,0.3)"></span>${r.name}</span>`;
                }).join('')
                : '<span class="text-[10px]" style="color:rgba(255,255,255,0.2)">Aucun rôle</span>';

            const actionBtn = (action, icon, label, hoverColor, hoverBg, id = '', sublabel = '') =>
                `<button type="button" ${id ? `id="${id}"` : ''} onclick="showActionPrompt('${action}')"
                    class="mm-action-btn w-full flex items-center gap-3 px-4 py-3.5 rounded-2xl transition-all text-left"
                    style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.05)"
                    onmouseover="this.style.background='${hoverBg}';this.style.borderColor='${hoverColor}30';this.style.color='${hoverColor}'"
                    onmouseout="this.style.background='rgba(255,255,255,0.03)';this.style.borderColor='rgba(255,255,255,0.05)';this.style.color=''">
                    <span class="shrink-0 w-8 h-8 rounded-xl flex items-center justify-center" style="background:rgba(255,255,255,0.04)">${icon}</span>
                    <span class="flex-1 min-w-0">
                        <span class="mm-btn-label block text-[11px] font-bold uppercase tracking-widest leading-none">${label}</span>
                        ${sublabel ? `<span class="mm-btn-sub block mt-1" style="font-size:9px;color:rgba(255,255,255,0.35);font-weight:500">${sublabel}</span>` : `<span class="mm-btn-sub block mt-1" style="font-size:9px;display:none"></span>`}
                    </span>
                    <svg class="shrink-0 opacity-20" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m9 18 6-6-6-6"></path></svg>
                </button>`;

            const muteLabel  = isMuted ? 'Unmute' : 'Mute';
            const muteAction = isMuted ? 'unmute' : 'mute';

            const svgWarn   = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>`;
            const svgMute   = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="1" y1="1" x2="23" y2="23"></line><path d="M9 9v3a3 3 0 0 0 5.12 2.12M15 9.34V4a3 3 0 0 0-5.94-.6"></path><path d="M17 16.95A7 7 0 0 1 5 12v-2m14 0v2a7 7 0 0 1-.11 1.23"></path><line x1="12" y1="19" x2="12" y2="23"></line><line x1="8" y1="23" x2="16" y2="23"></line></svg>`;
            const svgKick   = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>`;
            const svgBan    = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"></circle><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"></line></svg>`;

            document.getElementById('member-modal-content').innerHTML = `
                <div class="flex gap-6" style="min-height:0">
                    <!-- Colonne gauche : infos + sanctions -->
                    <div class="flex flex-col gap-5 min-w-0" style="flex:1 1 0">

                        <!-- Dates + roles -->
                        <div class="rounded-2xl overflow-hidden" style="background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.05)">
                            <div class="flex">
                                <div class="flex-1 px-5 py-4">
                                    <div class="text-[9px] font-bold uppercase tracking-widest mb-1.5" style="color:rgba(255,255,255,0.25)">Arrivée</div>
                                    <div class="text-sm font-bold">${joinDate}</div>
                                </div>
                                <div class="flex-1 px-5 py-4" style="border-left:1px solid rgba(255,255,255,0.05)">
                                    <div class="text-[9px] font-bold uppercase tracking-widest mb-1.5" style="color:rgba(255,255,255,0.25)">Compte créé</div>
                                    <div class="text-sm font-bold">${createDate}</div>
                                </div>
                            </div>
                            <div class="px-5 py-4" style="border-top:1px solid rgba(255,255,255,0.05)">
                                <div class="text-[9px] font-bold uppercase tracking-widest mb-2.5" style="color:rgba(255,255,255,0.25)">Rôles · ${m.roles.length}</div>
                                <div class="flex flex-wrap gap-1.5">${rolesHtml}</div>
                            </div>
                        </div>

                        <!-- Sanctions -->
                        <div class="flex-1 flex flex-col min-h-0">
                            <div class="flex items-center justify-between mb-3">
                                <span class="text-[9px] font-bold uppercase tracking-widest" style="color:rgba(255,255,255,0.25)">Sanctions</span>
                                <button type="button" id="mm-unwarn-btn" onclick="clearAllSanctions()" class="text-[9px] font-bold uppercase tracking-widest transition-colors" style="color:rgba(255,255,255,0.2)" onmouseover="this.style.color='rgba(255,255,255,0.6)'" onmouseout="this.style.color='rgba(255,255,255,0.2)'">Tout effacer</button>
                            </div>
                            <div id="mm-sanctions-list" class="flex flex-col gap-1.5 overflow-y-auto" style="max-height:280px">
                                <div class="text-[10px] text-center py-6 animate-pulse" style="color:rgba(255,255,255,0.15)">Chargement...</div>
                            </div>
                        </div>
                    </div>

                    <!-- Colonne droite : actions -->
                    <div class="flex flex-col gap-2 shrink-0" style="width:220px">
                        <div class="text-[9px] font-bold uppercase tracking-widest mb-1" style="color:rgba(255,255,255,0.25)">Actions</div>
                        ${actionBtn('warn',  svgWarn, 'Warn',   'rgba(249,115,22,1)', 'rgba(249,115,22,0.08)')}
                        ${actionBtn(muteAction, svgMute, muteLabel, 'rgba(234,179,8,1)', 'rgba(234,179,8,0.08)', 'btn-mute', muteRemaining || '')}
                        ${actionBtn('kick',  svgKick, 'Kick',   'rgba(239,68,68,1)',  'rgba(239,68,68,0.08)')}
                        ${actionBtn('ban',   svgBan,  'Ban',    'rgba(239,68,68,1)',  'rgba(185,28,28,0.1)')}
                    </div>
                </div>`;

            document.getElementById('member-modal').classList.remove('hidden');
            document.getElementById('member-modal').classList.add('flex');
            loadMemberSanctions(m.id);
        }

        function parseDetails(details, action) {
            if (!details) return { reason: '', mod: '' };
            const parMatch = details.match(/\|\s*Par:\s*(.+)$/);
            const mod = parMatch ? parMatch[1].replace(' (dashboard)', '').trim() : '';
            let reason = details.replace(/\s*\|\s*Par:.*$/, '').trim();
            if (action === 'warn' && reason.startsWith('Raison: ')) reason = reason.slice(8);
            if (action === 'mute' || action === 'Mute') {
                const dashIdx = reason.indexOf(' — ');
                if (dashIdx >= 0) reason = reason.slice(dashIdx + 3);
            }
            return { reason: reason || '', mod };
        }

        const _sanctionMeta = {
            warn:    { label:'Warn',    color:'rgba(249,115,22,1)',  bg:'rgba(249,115,22,0.1)'  },
            mute:    { label:'Mute',    color:'rgba(234,179,8,1)',   bg:'rgba(234,179,8,0.1)'   },
            unmute:  { label:'Unmute',  color:'rgba(34,197,94,1)',   bg:'rgba(34,197,94,0.1)'   },
            kick:    { label:'Kick',    color:'rgba(239,68,68,1)',   bg:'rgba(239,68,68,0.1)'   },
            ban:     { label:'Ban',     color:'rgba(248,113,113,1)', bg:'rgba(185,28,28,0.12)'  },
            unban:   { label:'Unban',   color:'rgba(34,197,94,1)',   bg:'rgba(34,197,94,0.1)'   },
            timeout: { label:'Timeout', color:'rgba(234,179,8,1)',   bg:'rgba(234,179,8,0.1)'   },
            automod: { label:'Automod', color:'rgba(148,163,184,1)', bg:'rgba(148,163,184,0.1)' },
        };

        async function loadMemberSanctions(userId) {
            const list = document.getElementById('mm-sanctions-list');
            try {
                const [sanctRes, warnRes] = await Promise.all([
                    safeFetch(`/shardguard/api/guild/<%= guild.id %>/member/${userId}/sanctions`),
                    safeFetch(`/shardguard/api/guild/<%= guild.id %>/member/${userId}/warns`)
                ]);
                const sanctData = await sanctRes.json();
                const warnData  = await warnRes.json();

                const sanctions = sanctData.success ? (sanctData.sanctions || []) : [];
                const warns     = warnData.success  ? (warnData.warns || [])     : [];

                const warnItems = warns.map(w => ({
                    _type: 'warn',
                    id: w.id,
                    action: 'warn',
                    reason: w.reason,
                    moderatorName: w.moderatorName,
                    timestamp: w.timestamp,
                    _warnId: w.id
                }));

                const sanctItems = sanctions.map(s => {
                    const rawAction = (s.action || s.type || 'unknown').toLowerCase();
                    const parsed = parseDetails(s.details, rawAction);
                    return {
                        _type: 'sanction',
                        _sanctionId: s.id,
                        action: rawAction,
                        reason: parsed.reason || s.reason || '',
                        moderatorName: parsed.mod || null,
                        timestamp: s.timestamp,
                    };
                });

                const all = [...warnItems, ...sanctItems].sort((a, b) => new Date(b.timestamp) - new Date(a.timestamp));

                if (all.length === 0) {
                    list.innerHTML = `<p class="text-[10px] text-white/15 text-center py-3">Aucune sanction.</p>`;
                    return;
                }

                list.innerHTML = all.map(s => {
                    const meta = _sanctionMeta[s.action] || { label: s.action, color:'rgba(255,255,255,0.35)', bg:'rgba(255,255,255,0.04)' };
                    const d = new Date(s.timestamp).toLocaleDateString('fr-FR', { day:'2-digit', month:'2-digit', year:'numeric', hour:'2-digit', minute:'2-digit' });
                    const modStr = s.moderatorName ? `${s.moderatorName} · ` : '';
                    const trashFn = s._type === 'warn'
                        ? `deleteWarn(${s._warnId})`
                        : `deleteSanction(${s._sanctionId})`;
                    const trashBtn = `<button type="button" onclick="${trashFn}" class="sanction-trash shrink-0 transition-colors" style="color:transparent" title="Supprimer">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 6h18"></path><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"></path><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"></path></svg>
                           </button>`;
                    return `<div class="sanction-row flex items-center gap-2.5 px-3 py-2.5 rounded-xl transition-colors" style="background:rgba(255,255,255,0.025)">
                        <span class="shrink-0 text-[8px] font-black uppercase px-2 py-0.5 rounded-lg tracking-widest" style="background:${meta.bg};color:${meta.color};min-width:44px;text-align:center">${meta.label}</span>
                        <div class="flex-1 min-w-0">
                            <div class="text-xs font-semibold truncate" style="color:rgba(255,255,255,0.85)">${s.reason || 'Aucune raison'}</div>
                            <div class="text-[10px] truncate" style="color:rgba(255,255,255,0.25)">${modStr}${d}</div>
                        </div>
                        ${trashBtn}
                    </div>`;
                }).join('');
            } catch(e) { list.innerHTML = `<p class="text-[10px] text-red-400 text-center py-3">Erreur.</p>`; }
        }

        let _pendingAction = null;

        function showActionPrompt(action) {
            if (!_currentMember) return;
            _pendingAction = action;
            const m = _currentMember;
            const titles = { warn:'Avertir', mute:'Muter', unmute:'Unmute', kick:'Expulser', ban:'Bannir', unwarn:'Effacer tous les warns' };
            document.getElementById('ap-title').textContent = titles[action] || action;
            document.getElementById('ap-subtitle').textContent = m.displayName;
            document.getElementById('ap-reason').value = '';
            const durWrap = document.getElementById('ap-duration-wrap');
            if (action === 'mute') {
                durWrap.classList.remove('hidden');
                document.getElementById('ap-duration').value = 60;
            } else {
                durWrap.classList.add('hidden');
            }
            document.getElementById('ap-confirm-btn').onclick = executeMemberAction;
            const overlay = document.getElementById('action-prompt-overlay');
            overlay.classList.remove('hidden');
            overlay.classList.add('flex');
            setTimeout(() => document.getElementById('ap-reason').focus(), 50);
        }

        function hideActionPrompt() {
            const overlay = document.getElementById('action-prompt-overlay');
            overlay.classList.add('hidden');
            overlay.classList.remove('flex');
            _pendingAction = null;
        }

        function refreshMuteButton() {
            const btn = document.getElementById('btn-mute');
            if (!btn || !_currentMember) return;
            const isMuted = _currentMember.timedOutUntil && new Date(_currentMember.timedOutUntil) > new Date();
            const remaining = isMuted ? formatMuteRemaining(_currentMember.timedOutUntil) : null;
            const action = isMuted ? 'unmute' : 'mute';
            btn.setAttribute('onclick', `showActionPrompt('${action}')`);
            const labelEl = btn.querySelector('.mm-btn-label');
            if (labelEl) labelEl.textContent = isMuted ? 'Unmute' : 'Mute';
            const subEl = btn.querySelector('.mm-btn-sub');
            if (subEl) {
                subEl.textContent = remaining || '';
                subEl.style.display = remaining ? '' : 'none';
            }
            const img = document.getElementById('mm-header')?.querySelector('img');
            if (img) {
                const indicator = img.parentElement.querySelector('[data-mute-indicator]');
                if (isMuted && !indicator) {
                    const div = document.createElement('div');
                    div.setAttribute('data-mute-indicator', '1');
                    div.className = 'absolute -bottom-1.5 -right-1.5 w-5 h-5 rounded-full flex items-center justify-center';
                    div.style.cssText = 'background:rgba(234,179,8,0.9);box-shadow:0 0 8px rgba(234,179,8,0.5)';
                    div.innerHTML = `<svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><line x1="1" y1="1" x2="23" y2="23"></line><path d="M9 9v3a3 3 0 0 0 5.12 2.12"></path></svg>`;
                    img.parentElement.appendChild(div);
                } else if (!isMuted && indicator) {
                    indicator.remove();
                }
            }
        }

        async function executeMemberAction() {
            if (!_currentMember || !_pendingAction) return;
            const action   = _pendingAction;
            const m        = _currentMember;
            const reason   = document.getElementById('ap-reason').value || '';
            const duration = document.getElementById('ap-duration')?.value || 60;
            hideActionPrompt();
            try {
                const res  = await safeFetch(`/shardguard/api/guild/<%= guild.id %>/member/${m.id}/action`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ action, reason, duration, username: m.username })
                });
                const data = await res.json();
                if (!data.success) { showAlert('Erreur', data.error || 'Inconnue'); return; }

                const notifLabels = { warn:'Avertissement', mute:'Mute', unmute:'Unmute', kick:'Expulsion', ban:'Ban', unwarn:'Warns effacés' };
                showNotification(notifLabels[action] || action, `${m.displayName} · action effectuée.`);

                if (action === 'warn') {
                    const nc = data.warnCount;
                    _currentMember.warns = nc;
                    const unBtn = document.getElementById('mm-unwarn-btn');
                    if (unBtn) unBtn.classList.toggle('invisible', nc === 0);
                    loadMemberSanctions(m.id);
                    const idx = _allMembers.findIndex(x => x.id === m.id);
                    if (idx !== -1) _allMembers[idx].warns = nc;
                    renderMembers();
                } else if (action === 'unwarn') {
                    _currentMember.warns = 0;
                    const unBtn = document.getElementById('mm-unwarn-btn');
                    if (unBtn) unBtn.classList.add('invisible');
                    loadMemberSanctions(m.id);
                    const idx = _allMembers.findIndex(x => x.id === m.id);
                    if (idx !== -1) _allMembers[idx].warns = 0;
                    renderMembers();
                } else if (action === 'kick' || action === 'ban') {
                    closeMemberModal();
                    _allMembers = _allMembers.filter(x => x.id !== m.id);
                    renderMembers();
                } else if (action === 'mute') {
                    const until = new Date(Date.now() + duration * 60000).toISOString();
                    _currentMember.timedOutUntil = until;
                    refreshMuteButton();
                    loadMemberSanctions(m.id);
                } else if (action === 'unmute') {
                    _currentMember.timedOutUntil = null;
                    refreshMuteButton();
                    loadMemberSanctions(m.id);
                }
            } catch(e) { showAlert('Erreur', 'Erreur réseau.'); }
        }

        async function deleteWarn(warnId) {
            if (!_currentMember) return;
            try {
                const res  = await safeFetch(`/shardguard/api/guild/<%= guild.id %>/member/${_currentMember.id}/action`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ action: 'deletewarn', warnId, username: _currentMember.username })
                });
                const data = await res.json();
                if (!data.success) return;
                _currentMember.warns = Math.max(0, _currentMember.warns - 1);
                const unBtn = document.getElementById('mm-unwarn-btn');
                if (unBtn) unBtn.classList.toggle('invisible', _currentMember.warns === 0);
                const idx = _allMembers.findIndex(x => x.id === _currentMember.id);
                if (idx !== -1) _allMembers[idx].warns = _currentMember.warns;
                loadMemberSanctions(_currentMember.id);
                renderMembers();
            } catch(e) {}
        }

        async function deleteSanction(sanctionId) {
            if (!_currentMember) return;
            try {
                const res = await safeFetch(`/shardguard/api/guild/<%= guild.id %>/member/${_currentMember.id}/action`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ action: 'deletesanction', sanctionId, username: _currentMember.username })
                });
                const data = await res.json();
                if (!data.success) return;
                loadMemberSanctions(_currentMember.id);
            } catch(e) {}
        }

        async function clearAllSanctions() {
            if (!_currentMember) return;
            try {
                const res = await safeFetch(`/shardguard/api/guild/<%= guild.id %>/member/${_currentMember.id}/action`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ action: 'clearall', username: _currentMember.username })
                });
                const data = await res.json();
                if (!data.success) return;
                _currentMember.warns = 0;
                const idx = _allMembers.findIndex(x => x.id === _currentMember.id);
                if (idx !== -1) _allMembers[idx].warns = 0;
                loadMemberSanctions(_currentMember.id);
                renderMembers();
                showNotification('Sanctions', `Toutes les sanctions de ${_currentMember.displayName} ont été supprimées.`);
            } catch(e) {}
        }

        function closeMemberModal() {
            document.getElementById('member-modal').classList.add('hidden');
            document.getElementById('member-modal').classList.remove('flex');
            _currentMember = null;
        }
        document.getElementById('member-modal').addEventListener('click', function(e) {
            if (e.target === this) closeMemberModal();
        });

        const _origShowSection = showSection;
        showSection = function(name, el) {
            _origShowSection(name, el);
            if (name === 'members' && !_membersLoaded) loadMembers();
        };

        const _sectionNames = {
            general: 'Général', rules: 'Règlement', logs: 'Logs',
            members: 'Membres', verification: 'Captcha', warns: 'Avertissements',
            modroles: 'Rôles de Modération', bannedwords: 'Mots Interdits',
            automod: 'Auto-Modération', audit: 'Audit'
        };

        let _searchIndex = [];

        function buildSearchIndex() {
            _searchIndex = [];
            document.querySelectorAll('.content-section').forEach(section => {
                const id = section.id.replace('section-', '');
                const sectionName = _sectionNames[id] || id;
                section.querySelectorAll('h3, label, .shard-card > div > div > h3, [class*="tracking-widest"]').forEach(el => {
                    const text = el.textContent.trim();
                    if (text.length < 3 || text.length > 80) return;
                    const card = el.closest('.shard-card') || el;
                    _searchIndex.push({ text, sectionId: id, sectionName, el: card });
                });
            });
        }

        let _lastSearch = '';
        function handleSearch(query) {
            _lastSearch = query.trim().toLowerCase();
            showSearchResults();
        }

        function showSearchResults() {
            const box = document.getElementById('search-results');
            const query = _lastSearch;
            if (!query) { box.classList.add('hidden'); return; }
            if (_searchIndex.length === 0) buildSearchIndex();
            const matches = _searchIndex.filter(e => e.text.toLowerCase().includes(query));
            const seen = new Set();
            const unique = matches.filter(m => {
                const key = m.sectionId + '|' + m.text;
                if (seen.has(key)) return false;
                seen.add(key); return true;
            }).slice(0, 8);
            if (!unique.length) {
                box.innerHTML = '<div class="px-3 py-4 text-center text-[10px] text-white/20 uppercase tracking-widest">Aucun résultat</div>';
            } else {
                box.innerHTML = unique.map((m, i) =>
                    `<div class="search-result-item" data-idx="${i}">
                        <span class="sri-label">${m.text}</span>
                        <span class="sri-section">${m.sectionName}</span>
                    </div>`
                ).join('');
                box.querySelectorAll('.search-result-item').forEach((el, i) => {
                    el.addEventListener('mousedown', (e) => {
                        e.preventDefault();
                        const match = unique[i];
                        const navItem = document.querySelector(`.nav-item[onclick*="'${match.sectionId}'"]`);
                        if (navItem) showSection(match.sectionId, navItem);
                        setTimeout(() => {
                            match.el.scrollIntoView({ behavior: 'smooth', block: 'center' });
                            match.el.classList.add('search-highlight');
                            setTimeout(() => match.el.classList.remove('search-highlight'), 1200);
                        }, 100);
                        document.getElementById('global-search').value = '';
                        _lastSearch = '';
                        box.classList.add('hidden');
                    });
                });
            }
            box.classList.remove('hidden');
        }

        document.addEventListener('click', (e) => {
            if (!document.getElementById('global-search-wrap').contains(e.target)) {
                document.getElementById('search-results').classList.add('hidden');
            }
        });

        async function doBackupSG() {
            try {
                const r = await fetch('/guild/<%= guild.id %>/backup', { method: 'POST' });
                const data = await r.json();
                if (data.success) showNotification('Backup', 'Backup créé avec succès !', 'success');
                else showNotification('Erreur', data.error || 'Erreur lors du backup', 'error');
            } catch { showNotification('Erreur', 'Erreur réseau', 'error'); }
        }

        async function doRestoreSG() {
            if (!confirm('⚠️ Restaurer le dernier backup ? La configuration actuelle sera écrasée.')) return;
            try {
                const r = await fetch('/guild/<%= guild.id %>/restore', { method: 'POST' });
                const data = await r.json();
                if (data.success) { showNotification('Restauration', 'Configuration restaurée !', 'success'); setTimeout(() => location.reload(), 1500); }
                else showNotification('Erreur', data.error || 'Erreur lors de la restauration', 'error');
            } catch { showNotification('Erreur', 'Erreur réseau', 'error'); }
        }

        async function triggerPanic() {
            const btn = document.getElementById('panic-btn');
            const badge = document.getElementById('panic-status-badge');
            const isActive = badge.textContent.trim() === 'LOCKDOWN ACTIF';
            const msg = isActive
                ? 'Désactiver le lockdown et rouvrir tous les salons ?'
                : '⚠️ ATTENTION — Activer le lockdown va bloquer tous les salons. Confirmer ?';
            if (!confirm(msg)) return;
            btn.disabled = true;
            btn.textContent = 'En cours…';
            try {
                const r = await fetch('/shardguard/api/guild/<%= guild.id %>/panic', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ activate: !isActive })
                });
                const data = await r.json();
                if (data.success) {
                    if (!isActive) {
                        badge.textContent = 'LOCKDOWN ACTIF';
                        badge.className = 'ml-auto px-3 py-1 rounded-full text-xs font-bold bg-red-500/20 text-red-400';
                        btn.className = 'flex items-center gap-2 px-6 py-3 rounded-[14px] text-sm font-bold transition-all bg-white/10 text-white/60 hover:bg-white/15';
                        btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg> Désactiver le lockdown';
                        showNotification('Lockdown', `${data.count || 0} salons verrouillés`, 'error');
                    } else {
                        badge.textContent = 'Inactif';
                        badge.className = 'ml-auto px-3 py-1 rounded-full text-xs font-bold bg-white/5 text-white/30';
                        btn.className = 'flex items-center gap-2 px-6 py-3 rounded-[14px] text-sm font-bold transition-all bg-red-500/20 text-red-400 hover:bg-red-500/30 border border-red-500/20';
                        btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg> Activer le lockdown';
                        showNotification('Lockdown', `${data.count || 0} salons déverrouillés`, 'success');
                    }
                } else {
                    showNotification('Erreur', data.error || 'Erreur lors du lockdown', 'error');
                    btn.disabled = false;
                    btn.textContent = isActive ? 'Désactiver le lockdown' : 'Activer le lockdown';
                }
            } catch {
                showNotification('Erreur', 'Erreur réseau', 'error');
                btn.disabled = false;
                btn.textContent = isActive ? 'Désactiver le lockdown' : 'Activer le lockdown';
            }
        }

    </script>
</body>
</html>