<!DOCTYPE html>
<html lang="fr" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ShardGuard | Configuration</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
    <style>
        :root {
            --bg: #000000;
            --text: #ffffff;
            --accent: #ffffff;
            --muted: #888888;
            --border: #1a1a1a;
            --sidebar-width: 280px;
        }
        
        body { 
            font-family: 'Plus Jakarta Sans', sans-serif; 
            background: #000;
            background-image: 
                radial-gradient(at 50% 0%, rgba(37, 99, 235, 0.15) 0px, transparent 50%),
                radial-gradient(at 100% 100%, rgba(37, 99, 235, 0.05) 0px, transparent 50%);
            background-attachment: fixed;
            color: var(--text); 
            margin: 0;
            padding: 0;
            display: flex;
            height: 100vh;
            overflow: hidden;
        }

        .bg-glow {
            position: fixed;
            top: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 100%;
            height: 100vh;
            background: radial-gradient(circle at 50% -20%, rgba(37, 99, 235, 0.1) 0%, transparent 70%);
            pointer-events: none;
            z-index: -1;
        }

        /* Sidebar Custom */
        .sidebar {
            width: var(--sidebar-width);
            background: transparent;
            border-right: 1px solid rgba(255,255,255,0.05);
            display: flex;
            flex-direction: column;
            padding: 28px 20px;
            z-index: 50;
            overflow: hidden;
            flex-shrink: 0;
        }

        .nav-item {
            padding: 12px 16px;
            border-radius: 12px;
            cursor: pointer;
            color: var(--muted);
            font-weight: 600;
            margin-bottom: 4px;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            gap: 12px;
            border: 1px solid transparent;
            font-size: 0.875rem;
        }

        .nav-item:hover {
            background: rgba(255,255,255,0.03);
            color: var(--text);
        }

        .nav-item.active {
            background: #fff;
            color: #000;
            margin-left: 8px;
            margin-right: 8px;
        }

        .nav-item svg {
            width: 18px;
            height: 18px;
        }

        /* Content Area */
        .main-content {
            flex: 1;
            overflow-y: auto;
            position: relative;
        }
        .main-body {
            padding: 40px 60px 40px;
        }
        #global-search-wrap {
            position: absolute;
            top: 40px;
            right: 60px;
            width: 260px;
            z-index: 40;
        }

        .content-section { display: none; width: 100%; }
        .content-section.active { display: block; animation: fadeIn 0.4s ease; }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .success-checkmark {
            display: flex;
            align-items: center;
            justify-content: center;
            animation: successScale 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
        }

        .success-checkmark svg {
            stroke-dasharray: 100;
            stroke-dashoffset: 100;
            animation: drawCheck 1.2s ease forwards 0.5s;
        }

        .success-checkmark circle {
            stroke-dasharray: 100;
            stroke-dashoffset: 100;
            animation: drawCircle 1s ease forwards;
        }

        @keyframes drawCircle { to { stroke-dashoffset: 0; } }
        @keyframes drawCheck { to { stroke-dashoffset: 0; } }
        @keyframes successScale { from { transform: scale(0.5); opacity: 0; } to { transform: scale(1); opacity: 1; } }

        .shard-card {
            background: #0a0a0a;
            border: 1px solid #1a1a1a;
            padding: 32px;
            border-radius: 24px;
            margin-bottom: 24px;
        }

        .sanction-row:hover .sanction-trash { color: rgba(255,255,255,0.4) !important; }
        .sanction-trash:hover { color: rgba(255,255,255,0.75) !important; }

        /* Forms */
        .field { margin-bottom: 24px; }
        label { 
            display: block; 
            margin-bottom: 8px; 
            font-weight: 700; 
            font-size: 0.7rem; 
            color: var(--muted); 
            text-transform: uppercase; 
            letter-spacing: 1.5px; 
        }

        input[type="text"], input[type="number"] { 
            width: 100%; 
            padding: 14px 18px; 
            background: rgba(255, 255, 255, 0.03); 
            border: 1px solid #1a1a1a; 
            color: white; 
            border-radius: 14px; 
            font-size: 0.9rem;
            font-family: inherit;
            outline: none;
            transition: all 0.2s;
            box-sizing: border-box;
        }

        input[type="text"]:focus, input[type="number"]:focus { 
            border-color: #fff; 
            background: rgba(255, 255, 255, 0.05);
        }

        ::placeholder { color: rgba(255,255,255,0.25); }

        /* Custom Dropdown Styling */
        .custom-select-wrapper { position: relative; width: 100%; }
        .custom-select-trigger {
            width: 100%; 
            padding: 14px 18px; 
            background: rgba(255, 255, 255, 0.03); 
            border: 1px solid #1a1a1a; 
            color: white; 
            border-radius: 14px; 
            font-size: 0.9rem;
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            align-items: center;
            transition: all 0.2s;
        }
        .custom-select-trigger:after {
            content: "";
            width: 8px; height: 8px;
            border-right: 2px solid #555;
            border-bottom: 2px solid #555;
            transform: rotate(45deg);
            margin-bottom: 4px;
        }
        .custom-select-wrapper.open .custom-select-trigger { border-color: #fff; }
        .custom-options {
            position: absolute;
            top: calc(100% + 8px); left: 0; right: 0;
            background: #0f0f0f;
            border: 1px solid #1a1a1a;
            border-radius: 14px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            display: none;
            z-index: 1000;
            max-height: 250px;
            overflow-y: auto;
            backdrop-filter: blur(20px);
        }
        .custom-select-wrapper.open .custom-options { display: block; }
        .custom-option {
            padding: 10px 18px;
            cursor: pointer;
            transition: all 0.2s;
            font-size: 0.85rem;
            color: var(--muted);
        }
        .custom-option:hover { background: rgba(255,255,255,0.05); color: #fff; }
        .custom-option.selected { background: rgba(255,255,255,0.1); color: #fff; font-weight: 700; }
        .hidden-select { display: none; }

        /* Save Bar */
        .footer-bar {
            position: fixed;
            bottom: 32px;
            right: 40px;
            background: rgba(10, 10, 10, 0.8);
            backdrop-filter: blur(20px);
            padding: 12px 24px;
            border-radius: 100px;
            border: 1px solid #1a1a1a;
            display: flex;
            align-items: center;
            gap: 24px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.4);
            z-index: 100;
            opacity: 0;
            pointer-events: none;
            transform: translateY(20px);
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .footer-bar.visible { opacity: 1; pointer-events: all; transform: translateY(0); }

        .btn-white {
            background: #fff;
            color: #000;
            padding: 10px 24px;
            border-radius: 100px;
            font-weight: 700;
            font-size: 0.875rem;
            transition: opacity 0.2s;
            cursor: pointer;
            border: none;
        }
        .btn-white:hover { opacity: 0.9; }

        /* Scrollbar */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.1); border-radius: 10px; }
        
        .status-pill { 
            padding: 4px 10px; 
            border-radius: 8px; 
            font-size: 0.65rem; 
            font-weight: 800; 
            text-transform: uppercase;
            display: inline-flex;
            align-items: center;
            gap: 4px;
        }
        .status-success { background: rgba(34, 197, 94, 0.1); color: #4ade80; }
        .status-failed { background: rgba(239, 68, 68, 0.1); color: #f87171; }

        .rule-item {
            display: flex;
            align-items: center;
            gap: 12px;
            background: rgba(255, 255, 255, 0.02);
            padding: 6px 12px;
            border-radius: 12px;
            border: 1px solid #1a1a1a;
            margin-bottom: 8px;
        }
        .rule-input { background: transparent !important; border: none !important; padding: 10px 0 !important; }
        nav::-webkit-scrollbar { display: none; }
        nav { scrollbar-width: none; }
        .search-result-item { display: flex; flex-direction: column; gap: 2px; padding: 8px 12px; cursor: pointer; transition: background 0.15s; border-bottom: 1px solid rgba(255,255,255,0.04); }
        .search-result-item:last-child { border-bottom: none; }
        .search-result-item:hover { background: rgba(255,255,255,0.05); }
        .search-result-item .sri-label { font-size: 11px; font-weight: 600; color: rgba(255,255,255,0.8); }
        .search-result-item .sri-section { font-size: 9px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: rgba(255,255,255,0.25); }
        .search-highlight { animation: searchPulse 1.2s ease; }
        @keyframes searchPulse { 0%,100% { background: transparent; } 30% { background: rgba(255,255,255,0.08); } }
    </style>
</head>
<body>
    <div class="bg-glow"></div>

    <aside class="sidebar" id="sidebar">
        <div class="mb-8">
            <a href="/shardguard/server" class="flex items-center gap-2 text-white/40 hover:text-white transition-colors text-xs font-bold uppercase tracking-widest px-2">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"></path></svg>
                Retour aux serveurs
            </a>
        </div>

        <div class="mb-10">
            <div class="text-xs font-bold text-white/30 uppercase mb-3 tracking-widest px-2">Application</div>
            <div class="relative group" id="botSelector">
                <div class="flex items-center gap-3 p-2 bg-white/[0.03] border border-white/10 rounded-xl cursor-pointer hover:bg-white/[0.06] transition-all" onclick="toggleBotDropdown()">
                    <img src="/image/shardguard.png" class="w-6 h-6 rounded-md" alt="ShardGuard">
                    <div class="flex-1 min-w-0">
                        <div class="font-bold text-sm truncate">ShardGuard</div>
                    </div>
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-white/20"><path d="m6 9 6 6 6-6"></path></svg>
                </div>
                <!-- Dropdown -->
                <div id="botDropdown" class="absolute left-0 right-0 top-full mt-2 p-1 bg-[#0f0f0f]/90 backdrop-blur-xl border border-white/10 rounded-xl opacity-0 invisible transition-all z-50">
                    <div class="text-[9px] font-bold text-white/20 uppercase px-2 pt-2 pb-1 tracking-widest">Changer d'application</div>
                    <a href="/shardguard/guild/<%= guild.id %>" class="flex items-center gap-2 p-2 rounded-lg bg-white/[0.06] border border-white/10 mb-1 cursor-default">
                        <img src="/image/shardguard.png" class="w-5 h-5 rounded-md" alt="ShardGuard">
                        <span class="font-bold text-sm">ShardGuard</span>
                        <span class="ml-auto text-[9px] font-bold text-blue-400 uppercase tracking-widest">Actif</span>
                    </a>
                    <a href="/shard/guild/<%= guild.id %>" class="flex items-center gap-2 p-2 rounded-lg hover:bg-white/[0.04] transition-colors">
                        <img src="/image/shard.png" class="w-5 h-5 rounded-md" alt="Shard">
                        <span class="font-bold text-sm">Shard</span>
                    </a>
                </div>
            </div>
        </div>

        <script>
            function toggleBotDropdown() {
                const dropdown = document.getElementById('botDropdown');
                dropdown.classList.toggle('opacity-0');
                dropdown.classList.toggle('invisible');
            }
            // Fermer si clic ailleurs
            window.addEventListener('click', function(e) {
                if (!document.getElementById('botSelector').contains(e.target)) {
                    const dropdown = document.getElementById('botDropdown');
                    dropdown.classList.add('opacity-0');
                    dropdown.classList.add('invisible');
                }
            });
        </script>

        <nav class="flex-1 overflow-y-auto min-h-0">
            <div class="nav-item active" onclick="showSection('general', this)">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="9" y1="3" x2="9" y2="21"></line></svg>
                Général
            </div>
            <div class="nav-item" onclick="showSection('rules', this)">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line></svg>
                Règlement
            </div>
            <div class="nav-item" onclick="showSection('logs', this)">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"></path><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path></svg>
                Logs
            </div>

            <div class="text-xs font-bold text-white/20 uppercase mt-6 mb-2 tracking-widest px-2">Membres</div>

            <div class="nav-item" onclick="showSection('members', this)">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                Gestionnaire
            </div>

            <div class="text-xs font-bold text-white/20 uppercase mt-6 mb-2 tracking-widest px-2">Modération</div>

            <div class="nav-item" onclick="showSection('verification', this)">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
                Captcha
            </div>
            <div class="nav-item" onclick="showSection('warns', this)">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
                Avertissements
            </div>
            <div class="nav-item" onclick="showSection('modroles', this)">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                Rôles de Modération
            </div>
            <div class="nav-item" onclick="showSection('bannedwords', this)">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path><line x1="9" y1="10" x2="15" y2="10"></line></svg>
                Mots Interdits
            </div>
            <div class="nav-item" onclick="showSection('automod', this)">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
                Auto-Modération
            </div>

        </nav>

        <div class="mt-auto p-4 bg-white/5 rounded-2xl border border-white/5">
            <div class="text-[10px] font-bold text-white/30 uppercase mb-3 tracking-widest">Serveur Actif</div>
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center overflow-hidden">
                    <% if (guild.icon) { %>
                        <img src="https://cdn.discordapp.com/icons/<%= guild.id %>/<%= guild.icon %>.png" class="w-full h-full object-cover">
                    <% } else { %>
                        <span class="font-bold text-white/20"><%= guild.name[0] %></span>
                    <% } %>
                </div>
                <div class="font-bold text-sm truncate"><%= guild.name %></div>
            </div>
        </div>
    </aside>

    <main class="main-content">
        <div id="global-search-wrap">
            <input id="global-search" type="text" placeholder="Rechercher un paramètre..." autocomplete="off"
                class="w-full bg-white/[0.04] border border-white/10 rounded-xl px-3 py-2 text-xs text-white/70 placeholder-white/20 outline-none focus:border-white/20 transition-colors"
                oninput="handleSearch(this.value)" onfocus="showSearchResults()" />
            <div id="search-results" class="hidden absolute right-0 left-0 top-full mt-1 bg-[#0f0f0f]/95 backdrop-blur-xl border border-white/10 rounded-xl overflow-hidden z-50 max-h-64 overflow-y-auto"></div>
        </div>
        <div class="main-body">
        <form action="/shardguard/guild/<%= guild.id %>/config" method="POST" id="configForm">
            <!-- Section Général -->
            <div id="section-general" class="content-section active">
                <div class="mb-12">
                    <p class="text-xs font-bold tracking-widest text-white/30 uppercase mb-2">Configuration</p>
                    <h1 class="text-3xl font-bold uppercase">Général</h1>
                </div>

                <div class="grid grid-cols-2 gap-6 mb-8">
                    <div class="shard-card">
                        <p class="text-[10px] font-bold text-white/30 uppercase mb-1 tracking-widest">Membres</p>
                        <p class="text-3xl font-bold"><%= stats.totalMembers %></p>
                    </div>
                    <div class="shard-card border-green-500/30">
                        <p class="text-[10px] font-bold text-green-500/50 uppercase mb-1 tracking-widest">Statut du Bot</p>
                        <p class="text-3xl font-bold text-green-500 flex items-center gap-2">
                            <span class="w-3 h-3 rounded-full bg-green-500 shrink-0 inline-block" style="box-shadow:0 0 8px rgba(34,197,94,0.6)"></span>En ligne
                        </p>
                    </div>
                </div>

                <div class="shard-card">
                    <div class="field">
                        <label>Langue du Bot</label>
                        <div class="custom-select-wrapper">
                            <div class="custom-select-trigger" onclick="toggleDropdown(this)">
                                <span><%= settings.language === 'en' ? 'English (🇺🇸)' : 'Français (🇫🇷)' %></span>
                            </div>
                            <div class="custom-options">
                                <div class="custom-option <%= settings.language === 'fr' ? 'selected' : '' %>" data-value="fr" onclick="selectOption(this, 'language')">Français (🇫🇷)</div>
                                <div class="custom-option <%= settings.language === 'en' ? 'selected' : '' %>" data-value="en" onclick="selectOption(this, 'language')">English (🇺🇸)</div>
                            </div>
                            <select name="language" class="hidden-select">
                                <option value="fr" <%= settings.language === 'fr' ? 'selected' : '' %>>fr</option>
                                <option value="en" <%= settings.language === 'en' ? 'selected' : '' %>>en</option>
                            </select>
                        </div>
                    </div>
                    
                    <div class="field">
                        <label>Rôle de Vérification</label>
                        <div class="custom-select-wrapper">
                            <% const currentRole = roles.find(r => r.id === settings.verifiedRole); %>
                            <div class="custom-select-trigger" onclick="toggleDropdown(this)">
                                <span><%= currentRole ? currentRole.name : '-- Aucun rôle --' %></span>
                            </div>
                            <div class="custom-options">
                                <div class="custom-option <%= !settings.verifiedRole ? 'selected' : '' %>" data-value="" onclick="selectOption(this, 'verifiedRole')">-- Aucun rôle --</div>
                                <% roles.forEach(role => { %>
                                    <% if (role.name !== '@everyone') { %>
                                        <div class="custom-option <%= settings.verifiedRole === role.id ? 'selected' : '' %>" data-value="<%= role.id %>" onclick="selectOption(this, 'verifiedRole')">
                                            <%= role.name %>
                                        </div>
                                    <% } %>
                                <% }) %>
                            </div>
                            <select name="verifiedRole" class="hidden-select">
                                <option value="">none</option>
                                <% roles.forEach(role => { %>
                                    <option value="<%= role.id %>" <%= settings.verifiedRole === role.id ? 'selected' : '' %>><%= role.id %></option>
                                <% }) %>
                            </select>
                        </div>
                    </div>

                    <div class="field">
                        <label>Salon de Vérification</label>
                        <div class="flex gap-4">
                            <div class="custom-select-wrapper flex-1">
                                <% const currentChannel = channels.find(c => c.id === settings.verificationChannelId); %>
                                <div class="custom-select-trigger" onclick="toggleDropdown(this)">
                                    <span><%= currentChannel ? '# ' + currentChannel.name : '-- Sélectionner un salon --' %></span>
                                </div>
                                <div class="custom-options">
                                    <div class="custom-option <%= !settings.verificationChannelId ? 'selected' : '' %>" data-value="" onclick="selectOption(this, 'verificationChannelId')">-- Sélectionner un salon --</div>
                                    <% channels.forEach(channel => { %>
                                        <div class="custom-option <%= settings.verificationChannelId === channel.id ? 'selected' : '' %>" data-value="<%= channel.id %>" onclick="selectOption(this, 'verificationChannelId')">
                                            # <%= channel.name %>
                                        </div>
                                    <% }) %>
                                </div>
                                <select name="verificationChannelId" id="verificationChannelId" class="hidden-select">
                                    <option value="">none</option>
                                    <% channels.forEach(channel => { %>
                                        <option value="<%= channel.id %>" <%= settings.verificationChannelId === channel.id ? 'selected' : '' %>><%= channel.id %></option>
                                    <% }) %>
                                </select>
                            </div>
                            <button type="button" onclick="deploySpecific('verification', event)" class="btn-white px-8">Envoyer</button>
                        </div>
                    </div>

                    <div class="field">
                        <label>Verrouillage Serveur</label>
                        <div class="custom-select-wrapper">
                            <div class="custom-select-trigger" onclick="toggleDropdown(this)">
                                <span><%= settings.serverLocked === 'true' ? 'Verrouillé (Code requis)' : 'Ouvert à tous' %></span>
                            </div>
                            <div class="custom-options">
                                <div class="custom-option <%= settings.serverLocked === 'false' ? 'selected' : '' %>" data-value="false" onclick="selectOption(this, 'serverLocked')">Ouvert à tous</div>
                                <div class="custom-option <%= settings.serverLocked === 'true' ? 'selected' : '' %>" data-value="true" onclick="selectOption(this, 'serverLocked')">Verrouillé (Code requis)</div>
                            </div>
                            <select name="serverLocked" class="hidden-select">
                                <option value="false" <%= settings.serverLocked === 'false' ? 'selected' : '' %>>false</option>
                                <option value="true" <%= settings.serverLocked === 'true' ? 'selected' : '' %>>true</option>
                            </select>
                        </div>
                    </div>

                    <div class="field">
                        <label>Code d'Accès</label>
                        <input type="text" name="accessCode" value="<%= settings.accessCode || '' %>" placeholder="SHARDTOWN">
                    </div>
                </div>

                <div class="shard-card mb-6">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="font-bold text-sm mb-1">Premium activé</p>
                        </div>
                        <div class="custom-select-wrapper" style="width:160px">
                            <div class="custom-select-trigger" onclick="toggleDropdown(this)">
                                <span><%= settings.isPremium ? 'Activé' : 'Désactivé' %></span>
                            </div>
                            <div class="custom-options">
                                <div class="custom-option <%= !settings.isPremium ? 'selected' : '' %>" data-value="0" onclick="selectOption(this,'isPremiumSG')">Désactivé</div>
                                <div class="custom-option <%= settings.isPremium ? 'selected' : '' %>" data-value="1" onclick="selectOption(this,'isPremiumSG')">Activé</div>
                            </div>
                            <select name="isPremiumSG" class="hidden-select">
                                <option value="0" <%= !settings.isPremium ? 'selected' : '' %>>0</option>
                                <option value="1" <%= settings.isPremium ? 'selected' : '' %>>1</option>
                            </select>
                        </div>
                    </div>
                </div>

            </div>

            <!-- Section Règlement -->
            <div id="section-rules" class="content-section">
                <div class="mb-12">
                    <p class="text-xs font-bold tracking-widest text-white/30 uppercase mb-2">Configuration</p>
                    <h1 class="text-3xl font-bold uppercase">Règlement</h1>
                </div>

                <div class="grid grid-cols-2 gap-8">
                    <div class="shard-card">
                        <div class="flex items-center justify-between mb-8">
                            <h3 class="font-bold uppercase text-xs tracking-widest">Version Française 🇫🇷</h3>
                            <button type="button" onclick="addRule('fr')" class="text-[10px] font-bold uppercase tracking-widest px-3 py-1 bg-white/5 rounded-full border border-white/10 hover:bg-white/10 transition-colors">+ Ajouter</button>
                        </div>
                        <div id="rules_fr_container" class="rules-list">
                            <% const rulesFr = settings.rules_fr ? (typeof settings.rules_fr === 'string' ? JSON.parse(settings.rules_fr) : settings.rules_fr) : []; %>
                            <% rulesFr.forEach(rule => { %>
                                <div class="rule-item">
                                    <div class="w-2 h-2 rounded-full bg-white/20 shrink-0"></div>
                                    <input type="text" name="rules_fr[]" class="rule-input" value="<%= rule %>">
                                    <button type="button" class="p-2 text-red-500/50 hover:text-red-500 transition-colors" onclick="this.parentElement.remove(); checkChanges();">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"></path><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"></path><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"></path></svg>
                                    </button>
                                </div>
                            <% }) %>
                        </div>
                    </div>

                    <div class="shard-card">
                        <div class="flex items-center justify-between mb-8">
                            <h3 class="font-bold uppercase text-xs tracking-widest">Version Anglaise 🇺🇸</h3>
                            <button type="button" onclick="addRule('en')" class="text-[10px] font-bold uppercase tracking-widest px-3 py-1 bg-white/5 rounded-full border border-white/10 hover:bg-white/10 transition-colors">+ Ajouter</button>
                        </div>
                        <div id="rules_en_container" class="rules-list">
                            <% const rulesEn = settings.rules_en ? (typeof settings.rules_en === 'string' ? JSON.parse(settings.rules_en) : settings.rules_en) : []; %>
                            <% rulesEn.forEach(rule => { %>
                                <div class="rule-item">
                                    <div class="w-2 h-2 rounded-full bg-white/20 shrink-0"></div>
                                    <input type="text" name="rules_en[]" class="rule-input" value="<%= rule %>">
                                    <button type="button" class="p-2 text-red-500/50 hover:text-red-500 transition-colors" onclick="this.parentElement.remove(); checkChanges();">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"></path><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"></path><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"></path></svg>
                                    </button>
                                </div>
                            <% }) %>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Section Vérification -->
            <div id="section-verification" class="content-section">
                <div class="mb-12">
                    <p class="text-xs font-bold tracking-widest text-white/30 uppercase mb-2">Configuration</p>
                    <h1 class="text-3xl font-bold uppercase">Système Captcha</h1>
                </div>

                <div class="shard-card">
                    <div class="grid grid-cols-2 gap-8">
                        <div class="field">
                            <label>Nombre de Chiffres</label>
                            <input type="number" name="captchaDigits" value="<%= settings.captchaDigits || 6 %>" min="4" max="8">
                        </div>
                        <div class="field">
                            <label>Niveau de Bruit</label>
                            <div class="custom-select-wrapper">
                                <div class="custom-select-trigger" onclick="toggleDropdown(this)">
                                    <span><%= settings.captchaNoise === 'high' ? 'Élevé' : (settings.captchaNoise === 'low' ? 'Faible' : 'Moyen') %></span>
                                </div>
                                <div class="custom-options">
                                    <div class="custom-option <%= settings.captchaNoise === 'low' ? 'selected' : '' %>" data-value="low" onclick="selectOption(this, 'captchaNoise')">Faible</div>
                                    <div class="custom-option <%= settings.captchaNoise === 'medium' ? 'selected' : '' %>" data-value="medium" onclick="selectOption(this, 'captchaNoise')">Moyen</div>
                                    <div class="custom-option <%= settings.captchaNoise === 'high' ? 'selected' : '' %>" data-value="high" onclick="selectOption(this, 'captchaNoise')">Élevé</div>
                                </div>
                                <select name="captchaNoise" class="hidden-select">
                                    <option value="low" <%= settings.captchaNoise === 'low' ? 'selected' : '' %>>low</option>
                                    <option value="medium" <%= settings.captchaNoise === 'medium' ? 'selected' : '' %>>medium</option>
                                    <option value="high" <%= settings.captchaNoise === 'high' ? 'selected' : '' %>>high</option>
                                </select>
                            </div>
                        </div>
                        <div class="field">
                            <label>Nombre d'Essais</label>
                            <input type="number" name="captchaAttempts" value="<%= settings.captchaAttempts || 3 %>" min="1" max="5">
                        </div>
                        <div class="field">
                            <label>Temps Limite (minutes)</label>
                            <input type="number" name="verificationTimeout" value="<%= settings.verificationTimeout || 15 %>" min="5" max="60">
                        </div>
                    </div>
                </div>

                <div class="shard-card mt-8">
                    <h3 class="font-bold text-xs uppercase tracking-wider mb-6 text-white/30">Actions Rapides</h3>
                    <div class="flex gap-4">
                        <button type="button" onclick="bulkAction('verify', this)" class="flex-1 p-4 bg-white/5 rounded-2xl text-sm font-bold uppercase border border-white/5 hover:bg-green-500/10 hover:border-green-500/20 hover:text-green-500 transition-all">
                            Vérifier tout le monde
                        </button>
                        <button type="button" onclick="bulkAction('kick', this)" class="flex-1 p-4 bg-white/5 rounded-2xl text-sm font-bold uppercase border border-white/5 hover:bg-red-500/10 hover:border-red-500/20 hover:text-red-500 transition-all">
                            Expulser les non-vérifiés
                        </button>
                    </div>
                </div>
            </div>

            <!-- Section Statistiques -->
            <div id="section-stats" class="content-section">
                <div class="mb-12">
                    <p class="text-xs font-bold tracking-widest text-white/30 uppercase mb-2">Données</p>
                    <h1 class="text-3xl font-bold uppercase">Analyses</h1>
                </div>

                <div class="grid grid-cols-2 gap-8">
                    <div class="shard-card">
                        <h3 class="font-bold text-xs uppercase tracking-widest mb-8">Flux des Membres (14j)</h3>
                        <div style="height:300px">
                            <canvas id="growthChart"></canvas>
                        </div>
                    </div>
                    <div class="shard-card">
                        <h3 class="font-bold text-xs uppercase tracking-widest mb-8">Performance Vérification</h3>
                        <div style="height:300px">
                            <canvas id="verificationChart"></canvas>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Section Logs -->
            <div id="section-logs" class="content-section">
                <div class="flex items-center justify-between mb-8">
                    <div>
                        <p class="text-xs font-bold tracking-widest text-white/30 uppercase mb-2">Activités</p>
                        <h1 class="text-3xl font-bold uppercase">Logs</h1>
                    </div>
                </div>

                <!-- Filtres -->
                <div class="shard-card mb-6">
                    <div class="grid grid-cols-3 gap-4">
                        <div class="field mb-0">
                            <label>Recherche</label>
                            <input type="text" id="log-search" placeholder="Nom d'utilisateur ou ID..." oninput="applyLogFilters()">
                        </div>
                        <div class="field mb-0">
                            <label>Type d'action</label>
                            <div class="custom-select-wrapper">
                                <div class="custom-select-trigger" onclick="toggleDropdown(this)">
                                    <span>Tous</span>
                                </div>
                                <div class="custom-options">
                                    <div class="custom-option selected" data-value="all" onclick="selectLogFilter(this, 'event')">Tous</div>
                                    <div class="custom-option" data-value="Arrivée" onclick="selectLogFilter(this, 'event')">Arrivée</div>
                                    <div class="custom-option" data-value="Départ" onclick="selectLogFilter(this, 'event')">Départ</div>
                                    <div class="custom-option" data-value="Captcha" onclick="selectLogFilter(this, 'event')">Captcha</div>
                                    <div class="custom-option" data-value="Warn" onclick="selectLogFilter(this, 'event')">Warn</div>
                                    <div class="custom-option" data-value="Auto-Mute" onclick="selectLogFilter(this, 'event')">Auto-Mute</div>
                                    <div class="custom-option" data-value="Auto-Kick" onclick="selectLogFilter(this, 'event')">Auto-Kick</div>
                                    <div class="custom-option" data-value="Auto-Ban" onclick="selectLogFilter(this, 'event')">Auto-Ban</div>
                                    <div class="custom-option" data-value="Timeout" onclick="selectLogFilter(this, 'event')">Timeout</div>
                                    <div class="custom-option" data-value="Access Code" onclick="selectLogFilter(this, 'event')">Access Code</div>
                                </div>
                                <select id="log-event-filter" class="hidden-select">
                                    <option value="all">Tous</option>
                                </select>
                            </div>
                        </div>
                        <div class="field mb-0">
                            <label>Statut</label>
                            <div class="custom-select-wrapper">
                                <div class="custom-select-trigger" onclick="toggleDropdown(this)">
                                    <span>Tous</span>
                                </div>
                                <div class="custom-options">
                                    <div class="custom-option selected" data-value="all" onclick="selectLogFilter(this, 'status')">Tous</div>
                                    <div class="custom-option" data-value="Join" onclick="selectLogFilter(this, 'status')">Rejoints</div>
                                    <div class="custom-option" data-value="Leave" onclick="selectLogFilter(this, 'status')">Partis</div>
                                    <div class="custom-option" data-value="Réussi" onclick="selectLogFilter(this, 'status')">Réussis</div>
                                    <div class="custom-option" data-value="Échoué" onclick="selectLogFilter(this, 'status')">Échoués</div>
                                    <div class="custom-option" data-value="Kicked" onclick="selectLogFilter(this, 'status')">Expulsés</div>
                                    <div class="custom-option" data-value="Success" onclick="selectLogFilter(this, 'status')">Success</div>
                                    <div class="custom-option" data-value="Failed" onclick="selectLogFilter(this, 'status')">Failed</div>
                                </div>
                                <select id="log-status-filter" class="hidden-select">
                                    <option value="all">Tous</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="shard-card p-0 overflow-hidden">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-white/5 border-b border-white/5 text-[10px] font-bold uppercase tracking-widest text-white/40">
                                <th class="p-6">Date</th>
                                <th class="p-6">Utilisateur</th>
                                <th class="p-6">Action</th>
                                <th class="p-6 text-right">Statut</th>
                            </tr>
                        </thead>
                        <tbody id="logs-tbody">
                            <% logs.forEach(log => { %>
                                <%
                                    const logStatus = log.status.toLowerCase();
                                    const isSuccess = logStatus.includes('success') || logStatus.includes('réussi') || logStatus.includes('join') || logStatus.includes('arrivée');
                                %>
                                <tr class="log-row border-b border-white/5 hover:bg-white/[0.02] transition-colors"
                                    data-event="<%= log.event %>"
                                    data-status="<%= log.status %>"
                                    data-user="<%= log.username %> <%= log.userId %>">
                                    <td class="p-6 text-xs text-white/40 font-bold"><%= new Date(log.timestamp).toLocaleString('fr-FR', { day: '2-digit', month: '2-digit', hour: '2-digit', minute: '2-digit' }) %></td>
                                    <td class="p-6">
                                        <div class="font-bold text-sm"><%= log.username %></div>
                                        <div class="text-[10px] text-white/20 font-mono"><%= log.userId %></div>
                                    </td>
                                    <td class="p-6 text-xs font-bold uppercase tracking-widest text-white/60"><%= log.event %></td>
                                    <td class="p-6 text-right">
                                        <span class="status-pill <%= isSuccess ? 'status-success' : 'status-failed' %>">
                                            <%= log.status %>
                                        </span>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                    <div id="logs-empty" class="hidden p-10 text-center text-white/20 text-xs">Aucun log ne correspond aux filtres.</div>
                </div>
            </div>

            <!-- Section Avertissements -->
            <div id="section-warns" class="content-section">
                <div class="mb-12">
                    <p class="text-xs font-bold tracking-widest text-white/30 uppercase mb-2">Modération</p>
                    <h1 class="text-3xl font-bold uppercase">Avertissements</h1>
                </div>

                <div class="shard-card mb-6">
                    <h3 class="font-bold text-sm uppercase tracking-widest mb-2">Seuils de Punition Automatique</h3>
                    <p class="text-xs text-white/30 mb-6 leading-relaxed">Quand un membre atteint le nombre d'avertissements configuré, l'action est déclenchée automatiquement. Mettez 0 pour désactiver un seuil.</p>
                    <div class="grid grid-cols-2 gap-6">
                        <div class="field mb-0">
                            <label>Mute après X warns (0 = désactivé)</label>
                            <input type="number" name="warnThresholdMute" value="<%= settings.warnThresholdMute || 0 %>" min="0" max="50" placeholder="0">
                        </div>
                        <div class="field mb-0">
                            <label>Durée du mute (minutes)</label>
                            <input type="number" name="warnMuteDuration" value="<%= settings.warnMuteDuration || 60 %>" min="1" max="10080" placeholder="60">
                        </div>
                        <div class="field mb-0">
                            <label>Kick après X warns (0 = désactivé)</label>
                            <input type="number" name="warnThresholdKick" value="<%= settings.warnThresholdKick || 0 %>" min="0" max="50" placeholder="0">
                        </div>
                        <div class="field mb-0">
                            <label>Ban après X warns (0 = désactivé)</label>
                            <input type="number" name="warnThresholdBan" value="<%= settings.warnThresholdBan || 0 %>" min="0" max="50" placeholder="0">
                        </div>
                    </div>
                </div>

                <div class="shard-card bg-blue-500/5 border-blue-500/10">
                    <div class="flex items-start gap-4">
                        <div class="w-8 h-8 rounded-lg bg-blue-500/10 flex items-center justify-center text-blue-400 shrink-0 mt-0.5">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
                        </div>
                        <div>
                            <p class="text-sm font-bold text-blue-400 mb-1">Commande <code class="bg-white/5 px-1 rounded">/warn</code></p>
                            <p class="text-xs text-white/40 leading-relaxed">Utilisez <strong>/warn @membre raison</strong> sur votre serveur. Les modérateurs ayant les rôles configurés peuvent l'utiliser. Les avertissements sont stockés en base de données et comptabilisés par serveur.</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Section Rôles de Modération -->
            <div id="section-modroles" class="content-section">
                <div class="mb-12">
                    <p class="text-xs font-bold tracking-widest text-white/30 uppercase mb-2">Modération</p>
                    <h1 class="text-3xl font-bold uppercase">Rôles de Modération</h1>
                </div>
                <input type="hidden" name="modRoles" id="modRolesInput" value="<%= settings.modRoles || '[]' %>">

                <div class="shard-card mb-6">
                    <p class="text-xs text-white/40 leading-relaxed mb-6">Les membres possédant un de ces rôles pourront utiliser les commandes de modération du bot (ban, kick, mute, warn…).</p>
                    <div class="flex flex-wrap gap-3" id="modRolesGrid">
                        <%
                            let modRolesArr = [];
                            try { modRolesArr = JSON.parse(settings.modRoles || '[]'); } catch(e) {}
                        %>
                        <% roles.forEach(role => { %>
                            <% if (role.name !== '@everyone') { %>
                                <%
                                    const roleColor = role.color ? '#' + role.color.toString(16).padStart(6, '0') : '#555';
                                    const isSelected = modRolesArr.includes(role.id);
                                %>
                                <button type="button"
                                    data-role-id="<%= role.id %>"
                                    onclick="toggleModRole(this)"
                                    class="mod-role-btn flex items-center gap-2 px-4 py-2 rounded-full border text-sm font-bold transition-all duration-200 <%= isSelected ? 'border-green-500/40 bg-green-500/10 text-green-400' : 'border-white/5 bg-white/[0.02] text-white/30 hover:text-white/60 hover:border-white/10' %>"
                                    data-selected="<%= isSelected %>">
                                    <span class="w-2.5 h-2.5 rounded-full shrink-0" style="background-color: <%= roleColor %>"></span>
                                    <%= role.name %>
                                </button>
                            <% } %>
                        <% }) %>
                        <% if (roles.filter(r => r.name !== '@everyone').length === 0) { %>
                            <p class="text-white/20 text-sm">Aucun rôle disponible sur ce serveur.</p>
                        <% } %>
                    </div>
                </div>

                <div class="shard-card bg-blue-500/5 border-blue-500/10">
                    <div class="flex items-start gap-4">
                        <div class="w-8 h-8 rounded-lg bg-blue-500/10 flex items-center justify-center text-blue-400 shrink-0 mt-0.5">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
                        </div>
                        <div>
                            <p class="text-sm font-bold text-blue-400 mb-1">Information</p>
                            <p class="text-xs text-white/40 leading-relaxed">Les administrateurs (permission Administrateur Discord) peuvent toujours utiliser les commandes de modération, même sans rôle sélectionné ici.</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Section Mots Interdits -->
            <div id="section-bannedwords" class="content-section">
                <div class="mb-12">
                    <p class="text-xs font-bold tracking-widest text-white/30 uppercase mb-2">Modération</p>
                    <h1 class="text-3xl font-bold uppercase">Mots Interdits</h1>
                </div>

                <div class="shard-card mb-6">
                    <div class="grid grid-cols-2 gap-8 mb-8">
                        <div class="field mb-0">
                            <label>Statut du Filtre</label>
                            <div class="custom-select-wrapper">
                                <div class="custom-select-trigger" onclick="toggleDropdown(this)">
                                    <span><%= settings.bannedWordsEnabled === 'true' ? 'Activé' : 'Désactivé' %></span>
                                </div>
                                <div class="custom-options">
                                    <div class="custom-option <%= settings.bannedWordsEnabled === 'false' ? 'selected' : '' %>" data-value="false" onclick="selectOption(this, 'bannedWordsEnabled')">Désactivé</div>
                                    <div class="custom-option <%= settings.bannedWordsEnabled === 'true' ? 'selected' : '' %>" data-value="true" onclick="selectOption(this, 'bannedWordsEnabled')">Activé</div>
                                </div>
                                <select name="bannedWordsEnabled" class="hidden-select">
                                    <option value="false" <%= settings.bannedWordsEnabled === 'false' ? 'selected' : '' %>>false</option>
                                    <option value="true" <%= settings.bannedWordsEnabled === 'true' ? 'selected' : '' %>>true</option>
                                </select>
                            </div>
                        </div>
                        <div class="field mb-0">
                            <label>Action automatique</label>
                            <div class="custom-select-wrapper">
                                <div class="custom-select-trigger" onclick="toggleDropdown(this)">
                                    <span><%=
                                        settings.bannedWordsAction === 'warn' ? 'Avertir l\'utilisateur' :
                                        settings.bannedWordsAction === 'mute' ? 'Mute (10 min)' :
                                        'Supprimer le message'
                                    %></span>
                                </div>
                                <div class="custom-options">
                                    <div class="custom-option <%= settings.bannedWordsAction === 'delete' ? 'selected' : '' %>" data-value="delete" onclick="selectOption(this, 'bannedWordsAction')">Supprimer le message</div>
                                    <div class="custom-option <%= settings.bannedWordsAction === 'warn' ? 'selected' : '' %>" data-value="warn" onclick="selectOption(this, 'bannedWordsAction')">Avertir l'utilisateur</div>
                                    <div class="custom-option <%= settings.bannedWordsAction === 'mute' ? 'selected' : '' %>" data-value="mute" onclick="selectOption(this, 'bannedWordsAction')">Mute (10 min)</div>
                                </div>
                                <select name="bannedWordsAction" class="hidden-select">
                                    <option value="delete" <%= settings.bannedWordsAction === 'delete' ? 'selected' : '' %>>delete</option>
                                    <option value="warn" <%= settings.bannedWordsAction === 'warn' ? 'selected' : '' %>>warn</option>
                                    <option value="mute" <%= settings.bannedWordsAction === 'mute' ? 'selected' : '' %>>mute</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="shard-card">
                    <div class="flex items-center justify-between mb-6">
                        <div>
                            <h3 class="font-bold uppercase text-xs tracking-widest">Liste Noire</h3>
