{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capabilities for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://shardtwn.fr/*" }
      ]
    },
    {
      "identifier": "shell:allow-open",
      "allow": [
        { "url": "https://shardtwn.fr/*" }
      ]
    }
  ]
}
