{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Shardtown",
  "version": "0.1.18",
  "identifier": "fr.shardtwn.dashboard",
  "build": {
    "beforeDevCommand": "cd ../status-app && npm run dev",
    "devUrl": "http://localhost:5174",
    "beforeBuildCommand": "cd ../status-app && npm run build",
    "frontendDist": "../../status-app/dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Shardtown",
        "label": "main",
        "width": 1100,
        "height": 760,
        "minWidth": 880,
        "minHeight": 600,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 14, "y": 14 },
        "backgroundColor": "#0a0a0a"
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost https://shardtwn.fr https://github.com https://*.githubusercontent.com; img-src 'self' data: https://cdn.discordapp.com https://shardtwn.fr; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns"
    ],
    "category": "DeveloperTool",
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://shardtwn.fr/updates/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc3Q0E3RkRBM0RBMTg5NTAKUldSUWlhRTkybi9LZHc2RGFFLzZnSG9oMzV4M0dtNHZOcGtXY1c5aXRxMm5YY2JyRFRET240NWMK",
      "windows": { "installMode": "passive" }
    }
  }
}
